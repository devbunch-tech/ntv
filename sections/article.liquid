{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'article.css' | asset_url | stylesheet_tag }}

{% liquid
  assign show_sidebar = false
  if section.settings.sidebar_show and section.blocks != blank
    assign show_sidebar = true
  endif

  assign design = section.settings.design

  assign animation_effect = settings.animations
  assign animated = false
  if animation_effect != 'none'
    assign animated = true
  endif

  assign article_class = 'm-article'
  assign article_class = article_class | append: ' m-article--' | append: design

  if show_sidebar
    if section.settings.sidebar_position == 'left_column'
      assign sidebar_class = 'sidebar-left'
    else
      assign sidebar_class = 'sidebar-right'
    endif
    assign article_class = article_class | append: ' m-article--' | append: sidebar_class
  else
    assign article_class = article_class | append: ' m-article--no-sidebar'
  endif

  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif
%}

<section data-section-type="article-template" data-section-id="{{ section.id }}" class="{{ article_class }}">
  <div class="{{ container }}">
    <div class="m-row{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
      <div class="m-article__wrapper">
        {%- if design == 'layout3' -%}
          {%- comment -%}Layout 3: Breadcrumbs > Blog Title > Article Title > Image > Meta+Social > Content > Tags > Comments > Related{%- endcomment -%}
          {% if section.settings.blog_show_breadcrumb %}
            {% render 'breadcrumb', justify: 'start' %}
          {% endif %}
          {% if section.settings.blog_show_blog_title %}
            <a class="m-article__blog" href="{{ blog.url }}">{{ blog.title }}</a>
          {% endif %}
          <div role="article" class="m-article__inner">
            <article>
              <div class="m-article__header m:text-left">
                <h1 class="m-article__title">{{ article.title }}</h1>
              </div>

              {%- if article.image -%}
                <div class="m-article__feature-image m:blocks-radius">
                  {% render 'responsive-image', image: article.image, image_class: 'w-full' %}
                </div>
              {%- endif -%}

              {% if section.settings.blog_show_author or section.settings.blog_show_date or section.settings.blog_show_social %}
                <div class="m-article__meta-row m:flex m:items-center m:justify-between m:gap-4">
                  <div class="m-article__meta m:flex m:items-center m:justify-between sm:m:justify-start m:gap-2 m:w-full sm:m:w-auto">
                    {% if section.settings.blog_show_date %}
                      <span>{% render 'date-format-br', date: article.published_at %}</span>
                    {% endif %}
                    {% if section.settings.blog_show_date and section.settings.blog_show_author %}
                      <span>•</span>
                    {% endif %}
                    {% if section.settings.blog_show_author %}
                      <span>{{ article.author }}</span>
                    {% endif %}
                  </div>
                  {% if section.settings.blog_show_social %}
                    <div class="m-article__share m:hidden sm:m:flex">
                      <span class="m-article__share-label">{{ 'blogs.article.share' | t }}</span>
                      <button type="button" class="m-article__share-btn" data-share-url="{{ shop.url | append: article.url }}" data-share-title="{{ article.title | escape }}" data-share-text="{{ article.excerpt | strip_html | truncate: 100 | escape }}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 15 15" fill="none">
                          <path d="M8.09688 2.64271L9.65521 1.08438C10.4344 0.305208 11.9927 0.305208 12.7719 1.08438L13.551 1.86354C14.3302 2.64271 14.3302 4.20104 13.551 4.98021L9.65521 8.87604C8.87604 9.65521 7.31771 9.65521 6.53854 8.87604M6.53854 11.9927L4.98021 13.551C4.20104 14.3302 2.64271 14.3302 1.86354 13.551L1.08438 12.7719C0.305208 11.9927 0.305208 10.4344 1.08438 9.65521L4.98021 5.75938C5.75938 4.98021 7.31771 4.98021 8.09688 5.75938" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </div>
                  {% endif %}
                </div>
              {% endif %}

              {% if article.content != blank %}
                <div class="m-article__content rte">
                  {{ article.content }}
                </div>
              {% endif %}

              {% if section.settings.blog_show_social %}
                <div class="m-article__share m:flex sm:m:hidden m:mb-8">
                  <span class="m-article__share-label">{{ 'blogs.article.share' | t }}</span>
                  <button type="button" class="m-article__share-btn" data-share-url="{{ shop.url | append: article.url }}" data-share-title="{{ article.title | escape }}" data-share-text="{{ article.excerpt | strip_html | truncate: 100 | escape }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 15 15" fill="none">
                      <path d="M8.09688 2.64271L9.65521 1.08438C10.4344 0.305208 11.9927 0.305208 12.7719 1.08438L13.551 1.86354C14.3302 2.64271 14.3302 4.20104 13.551 4.98021L9.65521 8.87604C8.87604 9.65521 7.31771 9.65521 6.53854 8.87604M6.53854 11.9927L4.98021 13.551C4.20104 14.3302 2.64271 14.3302 1.86354 13.551L1.08438 12.7719C0.305208 11.9927 0.305208 10.4344 1.08438 9.65521L4.98021 5.75938C5.75938 4.98021 7.31771 4.98021 8.09688 5.75938" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              {% endif %}

              {% if article.tags.size > 0 and section.settings.blog_show_tags %}
                <div class="m-article__footer">
                  <div class="m-article-tags">
                    <span class="m-article-tags__heading">{{ 'blogs.article.tags' | t }}</span>
                    {% for tag in article.tags %}
                      <a href="{{ blog.url }}/tagged/{{ tag | handle }}">{{ tag }}</a>
                      {%- unless forloop.last %},{% endunless %}
                    {% endfor %}
                  </div>
                </div>
              {% endif %}
            </article>
          </div>
        {%- else -%}
          {%- comment -%}Layout 1 and Layout 2{%- endcomment -%}
          {% if section.settings.blog_show_breadcrumb %}
            {% render 'breadcrumb', justify: 'center' %}
          {% endif %}
          {%- if design == 'layout2' and article.image -%}
            <div class="m-article__feature-image m:blocks-radius">
              {% render 'responsive-image', image: article.image, image_class: 'w-full' %}
            </div>
          {%- endif -%}
          <div role="article" class="m-article__inner">
            <article>
              <div class="m-article__header m:text-center">
                <a class="m-article__blog" href="{{ blog.url }}">{{ blog.title }}</a>
                <h1 class="m-article__title">{{ article.title }}</h1>
                {% if section.settings.blog_show_author or section.settings.blog_show_date %}
                  <div class="m-article__meta">
                    {% if section.settings.blog_show_author %}
                      {{ 'blogs.article.by_author' | t }}
                      <span>{{ article.author }}</span>
                    {% endif %}
                    {% if section.settings.blog_show_date %}
                      {% if section.settings.blog_show_author %}{{ 'blogs.article.posted_in' | t }}{% endif %}
                      <span>{% render 'date-format-br', date: article.published_at %}</span>
                    {% endif %}
                  </div>
                {% endif %}
              </div>

              {%- if design == 'layout1' and article.image -%}
                <div class="m-article__feature-image m:blocks-radius">
                  {% render 'responsive-image', image: article.image, image_class: 'w-full' %}
                </div>
              {%- endif -%}

              {% if article.content != blank %}
                <div class="m-article__content rte">
                  {{ article.content }}
                </div>
              {% endif %}

              {%- if section.settings.blog_show_social or section.settings.blog_show_tags -%}
                <div class="m-article__footer">
                  {% if article.tags.size > 0 and section.settings.blog_show_tags %}
                    <div class="m-article-tags">
                      <span class="m-article-tags__heading">{{ 'blogs.article.tags' | t }}</span>
                      {% for tag in article.tags %}
                        <a href="{{ blog.url }}/tagged/{{ tag | handle }}">{{ tag }}</a>
                        {%- unless forloop.last %},{% endunless %}
                      {% endfor %}
                    </div>
                  {% endif %}
                  {% if section.settings.blog_show_social %}
                    {% assign url = shop.url | append: article.url %}
                    {% render 'social-sharing', url: url, class: 'm:flex m:items-center' %}
                  {% endif %}
                </div>
              {% endif %}
        {%- endif -%}

            {%- comment -%}Navigation{%- endcomment -%}
            {% liquid
              assign article_navigation_class = 'm-article-navigation'

              if blog.previous_article != null and blog.next_article != null
                assign article_navigation_class = article_navigation_class | append: ' m-article-navigation--full m:justify-between'
              elsif blog.previous_article != null
                assign article_navigation_class = article_navigation_class | append: ' m:justify-start'
              else
                assign article_navigation_class = article_navigation_class | append: ' m:justify-end'
              endif
            %}
            <div class="{{ article_navigation_class }}">
              {% if blog.previous_article != null %}
                <a href="{{ blog.previous_article.url }}" class="m-article-navigation__prev">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"></path>
                  </svg>
                  <div class="m-article-navigation__inner">
                    <div class="m-article-navigation__label">{{ 'blogs.article.previous_post' | t }}</div>
                    <div class="m-article-navigation__article-title">{{ blog.previous_article.title }}</div>
                  </div>
                </a>
              {% endif %}
              {% if blog.next_article != null %}
                <a href="{{ blog.next_article.url }}" class="m-article-navigation__next">
                  <div class="m-article-navigation__inner m:text-right">
                    <div class="m-article-navigation__label">{{ 'blogs.article.next_post' | t }}</div>
                    <div class="m-article-navigation__article-title">{{ blog.next_article.title }}</div>
                  </div>
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                </a>
              {% endif %}
            </div>

            {%- comment -%}Related Posts - Layout 1/2 (before comments){%- endcomment -%}
            {%- if design != 'layout3' -%}
              {% if section.settings.show_related_articles %}
                <div class="m-related-posts">
                  <h3 class="m-related-posts__heading">{{ 'blogs.article.related_title' | t }}</h3>
                  <div class="m-related-posts__wrapper m-mixed-layout m-mixed-layout--mobile-scroll">
                    <div class="m-mixed-layout__inner m:grid m:grid-2-cols md:m:grid-3-cols">
                      {% liquid
                        assign currentID = article.id
                        assign counter = 0

                        for article in blog.articles limit: 4
                          if counter > 3
                            break
                          endif

                          if article.id == currentID
                            continue
                          endif

                          echo '<div class="m:column">'
                          render 'article-card', article: article, view: 'grid', content_align: section.settings.article_align_content, article_show_date: section.settings.article_show_date, article_show_author: section.settings.article_show_author, article_show_tags: section.settings.article_show_tags, article_show_excerpt: section.settings.article_show_excerpt, article_show_button: section.settings.article_show_button, animated: animated, animation_effect: animation_effect
                          echo '</div>'
                          assign counter = counter | plus: 1
                        endfor
                      %}
                    </div>
                  </div>
                </div>
              {% endif %}
            {%- endif -%}

            {%- comment -%}Comment{%- endcomment -%}
            {%- if blog.comments_enabled? and section.settings.blog_show_comment -%}
              {% liquid
                assign new_comment = false
                if comment and comment.created_at
                  assign new_comment = true
                  assign new_comment_id = comment.id
                endif

                if new_comment
                  assign duplicate_comment = false
                  for comment in article.comments
                    if comment.id == new_comment_id
                      assign duplicate_comment = true
                      break
                    endif
                  endfor

                  if duplicate_comment
                    assign number_of_comments = article.comments_count
                  else
                    assign number_of_comments = article.comments_count | plus: 1
                  endif
                else
                  assign number_of_comments = article.comments_count
                endif
              %}

              {% if number_of_comments > 0 %}
                <div class="m-comment-section">
                  <h3 class="m-comment-section__heading">
                    {{ 'blogs.comments.comments_with_count' | t: count: number_of_comments }}
                  </h3>
                  {% paginate article.comments by 5 %}
                    <div id="m-comments" class="m-comment-section__wrapper">
                      {% if comment and comment.status and comment.id != blank and paginate.current_page == 1 %}
                        <p class="m-comment-section__form-message">
                          {% if blog.moderated? and comment.status != 'published' %}
                            {{ 'blogs.comments.success_moderated' | t }}
                          {% else %}
                            {{ 'blogs.comments.success' | t }}
                          {% endif %}
                        </p>
                      {% endif %}

                      {% if article.comments_count > 0 %}
                        <ul class="m-comment-list">
                          {% if comment and comment.status != 'published' and comment.id != blank %}
                            <li id="{{ comment.id }}" class="m-comment m-comment--unpublished">
                              <div class="m-comment__author">
                                {{ comment.author }}
                              </div>
                              <div class="m-comment__content">
                                {{ comment.content }}
                              </div>
                            </li>
                          {% endif %}

                          {% for comment in article.comments %}
                            <li id="{{ comment.id }}" class="m-comment">
                              <div class="m-comment__meta">
                                <div class="m-comment__author">{{ comment.author }}</div>
                                <div class="m-comment__date">
                                  {{ comment.created_at | date: '%b %d, %Y' }}
                                  {{ 'blogs.comments.at_time' | t }}
                                  {{ comment.created_at | date: '%H:%M' }}
                                </div>
                              </div>
                              <div class="m-comment__content">
                                {{ comment.content }}
                              </div>
                              <a href="#m-leave-comment" class="m-comment__reply m-button m-button--link">
                                {{- 'blogs.comments.reply' | t -}}
                              </a>
                            </li>
                          {% endfor %}
                        </ul>

                        {% if paginate.pages > 1 %}
                          {% render 'pagination', paginate: paginate %}
                        {% endif %}
                      {% endif %}
                    </div>
                  {% endpaginate %}
                </div>
              {% endif %}

              <div class="m-comment-form" id="m-leave-comment">
                {% form 'new_comment', article %}
                  <div class="m-comment-form__header m:text-center">
                    <h3 class="m-comment-form__heading">{{ 'blogs.comments.title' | t }}</h3>
                    <p class="m-comment-form__text">{{ 'blogs.comments.sub_title' | t }}</p>
                  </div>

                  {% if form.errors %}
                    <ul>
                      {% for error in form.errors %}
                        <li class="notification warning show">
                          <svg
                            class="m-svg-icon"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                          </svg>
                          {% if error == 'form' %}
                            {{ form.errors.messages[error] }}
                          {% else %}
                            {{ form.errors.translated_fields[error] }} - {{ form.errors.messages[error] }}
                          {% endif %}
                        </li>
                      {% endfor %}
                    </ul>
                  {% endif %}

                  <div class="m-comment-form__message">
                    <label for="CommentBody" class="m:hidden">{{ 'blogs.comments.message' | t }}</label>
                    <textarea
                      name="comment[body]"
                      id="CommentBody"
                      class="form-field form-field--input"
                      placeholder="{{ 'blogs.comments.message' | t }}"
                      rows="6"
                    >
                  {{- form.body -}}
                  </textarea>
                  </div>

                  <div class="m-comment-form__fields">
                    <div>
                      <label for="CommentAuthor" class="m:hidden">
                        {{ 'blogs.comments.name' | t }}
                      </label>
                      <input
                        type="text"
                        name="comment[author]"
                        id="CommentAuthor"
                        class="form-field form-field--input"
                        placeholder="{{ 'blogs.comments.name' | t }}"
                        value="{{ form.author }}"
                        autocapitalize="words"
                      >
                    </div>
                    <div>
                      <label for="CommentEmail" class="m:hidden">
                        {{ 'blogs.comments.email' | t }}
                      </label>
                      <input
                        type="email"
                        name="comment[email]"
                        id="CommentEmail"
                        class="form-field form-field--input"
                        placeholder="{{ 'blogs.comments.email' | t }}"
                        value="{{ form.email }}"
                        spellcheck="false"
                        autocomplete="off"
                        autocapitalize="off"
                      >
                    </div>
                  </div>
                  <div class="m-comment-form__submit">
                    <input type="submit" class="m-button m-button--primary" value="{{ 'blogs.comments.post' | t }}">
                  </div>
                {% endform %}
              </div>
            {%- endif -%}

            {%- comment -%}Related Posts - Layout 3 (after comments){%- endcomment -%}
            {%- if design == 'layout3' -%}
              {% if section.settings.show_related_articles %}
                <div class="m-related-posts">
                  <h3 class="m-related-posts__heading h3">{{ 'blogs.article.related_title' | t }}</h3>
                  <div class="m-related-posts__wrapper m-mixed-layout m-mixed-layout--mobile-scroll">
                    <div class="m-mixed-layout__inner m:grid m:grid-2-cols md:m:grid-3-cols">
                      {% liquid
                        assign currentID = article.id
                        assign counter = 0

                        for article in blog.articles limit: 4
                          if counter > 3
                            break
                          endif

                          if article.id == currentID
                            continue
                          endif

                          echo '<div class="m:column">'
                          render 'article-card', article: article, view: 'grid', content_align: section.settings.article_align_content, article_show_date: section.settings.article_show_date, article_show_author: section.settings.article_show_author, article_show_tags: section.settings.article_show_tags, article_show_excerpt: section.settings.article_show_excerpt, article_show_button: section.settings.article_show_button, animated: animated, animation_effect: animation_effect
                          echo '</div>'
                          assign counter = counter | plus: 1
                        endfor
                      %}
                    </div>
                  </div>
                </div>
              {% endif %}
            {%- endif -%}
          </article>
        </div>
      </div>

      {% if show_sidebar %}
        <div class="m-blog-sidebar">
          {% render 'blog-sidebar' %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const shareBtns = document.querySelectorAll('.m-article__share-btn');
    const linkCopiedText = '{{ "blogs.article.link_copied" | t | default: "Link copiado!" }}';
    shareBtns.forEach(function(shareBtn) {
      shareBtn.addEventListener('click', async function() {
        const url = this.dataset.shareUrl;
        const title = this.dataset.shareTitle;
        const text = this.dataset.shareText;
        const shareBlock = this.closest('.m-article__share');
        const labelEl = shareBlock ? shareBlock.querySelector('.m-article__share-label') : null;

        if (navigator.share) {
          try {
            await navigator.share({
              title: title,
              text: text,
              url: url
            });
          } catch (err) {
            if (err.name !== 'AbortError') {
              console.log('Share error:', err);
            }
          }
        } else {
          try {
            await navigator.clipboard.writeText(url);
            if (labelEl) {
              var originalLabel = labelEl.textContent;
              labelEl.textContent = linkCopiedText;
              setTimeout(function() {
                labelEl.textContent = originalLabel;
              }, 2000);
            }
          } catch (err) {
            console.log('Clipboard error:', err);
          }
        }
      });
    });
  });
</script>

{%- comment -%}
  ===== STRUCTURED DATA: Article (schema.org 2026 best practices) =====
  - URL corrigido no mainEntityOfPage (article.url ao invés de page.url)
  - dateModified adicionado (updated_at)
  - inLanguage pt-BR
  - wordCount automático
  - Image como ImageObject com dimensões
  - Publisher com @id referenciando Organization e URL
  - author com URL do blog
{%- endcomment -%}
{%- assign article_word_count = article.content | strip_html | split: ' ' | size -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": {{ request.origin | append: article.url | json }}
  },
  "headline": {{ article.title | json }},
  {%- if article.excerpt != blank -%}
    "description": {{ article.excerpt | strip_html | truncate: 300 | json }},
  {%- endif -%}
  {%- if article.content != blank -%}
    "articleBody": {{ article.content | strip_html | truncate: 5000 | json }},
    "wordCount": {{ article_word_count }},
  {%- endif -%}
  "inLanguage": "pt-BR",
  {% if article.image %}
    "image": {
      "@type": "ImageObject",
      "url": {{ article | image_url: width: article.image.width | prepend: "https:" | json }},
      "width": {{ article.image.width }},
      "height": {{ article.image.height }}
    },
  {% endif %}
  "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
  "dateModified": {{ article.updated_at | default: article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
  "dateCreated": {{ article.created_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
  {%- if article.author != blank -%}
    "author": {
      "@type": "Person",
      "name": {{ article.author | json }},
      "url": {{ request.origin | append: blog.url | json }}
    },
  {%- else -%}
    "author": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    },
  {%- endif -%}
  "publisher": {
    "@type": "Organization",
    "@id": {{ request.origin | append: '/#organization' | json }},
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }}
    {%- if page_image -%}
      {%- assign pub_img_size = page_image.width -%}
      ,"logo": {
        "@type": "ImageObject",
        "url": {{ page_image | image_url: width: pub_img_size | prepend: "https:" | json }},
        "width": {{ page_image.width }},
        "height": {{ page_image.height }}
      }
    {%- endif -%}
  },
  {%- if blog -%}
    "isPartOf": {
      "@type": "Blog",
      "@id": {{ request.origin | append: blog.url | append: '#blog' | json }},
      "name": {{ blog.title | json }},
      "url": {{ request.origin | append: blog.url | json }}
    }
  {%- endif -%}
}
</script>
{% schema %}
{
  "name": "Blog post",
  "settings": [
    {
      "type": "paragraph",
      "content": "[Watch tutorial](https://foxecom.link/Xa07z7)"
    },
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Container type",
      "default": "container-fluid",
      "options": [
        {
          "value": "container-fluid",
          "label": "Default"
        },
        {
          "value": "w-full",
          "label": "Full width"
        },
        {
          "value": "container",
          "label": "Use container box"
        }
      ]
    },
    {
      "type": "header",
      "content": "Sidebar settings"
    },
    {
      "type": "checkbox",
      "id": "sidebar_show",
      "label": "Show sidebar",
      "default": true
    },
    {
      "type": "select",
      "id": "sidebar_position",
      "label": "Position",
      "default": "right_column",
      "options": [
        {
          "value": "left_column",
          "label": "Left column"
        },
