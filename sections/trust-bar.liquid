{{ 'trust-bar.css' | asset_url | stylesheet_tag }}
{{ 'scrolling-promotion.css' | asset_url | stylesheet_tag }}
<script src="{{ 'scrolling-promotion.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif

  assign classes = 'm-section m-trust-bar-section'
  if section.settings.custom_class != blank
    assign classes = classes | append: ' ' | append: section.settings.custom_class
  endif
  assign classes = classes | append: ' m-gradient' | append: ' m-color-' | append: section.settings.color_scheme
%}

<style>
  #m-section--{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --item-gap: {{ section.settings.item_gap }}px;
    --item-gap-mobile: {{ section.settings.item_gap_mobile }}px;
    --duration: {{ section.settings.speed }}s;
  }
</style>

<section
  id="m-section--{{ section.id }}"
  class="{{ classes }}"
  data-section-type="trust-bar"
  data-section-id="{{ section.id }}"
>
  <div class="{{ container }} m-section-py">
    {%- comment -%} Desktop: static grid {%- endcomment -%}
    <div class="m-trust-bar__desktop">
      {% for block in section.blocks %}
        <div class="m-trust-bar__item" {{ block.shopify_attributes }}>
          {% if block.settings.custom_svg != blank %}
            <span class="m-trust-bar__icon">
              {{- block.settings.custom_svg -}}
            </span>
          {% elsif block.settings.image != blank %}
            <span class="m-trust-bar__icon">
              <img
                src="{{ block.settings.image | image_url: width: 60 }}"
                alt="{{ block.settings.text | escape }}"
                width="30"
                height="30"
                loading="lazy"
              >
            </span>
          {% else %}
            <span class="m-trust-bar__icon">
              {{ 'product-1' | placeholder_svg_tag: 'm-placeholder-svg' }}
            </span>
          {% endif %}
          {% if block.settings.text != blank %}
            <span class="m-trust-bar__text">
              {{ block.settings.text }}
            </span>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {%- comment -%} Mobile: marquee animation {%- endcomment -%}
    <m-scrolling-promotion
      class="m-scrolling-promotion m-trust-bar__mobile m-scrolling-promotion--{{ section.settings.direction }}"
    >
      <div class="m-promotion">
        {% for block in section.blocks %}
          <div class="m-promotion__item" {{ block.shopify_attributes }}>
            {% if block.settings.custom_svg != blank %}
              <span class="m-promotion__icon m-promotion__icon--small">
                {{- block.settings.custom_svg -}}
              </span>
            {% elsif block.settings.image != blank %}
              <span class="m-trust-bar__icon--mobile">
                <img
                  src="{{ block.settings.image | image_url: width: 40 }}"
                  alt="{{ block.settings.text | escape }}"
                  width="20"
                  height="20"
                  loading="lazy"
                >
              </span>
            {% else %}
              <span class="m-trust-bar__icon--mobile">
                {{ 'product-1' | placeholder_svg_tag: 'm-placeholder-svg' }}
              </span>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="m-promotion__text" style="--text-size: {{ section.settings.mobile_text_size }}px;">
                {{ block.settings.text }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </m-scrolling-promotion>
  </div>
</section>

{% schema %}
{
  "name": "Trust bar",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Container type",
      "default": "container",
      "options": [
        {
          "value": "container-fluid",
          "label": "Default"
        },
        {
          "value": "w-full",
          "label": "Full width"
        },
        {
          "value": "container",
          "label": "Use container box"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Desktop settings"
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Gap between items",
      "min": 10,
      "max": 120,
      "step": 2,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Mobile settings (marquee)"
    },
    {
      "type": "range",
      "id": "item_gap_mobile",
      "label": "Gap between items",
      "min": 10,
      "max": 60,
      "step": 2,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_text_size",
      "label": "Text size",
      "min": 10,
      "max": 18,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Scroll direction",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 5,
      "max": 30,
      "step": 1,
      "default": 16,
      "unit": "s"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "default": 20,
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "default": 20,
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Custom Attributes"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom classes"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon image"
        },
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Icon (SVG code)",
          "info": "Overrides the image if provided"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Trust item text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust bar",
      "category": "Promotional",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "text": "CUPOM PRIMEIRA COMPRA: BEMVINDA10"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "PRIMEIRA TROCA GRÁTIS"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "PARCELAMENTO 6X SEM JUROS"
          }
        }
      ]
    }
  ]
}
{% endschema %}
