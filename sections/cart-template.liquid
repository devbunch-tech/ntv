<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{{ 'component-quantity-popover.css' | asset_url | stylesheet_tag }}
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
{%- liquid
  if linklists['gift-wrapping'].links != blank and linklists['gift-wrapping'].links.first.type == 'product_link'
    assign gift_wrapping = linklists['gift-wrapping'].links.first

    assign gift_wrap_id = gift_wrapping.object.variants.first.id
    assign gift_wraps_in_cart = 0
    for item in cart.items
      if item.id == gift_wrap_id
        assign gift_wraps_in_cart = item.quantity
        break
      endif
    endfor
    assign items_in_cart = cart.item_count | minus: gift_wraps_in_cart
  endif
-%}
{%- capture page_title -%}
    {{ 'cart.general.title' | t }}
{%- endcapture -%}
{% render 'page-title', title: page_title, container: 'container' %}
<div class="container">
  <m-cart
    class="m-cart"
    id="MinimogCart"
  >
    <form is="m-cart-form" id="cart-template-form" action="{{ routes.cart_url }}" method="post" novalidate>
      <div class="m-cart__wrapper m:w-full">
        <div class="m-cart__header" id="MinimogCartHeader">
          <div class="m-cart__header--wrapper{% if cart == empty %} m:hidden{% else %} m:flex{% endif %}">
            <div class="m-cart__column m-cart__column--product">{{ 'cart.label.product' | t }}</div>
            <div class="m-cart__column m-cart__column--price">{{ 'cart.label.price' | t }}</div>
            <div class="m-cart__column m-cart__column--quantity m:hidden md:m:block">
              {{ 'cart.label.quantity' | t }}
            </div>
            <div class="m-cart__column m-cart__column--subtotal m:text-right m:hidden md:m:block">
              {{ 'cart.label.total' | t }}
            </div>
          </div>
        </div>

        <m-cart-items
          class="m-cart__body"
          data-section-name="cart-template"
          id="MinimogCartBody"
        >
          {%- if cart.item_count > 0 -%}
            <div class="m-cart__items">
              {% for item in cart.items %}
                {% render 'cart-line-item', item: item %}
              {% endfor %}
            </div>
          {%- else -%}
            <div class="m-cart__empty">
              <h3 class="m:text-center m:text-xl">
                {{ 'cart.general.empty' | t }}
                <a href="{{ routes.all_products_collection_url }}" class="m-text-link">
                  {{ 'layout.back_to_shopping' | t }}
                </a>
              </h3>
            </div>
          {%- endif -%}
        </m-cart-items>
      </div>

      <div class="m-cart__footer m-cart-drawer__footer m:flex m:justify-end" id="MinimogCartFooter">
        <div class="m-cart__footer--wrapper m-cart-drawer__footer--wrapper m-cart-drawer__footer--estilo-2{% if cart == empty %} m:hidden{% else %} m:block{% endif %}">
          {% render 'cart-addons-estilo-2', form_id: 'cart-template-form' %}
          <div class="m-cart__gift-wrapping m-cart-drawer__gift-wrapping">
            {%- if gift_wrapping != null -%}
              <div class="m:hidden">{{ gift_wrapping.object.variants.first | json }}</div>
              <m-gift-wrapping-component
                class="m-gift-wrapping"
                data-gift-wrap-id="{{ gift_wrap_id }}"
                data-gift-wrapping="{{ cart.attributes.gift-wrapping | escape }}"
                cart-items-size="{{ cart.items.size }}"
                gift-wraps-in-cart="{{ gift_wraps_in_cart }}"
                items-in-cart="{{ items_in_cart }}"
              >
                <input
                  id="m-gift-wrapping-page"
                  type="checkbox"
                  name="attributes[gift-wrapping]"
                  value="yes"
                  {% if gift_wraps_in_cart > 0 %}
                    checked="checked"
                  {% endif %}
                  class="m:visually-hidden"
                >
                <label for="m-gift-wrapping-page" class="m-gift-wrapping--label">
                  {%- capture gift_price -%}<strong class="m-gift-wrapping--price">{{ gift_wrapping.object.price | money }}</strong>{%- endcapture -%}
                  <span class="m-gift-wrapping--text">
                    {{- 'cart.general.gift_wrapping_html' | t: price: gift_price -}}
                  </span>
                  <div class="m-gift-wrapping--loading">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
                      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                  </div>
                  <svg
                    class="m-gift-wrapping--icon"
                    viewBox="0 0 14 14"
                    with="16"
                    height="16"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <rect x="0.5" y="0.5" width="13" height="13" stroke="currentColor"/>
                    <path d="M3.5625 7.625L5.75 9.8125L10.75 4.8125" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </label>
                {%- if gift_wraps_in_cart > 0 -%}
                  <m-gift-note-component class="m-gift-wrapping--note">
                    <textarea
                      class="form-field"
                      name="attributes[gift-note]"
                      placeholder="{{ 'cart.general.gift_note_placeholder' | t }}"
                    >{{ cart.attributes.gift-note }}</textarea>
                  </m-gift-note-component>
                {%- endif -%}
              </m-gift-wrapping-component>
            {%- endif -%}
          </div>
          <div class="m-cart__summary m-cart-drawer__summary">
            <div data-foxkit-cart-summary></div>
            <div data-minimog-cart-discounts>
              {%- liquid
                assign discount_codes = cart.cart_level_discount_applications | where: 'type', 'discount_code' | map: 'title'
                assign cart_items_has_discount = false
                for item in cart.items
                  for allocation in item.line_level_discount_allocations
                    if allocation.discount_application.type == 'discount_code'
                      assign cart_items_has_discount = true
                    endif
                  endfor
                endfor
              -%}
              {%- if cart.cart_level_discount_applications.size > 0 or cart_items_has_discount -%}
                <ul class="m-cart__discount m:flex m:flex-wrap m:justify-end m:items-center" role="list" data-discounts-list>
                  {%- for discount in cart.cart_level_discount_applications -%}
                    {% render 'cart-discount-item', discount: discount %}
                  {%- endfor -%}
                  {%- if cart_items_has_discount -%}
                    {%- for item in cart.items -%}
                      {%- for allocation in item.line_level_discount_allocations -%}
                        {%- liquid
                          unless allocation.discount_application.type == 'discount_code'
                            continue
                          endunless

                          assign discount = allocation.discount_application

                          assign is_displayed = discount_codes | has: discount.title
                          if is_displayed
                            continue
                          endif

                          assign discount_codes = item.line_level_discount_allocations | slice: forloop.index0 | map: 'discount_application' | map: 'title' | concat: discount_codes
                        -%}
                        {% render 'cart-discount-item', discount: discount %}
                      {%- endfor -%}
                    {%- endfor -%}
                  {%- endif -%}
                </ul>
              {%- endif -%}
            </div>
            {%- liquid
              comment
                Estilo 2 (página do carrinho): cálculo do preço comparativo sempre ativo.
              endcomment
              assign cart_original_total = 0
              assign has_total_discount = false
              assign gift_discount_value = 0

              for item in cart.items
                if item.variant.compare_at_price != null and item.variant.compare_at_price > item.variant.price
                  assign item_original = item.variant.compare_at_price | times: item.quantity
                else
                  assign item_original = item.original_line_price
                endif
                assign cart_original_total = cart_original_total | plus: item_original
              endfor

              assign promo_threshold_type = settings.cart_drawer_promo_threshold_type | default: 'value'
              assign gift_goal_reached = false
              if promo_threshold_type == 'quantity'
                assign threshold_qty = settings.cart_drawer_promo_threshold_quantity | default: 3
                if cart.item_count >= threshold_qty
                  assign gift_goal_reached = true
                endif
              else
                assign promo_threshold = settings.cart_drawer_promo_threshold
                assign cart_total_value = cart.total_price | divided_by: 100.0
                if cart_total_value >= promo_threshold
                  assign gift_goal_reached = true
                endif
              endif
              if settings.cart_drawer_progress_type == 'gift' and settings.cart_drawer_gift_product != blank and gift_goal_reached and cart.item_count > 0
                assign gift_product = settings.cart_drawer_gift_product
                assign gift_variant = gift_product.selected_or_first_available_variant
                if gift_variant.compare_at_price != null and gift_variant.compare_at_price > 0
                  assign gift_discount_value = gift_variant.compare_at_price
                else
                  assign gift_discount_value = gift_variant.price
                endif
                assign cart_original_total = cart_original_total | plus: gift_discount_value
              endif

              assign cart_total_discount = cart_original_total | minus: cart.total_price
              if cart_total_discount > 0
                assign has_total_discount = true
              endif
            -%}
            {%- if has_total_discount -%}
              <div class="m-cart__pricing-breakdown">
                <div class="m-cart__pricing-row m-cart__pricing-subtotal">
                  <span class="m-cart__pricing-label">Subtotal</span>
                  <span class="m-cart__pricing-value">
                    {% if settings.currency_code_enabled %}
                      {{ cart_original_total | money_with_currency }}
                    {% else %}
                      {{ cart_original_total | money }}
                    {% endif %}
                  </span>
                </div>
                <div class="m-cart__pricing-row m-cart__pricing-discount">
                  <span class="m-cart__pricing-label">Descontos</span>
                  <span class="m-cart__pricing-value">
                    -{% if settings.currency_code_enabled %}{{ cart_total_discount | money_with_currency }}{% else %}{{ cart_total_discount | money }}{% endif %}
                  </span>
                </div>
              </div>
            {%- endif -%}
            <div class="m-cart__subtotal m-cart-drawer__subtotal-row m:flex m:justify-between m:items-center" data-cart-subtotal>
              <span class="m-cart__subtotal--label m:font-medium">{% if has_total_discount %}TOTAL{% else %}{{ 'cart.general.subtotal' | t }}{% endif %}</span>
              <span class="m-cart__subtotal--price m:font-medium" data-cart-subtotal-price>
                {% if settings.currency_code_enabled %}
                  {{ cart.total_price | money_with_currency }}
                {% else %}
                  {{ cart.total_price | money }}
                {% endif %}
              </span>
            </div>
          </div>
          <div class="m:flex m:flex-col m:items-center">
            {% assign show_terms = false %}
            {% if settings.agree_text != blank and settings.show_agree_on_cart %}
              <div class="m-terms-conditons">
                <label class="form-field--checkbox">
                  <input type="checkbox" name="agree_terms" value="yes" required>
                  <span class="form-field--checkbox__label">{{ settings.agree_text }}</span>
                  <span class="form-field--checkbox__icon">
                    <svg
                      class="m-svg-icon--medium"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                      focusable="false"
                      fill="none"
                      viewBox="0 0 20 20"
                    >
                      <path d="M18.5 1.5H1.5L1.5 18.5H18.5V1.5ZM1.5 0.5C0.947715 0.5 0.5 0.947715 0.5 1.5V18.5C0.5 19.0523 0.947715 19.5 1.5 19.5H18.5C19.0523 19.5 19.5 19.0523 19.5 18.5V1.5C19.5 0.947715 19.0523 0.5 18.5 0.5H1.5Z" fill-rule="evenodd" fill="currentColor"/>
                      <path d="M14.9975 6.09084C15.201 6.27746 15.2147 6.59375 15.0281 6.79728L8.91631 13.4627C8.82231 13.5652 8.68987 13.6239 8.55079 13.6247C8.41172 13.6256 8.27857 13.5684 8.18335 13.4671L4.99513 10.0731C4.80606 9.87179 4.81596 9.55536 5.01723 9.3663C5.21849 9.17723 5.53492 9.18713 5.72399 9.3884L8.54335 12.3897L14.291 6.12145C14.4776 5.91791 14.7939 5.90421 14.9975 6.09084Z" fill="currentColor"/>
                    </svg>
                  </span>
                </label>
              </div>
              {% assign show_terms = true %}
            {% endif %}
            <button
              type="submit"
              form="cart-template-form"
              name="checkout"
              class="m-button m-button--primary m:w-full"
              {% if show_terms %}
                data-terms-action disabled
              {% endif %}
            >
              <span>{{ 'cart.general.checkout' | t | upcase }}</span>
            </button>
            {%- if settings.cart_drawer_show_accelerated_button and additional_checkout_buttons -%}
              <div class="additional-checkout-buttons m:w-full">
                {{ content_for_additional_checkout_buttons }}
              </div>
            {%- endif -%}
          </div>
          {% if settings.cart_drawer_trust_badge_style == 'style_1' %}
            {% if settings.cart_drawer_trust_badge_text or settings.cart_drawer_trust_badge_image %}
              <div class="m-cart__trust-badge">
                {% if settings.cart_drawer_trust_badge_image %}
                  <img
                    src="{{ settings.cart_drawer_trust_badge_image | image_url: width: 200 }}"
                    loading="lazy"
                    width="200"
                    height="auto"
                    alt="Trust badge logo"
                  >
                {% endif %}
                {% if settings.cart_drawer_trust_badge_text %}
                  <span>{{ settings.cart_drawer_trust_badge_text }}</span>
                {% endif %}
              </div>
            {% endif %}
            {% if settings.cart_drawer_trust_badge %}
              <div class="m-cart__trust-badge">
                <img
                  src="{{ settings.cart_drawer_trust_badge | image_url: width: 840 }}"
                  loading="lazy"
                  width="400"
                  height="100"
                  alt="Trust secure badge"
                >
              </div>
            {% endif %}
          {% elsif settings.cart_drawer_trust_badge_style == 'style_2' and settings.cart_drawer_trust_badge_text != blank %}
            <div class="m-cart-drawer__benefits-bar m-cart-drawer__benefits-bar--cart-page">
              <div class="m-cart-drawer__benefits-item">
                {% if settings.cart_drawer_trust_badge_image %}
                  <img
                    src="{{ settings.cart_drawer_trust_badge_image | image_url: width: 28 }}"
                    loading="lazy"
                    width="14"
                    height="14"
                    alt=""
                  >
                {% else %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                    <path d="M5.73125 7.45675C5.35208 7.45908 4.98128 7.41844 4.61883 7.33483C4.25639 7.25122 3.9445 7.07856 3.68317 6.81683C3.47356 6.60761 3.31217 6.36844 3.199 6.09933C3.08544 5.83022 3.02867 5.54828 3.02867 5.2535C3.02867 5.12633 3.03742 5.00539 3.05492 4.89067C3.07203 4.77556 3.10256 4.65928 3.1465 4.54183C3.17061 4.47028 3.16828 4.40047 3.1395 4.33242C3.11072 4.26436 3.06522 4.21711 3.003 4.19067C2.93883 4.16461 2.87331 4.16656 2.80642 4.1965C2.73953 4.22644 2.69403 4.27739 2.66992 4.34933C2.62131 4.49517 2.583 4.64294 2.555 4.79267C2.527 4.942 2.513 5.09444 2.513 5.25C2.513 5.61633 2.58261 5.96575 2.72183 6.29825C2.86144 6.63075 3.05978 6.92553 3.31683 7.18258C3.61706 7.49214 3.97639 7.70117 4.39483 7.80967C4.81328 7.91856 5.23814 7.97397 5.66942 7.97592L5.10767 8.53825C5.0575 8.58842 5.03047 8.64753 5.02658 8.71558C5.02269 8.78364 5.04972 8.84644 5.10767 8.904C5.16561 8.96156 5.22647 8.99033 5.29025 8.99033C5.35403 8.99033 5.41508 8.96156 5.47342 8.904L6.36183 8.01558C6.45594 7.92108 6.503 7.81103 6.503 7.68542C6.503 7.5598 6.45594 7.44994 6.36183 7.35583L5.47342 6.46742C5.42286 6.41686 5.36375 6.38983 5.29608 6.38633C5.22803 6.38244 5.16522 6.40947 5.10767 6.46742C5.05011 6.52536 5.02133 6.58622 5.02133 6.65C5.02133 6.71378 5.05011 6.77483 5.10767 6.83317L5.73125 7.45675ZM4.77692 3.04033C5.15608 3.04033 5.52728 3.08194 5.8905 3.16517C6.25411 3.24839 6.56678 3.42086 6.8285 3.68258C7.03772 3.89219 7.19911 4.13156 7.31267 4.40067C7.42622 4.66978 7.48281 4.95172 7.48242 5.2465C7.48242 5.37367 7.47386 5.49461 7.45675 5.60933C7.43964 5.72406 7.40892 5.84014 7.36458 5.95758C7.34086 6.02953 7.34339 6.10011 7.37217 6.16933C7.40094 6.23856 7.44625 6.28619 7.50808 6.31225C7.57264 6.33831 7.63836 6.33831 7.70525 6.31225C7.77214 6.28619 7.81744 6.23719 7.84117 6.16525C7.88978 6.01942 7.92828 5.86931 7.95667 5.71492C7.98467 5.56053 7.99867 5.40556 7.99867 5.25C7.99867 4.88367 7.93003 4.53425 7.79275 4.20175C7.65547 3.86925 7.45714 3.57331 7.19775 3.31392C6.89519 3.00397 6.53469 2.79553 6.11625 2.68858C5.69819 2.58125 5.27333 2.52758 4.84167 2.52758L5.4075 1.96175C5.45494 1.91158 5.48061 1.85247 5.4845 1.78442C5.48839 1.71636 5.46156 1.65356 5.404 1.596C5.34644 1.53844 5.28539 1.50986 5.22083 1.51025C5.15628 1.51064 5.09542 1.53922 5.03825 1.596L4.14983 2.485C4.05533 2.5795 4.00808 2.68956 4.00808 2.81517C4.00808 2.94078 4.05533 3.05064 4.14983 3.14475L5.03825 4.03317C5.08842 4.08372 5.14753 4.11075 5.21558 4.11425C5.28364 4.11775 5.34644 4.09092 5.404 4.03375C5.46156 3.97658 5.49033 3.91553 5.49033 3.85058C5.49033 3.78564 5.46156 3.72478 5.404 3.668L4.77692 3.04033ZM5.25 10.5C4.52511 10.5 3.84339 10.3619 3.20483 10.0858C2.56628 9.80933 2.01075 9.43483 1.53825 8.96233C1.06536 8.48944 0.690861 7.93372 0.41475 7.29517C0.13825 6.65661 0 5.97489 0 5.25C0 4.52511 0.138056 3.84339 0.414167 3.20483C0.690278 2.56628 1.06497 2.01075 1.53825 1.53825C2.01153 1.06575 2.56706 0.691056 3.20483 0.414167C3.84378 0.138056 4.5255 0 5.25 0C5.9745 0 6.65622 0.138056 7.29517 0.414167C7.93372 0.690667 8.48925 1.06536 8.96175 1.53825C9.43464 2.01075 9.80914 2.56628 10.0852 3.20483C10.3617 3.84378 10.5 4.5255 10.5 5.25C10.5 5.9745 10.3619 6.65622 10.0858 7.29517C9.80933 7.93372 9.43483 8.48925 8.96233 8.96175C8.48944 9.43464 7.93372 9.80914 7.29517 10.0852C6.65661 10.3617 5.97489 10.5 5.25 10.5ZM5.25 9.91667C6.55278 9.91667 7.65625 9.46458 8.56042 8.56042C9.46458 7.65625 9.91667 6.55278 9.91667 5.25C9.91667 3.94722 9.46458 2.84375 8.56042 1.93958C7.65625 1.03542 6.55278 0.583333 5.25 0.583333C3.94722 0.583333 2.84375 1.03542 1.93958 1.93958C1.03542 2.84375 0.583333 3.94722 0.583333 5.25C0.583333 6.55278 1.03542 7.65625 1.93958 8.56042C2.84375 9.46458 3.94722 9.91667 5.25 9.91667Z" fill="currentColor"/>
                  </svg>
                {% endif %}
                <span>{{ settings.cart_drawer_trust_badge_text }}</span>
              </div>
              {% if settings.cart_drawer_trust_badge_text_2 != blank %}
                <div class="m-cart-drawer__benefits-divider"></div>
                <div class="m-cart-drawer__benefits-item">
                  {% if settings.cart_drawer_trust_badge_image_2 %}
                    <img
                      src="{{ settings.cart_drawer_trust_badge_image_2 | image_url: width: 28 }}"
                      loading="lazy"
                      width="14"
                      height="14"
                      alt=""
                    >
                  {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <path d="M1.66602 10.0002C1.66602 6.85766 1.66602 5.286 2.64268 4.31016C3.61935 3.33433 5.19018 3.3335 8.33268 3.3335H11.666C14.8085 3.3335 16.3802 3.3335 17.356 4.31016C18.3318 5.28683 18.3327 6.85766 18.3327 10.0002C18.3327 13.1427 18.3327 14.7143 17.356 15.6902C16.3793 16.666 14.8085 16.6668 11.666 16.6668H8.33268C5.19018 16.6668 3.61852 16.6668 2.64268 15.6902C1.66685 14.7135 1.66602 13.1427 1.66602 10.0002Z" stroke="#fff"/>
                      <path d="M8.33268 13.3335H4.99935M11.666 13.3335H10.416M1.66602 8.3335H18.3327" stroke="#fff" stroke-linecap="round"/>
                    </svg>
                  {% endif %}
                  <span>{{ settings.cart_drawer_trust_badge_text_2 }}</span>
                </div>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </form>
  </m-cart>
</div>
