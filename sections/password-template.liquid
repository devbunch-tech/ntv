{{ 'password-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .password-hero {
    --password-hero-highlight-color: {{ section.settings.highlight_color }};
  }
{%- endstyle -%}

<section class="password-hero">
  <div class="password-hero__image">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1920
        | image_tag:
          loading: 'eager',
          sizes: '(max-width: 767px) 100vw, 57vw',
          widths: '430, 768, 905, 1200, 1600, 1920'
      }}
    {%- else -%}
      <div class="password-hero__image-placeholder"></div>
    {%- endif -%}
    {%- if section.settings.logo_icon != blank -%}
      <div class="password-hero__logo-mark">
        {{ section.settings.logo_icon | image_url: width: 276 | image_tag: loading: 'eager' }}
      </div>
    {%- endif -%}
  </div>

  <div class="password-hero__content">
    <div class="password-hero__content-inner">
      {%- if section.settings.brand_logo != blank or section.settings.brand_name != blank -%}
        <div class="password-hero__brand">
          {%- if section.settings.brand_logo != blank -%}
            {{ section.settings.brand_logo | image_url: width: 400 | image_tag: loading: 'eager' }}
          {%- elsif section.settings.brand_name != blank -%}
            <p class="password-hero__brand-text">{{ section.settings.brand_name }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      <h1 class="password-hero__heading">
        {%- if section.settings.heading_text != blank -%}
          {{- section.settings.heading_text }}
        {%- endif -%}
        {%- if section.settings.heading_highlight != blank -%}
          {{ ' ' }}<strong>{{ section.settings.heading_highlight }}</strong>
        {%- endif -%}
        {%- if section.settings.heading_line_2 != blank -%}
          <br>{{- section.settings.heading_line_2 -}}
        {%- endif -%}
      </h1>

      {%- if section.settings.subheading != blank -%}
        <p class="password-hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.show_newsletter -%}
        <div class="password-hero__newsletter">
          {%- if section.settings.form_intro != blank -%}
            <p class="password-hero__form-intro">{{ section.settings.form_intro }}</p>
          {%- endif -%}

          {%- form 'customer', class: 'password-hero__form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="password-hero__form-fields">
              <input
                type="email"
                name="contact[email]"
                class="password-hero__input"
                placeholder="{{ section.settings.email_placeholder }}"
                autocomplete="email"
                required
                aria-label="{{ section.settings.email_placeholder }}"
              >
              <button type="submit" class="password-hero__submit" aria-label="{{ section.settings.button_text }}">
                <span>{{ section.settings.button_text }}</span>
                <svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M15.354 4.354a.5.5 0 000-.708l-3.182-3.182a.5.5 0 10-.708.708L14.293 4l-2.829 2.828a.5.5 0 10.708.708L15.354 4.354zM0 4.5h15v-1H0v1z" fill="currentColor"/>
                </svg>
              </button>
            </div>

            {%- if form.posted_successfully? -%}
              <p class="password-hero__success">{{ 'contact.form.post_success' | t }}</p>
            {%- endif -%}
            {%- if form.errors -%}
              <p class="password-hero__error">
                {{ form.errors.translated_fields['email'] | capitalize }}
                {{ form.errors.messages['email'] }}
              </p>
            {%- endif -%}
          {%- endform -%}

          {%- if section.settings.disclaimer != blank -%}
            <p class="password-hero__disclaimer password-hero__disclaimer--desktop">{{ section.settings.disclaimer }}</p>
          {%- endif -%}
          {%- if section.settings.disclaimer_mobile != blank -%}
            <p class="password-hero__disclaimer password-hero__disclaimer--mobile">{{ section.settings.disclaimer_mobile }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_password -%}
        <div class="password-hero__password-section">
          {%- if section.settings.password_intro != blank -%}
            <p class="password-hero__form-intro">{{ section.settings.password_intro }}</p>
          {%- endif -%}

          {%- form 'storefront_password', class: 'password-hero__form' -%}
            <div class="password-hero__form-fields">
              <input
                type="password"
                name="password"
                class="password-hero__input"
                placeholder="{{ section.settings.password_placeholder }}"
                aria-label="{{ section.settings.password_placeholder }}"
              >
              <button type="submit" class="password-hero__submit" aria-label="{{ section.settings.password_button_text }}">
                <span>{{ section.settings.password_button_text }}</span>
                <svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M15.354 4.354a.5.5 0 000-.708l-3.182-3.182a.5.5 0 10-.708.708L14.293 4l-2.829 2.828a.5.5 0 10.708.708L15.354 4.354zM0 4.5h15v-1H0v1z" fill="currentColor"/>
                </svg>
              </button>
            </div>
            {{ form.errors | default_errors }}
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Password Hero",
  "settings": [
    {
      "type": "header",
      "content": "Imagem"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagem principal"
    },
    {
      "type": "image_picker",
      "id": "logo_icon",
      "label": "Logo ícone (overlay na imagem)"
    },
    {
      "type": "header",
      "content": "Marca"
    },
    {
      "type": "image_picker",
      "id": "brand_logo",
      "label": "Logo da marca"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Nome da marca (se sem logo)",
      "default": "Onça Preta"
    },
    {
      "type": "header",
      "content": "Título"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Título (parte 1)",
      "default": "A experiência que"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Título (destaque em cor)",
      "default": "você merece."
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Título (segunda linha)",
      "default": "Em breve."
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Cor do destaque",
      "default": "#946625"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Novo visual, nova jornada, mesma Onça."
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Mostrar newsletter",
      "default": true
    },
    {
      "type": "text",
      "id": "form_intro",
      "label": "Texto introdutório do formulário",
      "default": "Fique por dentro antes de todo mundo."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Placeholder do e-mail",
      "default": "Seu melhor e-mail"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto do botão",
      "default": "Inscrever-se"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Texto de aviso — Desktop",
      "default": "Ao se cadastrar, você concorda com nossa Política de Privacidade. Cancele quando quiser."
    },
    {
      "type": "textarea",
      "id": "disclaimer_mobile",
      "label": "Texto de aviso — Mobile",
      "default": "Cancele quando quiser. Sem Spam."
    },
    {
      "type": "header",
      "content": "Senha"
    },
    {
      "type": "checkbox",
      "id": "show_password",
      "label": "Mostrar campo de senha",
      "default": false
    },
    {
      "type": "text",
      "id": "password_intro",
      "label": "Texto introdutório",
      "default": "Digite a senha para acessar o site"
    },
    {
      "type": "text",
      "id": "password_placeholder",
      "label": "Placeholder da senha",
      "default": "Digite a senha"
    },
    {
      "type": "text",
      "id": "password_button_text",
      "label": "Texto do botão de senha",
      "default": "Entrar"
    }
  ]
}
{% endschema %}