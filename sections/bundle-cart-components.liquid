{%- comment -%}
  Section para expor componentes de bundles no carrinho
  Usado pelo YampiSnippet para expandir bundles automaticamente
{%- endcomment -%}

{%- if settings.enable_bundle_expansion -%}
<script type="application/json" id="bundle-cart-data">
{
  "item_count": {{ cart.item_count }},
  "items": [
    {%- for item in cart.items -%}
    {
      "key": {{ item.key | json }},
      "variant_id": {{ item.variant_id }},
      "product_id": {{ item.product_id }},
      "title": {{ item.title | json }},
      "quantity": {{ item.quantity }},
      "has_components": {% if item.item_components.size > 0 %}true{% else %}false{% endif %},
      "item_components": [
        {%- for comp in item.item_components -%}
        {
          "variant_id": {{ comp.variant.id }},
          "product_id": {{ comp.product.id }},
          "title": {{ comp.product.title | json }},
          "quantity": {{ comp.quantity }}
        }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}
