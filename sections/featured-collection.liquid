{{ 'component-product-inventory.css' | asset_url | stylesheet_tag }}
{{ 'featured-collection.css' | asset_url | stylesheet_tag }}
<script src="{{ 'featured-collection.js' | asset_url }}" defer="defer"></script>
{% liquid
  assign enable_slider = section.settings.enable_slider
  assign mobile_disable_slider = section.settings.mobile_disable_slider
  assign current_collection = collections[section.settings.collection]
  assign items_per_row = section.settings.items_per_row
  assign product_to_show = section.settings.product_to_show | default: 8
  assign button_type = section.settings.button_type
  assign max_pages = section.settings.max_page_load
  assign show_button_on_header = section.settings.show_button_on_header
  assign split_by_color = section.settings.split_by_color_variant
  assign color_option_name = settings.pcard_option_name | default: 'Cor' | downcase

  comment
    Calcular o total de cards que serão exibidos
  endcomment
  assign total_cards = 0
  if split_by_color and current_collection != blank
    for product in current_collection.products
      if total_cards >= product_to_show
        break
      endif
      assign color_option = null
      for option in product.options_with_values
        assign option_name_downcase = option.name | downcase
        if option_name_downcase == color_option_name or option_name_downcase == 'color' or option_name_downcase == 'colour' or option_name_downcase == 'cor'
          assign color_option = option
          break
        endif
      endfor
      if color_option != null
        for color_value in color_option.values
          if total_cards >= product_to_show
            break
          endif
          assign total_cards = total_cards | plus: 1
        endfor
      else
        assign total_cards = total_cards | plus: 1
      endif
    endfor
  else
    if current_collection != blank
      assign total_cards = current_collection.products.size
      if total_cards > product_to_show
        assign total_cards = product_to_show
      endif
    else
      assign total_cards = product_to_show
    endif
  endif

  if current_collection != blank
    if total_cards <= items_per_row
      assign enable_slider = false
    endif
  else
    if product_to_show <= items_per_row
      assign enable_slider = false
    endif
  endif

  if button_type == 'load'
    assign show_button_on_header = false
  endif

  assign infinite_load = section.settings.infinite_load
  assign card_style = section.settings.pcard_layout
  assign image_ratio = section.settings.pcard_image_ratio
  assign show_vendor = section.settings.show_vendor
  assign hide_title = section.settings.hide_title
  assign use_scroll_mobile = section.settings.use_scroll_mobile
  assign enable_flashsale = section.settings.enable_flashsale
  assign show_countdown = false

  if card_style == null or card_style == blank
    assign card_style = settings.pcard_layout
  endif

  if enable_flashsale and section.settings.show_countdown
    assign show_countdown = true
  endif

  if paginate.pages < max_pages
    assign max_pages = paginate.pages
  endif

  assign animation_effect = settings.animations
  assign animated = false
  if animation_effect != 'none'
    assign animated = true
    if section.settings.animations != 'inherit'
      assign animation_effect = section.settings.animations
    endif
  endif

  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif

  assign button_loadmore_class = ''
  if enable_slider
    assign button_loadmore_class = 'md:m:hidden'
    if mobile_disable_slider
      if use_scroll_mobile
        assign button_loadmore_class = button_loadmore_class | append: ' m:hidden'
      else
        assign button_loadmore_class = button_loadmore_class | append: ' m:flex'
      endif
    else
      assign button_loadmore_class = button_loadmore_class | append: ' m:hidden'
    endif
  else
    assign button_loadmore_class = 'md:m:flex'
    if use_scroll_mobile
      assign button_loadmore_class = button_loadmore_class | append: ' m:hidden'
    else
      assign button_loadmore_class = button_loadmore_class | append: ' m:flex'
    endif
  endif

  assign classes = 'm-featured-collection'
  unless section.settings.show_header_navigation
    assign classes = classes | append: ' m-swiper-overflow'
  endunless
  if section.settings.button_text == blank
    assign classes = classes | append: ' show__more-disabled'
  endif
  if show_countdown
    assign classes = classes | append: ' m-featured-collection--show-countdown'
  endif
  if section.settings.custom_class != blank
    assign classes = classes | append: ' ' | append: section.settings.custom_class
  endif
  assign classes = classes | append: ' m-gradient' | append: ' m-color-' | append: section.settings.color_scheme
%}
{% comment %} Fix SEO {% endcomment %}
<style>
  #m-section--{{ section.id }} {
    --column-gap: {{ section.settings.item_gap }}px;
    --column-gap-mobile: {{ section.settings.item_gap_mobile }}px;
    --row-gap: {{ section.settings.item_gap | plus: 10 }}px;
    --row-gap-mobile: 30px;
    --items: {{ items_per_row }};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  }
</style>
{% paginate current_collection.products by product_to_show %}
  <section
    id="m-section--{{ section.id }}"
    class="m-section m-featured-collection-section"
  >
    <m-featured-collection
      data-id="{{ section.id }}"
      data-section-type="featured-collection"
      data-section-id="{{ section.id }}"
      data-enable-slider="{{ enable_slider }}"
      data-mobile-disable-slider="{{ section.settings.mobile_disable_slider }}"
      {% if enable_slider %}
        data-show-pagination="{{ section.settings.show_pagination }}"
        data-show-navigation="{{ section.settings.show_navigation }}"
      {% endif %}
      data-url="{{ current_collection.url }}"
      data-items="{{ items_per_row }}"
      data-total-pages="{{ paginate.pages }}"
      data-button-type="{{ button_type }}"
      {% if infinite_load %}
        data-infinite-load="{{ infinite_load }}"
        data-max-pages="{{ max_pages }}"
      {% endif %}
      class="{{ classes }}"
      data-enable-flashsale="{{ enable_flashsale }}"
      data-enable-countdown="{{ show_countdown }}"
      data-collection-id="{{ current_collection.id }}"
    >
      <div class="{{ container }} m-section-my m-section-py">
        {% if show_countdown %}
          <div class="m-section__header{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
            <h2 class="m-section__heading {{ section.settings.heading_size | default: 'h3' }}">
              <a href="{{ current_collection.url }}">{{ section.settings.heading }}</a>
            </h2>
            <div
              data-flashsale-countdown
              class="m-flashsale-countdown"
            >
              <div class="m-flashsale-countdown__wrapper">
                <div class="m-flashsale-countdown__box">
                  <span class="countdown-timer-day">00</span>
                </div>
                <div class="m-flashsale-countdown__box">
                  <span class="countdown-timer-hour">00</span>
                </div>
                <div class="m-flashsale-countdown__box">
                  <span class="countdown-timer-minute">00</span>
                </div>
                <div class="m-flashsale-countdown__box">
                  <span class="countdown-timer-sec">00</span>
                </div>
              </div>
            </div>
          </div>
        {% else %}
          {% render 'index-section-header',
            section_settings: section.settings,
            show_button_on_header: show_button_on_header,
            button_style: section.settings.button_style,
            button_link: current_collection.url,
            button_size: section.settings.button_size,
            button_label: section.settings.button_text,
            show_header_nav: section.settings.show_header_navigation,
            header_arrow_style: section.settings.arrow_style,
            inline_mobile: section.settings.inline_mobile_header
          %}
        {% endif %}

        <div class="m-product-list m-slider-control-hover-inside m-mixed-layout {% if mobile_disable_slider or enable_slider != true %} m-mixed-layout--mobile-grid{% if use_scroll_mobile %} m-mixed-layout--mobile-scroll{% endif %}{% endif %}">
          <div class="m-mixed-layout__wrapper{% if enable_slider %} swiper-container{% endif %}">
            <div
              class="m-mixed-layout__inner m:grid m-cols-{{ items_per_row }} m:grid-2-cols md:m:grid-{{ items_per_row | divided_by: 2.0 | ceil }}-cols lg:m:grid-3-cols xl:m:grid-{{ items_per_row }}-cols{% if enable_slider %} swiper-wrapper{% endif %}"
              data-products-container
            >
              {% if current_collection != blank %}
                {%- if split_by_color -%}
                  {%- comment -%} Modo separado por variante de cor {%- endcomment -%}
                  {%- assign card_index = 0 -%}
                  {%- for product in current_collection.products -%}
                    {%- if card_index >= product_to_show -%}
                      {%- break -%}
                    {%- endif -%}
                    
                    {%- liquid
                      assign color_option = null
                      for option in product.options_with_values
                        assign option_name_downcase = option.name | downcase
                        if option_name_downcase == color_option_name or option_name_downcase == 'color' or option_name_downcase == 'colour' or option_name_downcase == 'cor'
                          assign color_option = option
                          break
                        endif
                      endfor
                    -%}

                    {%- if color_option != null -%}
                      {%- for color_value in color_option.values -%}
                        {%- if card_index >= product_to_show -%}
                          {%- break -%}
                        {%- endif -%}
                        {%- liquid
                          assign card_index = card_index | plus: 1

                          comment
                            Encontrar uma variante disponível com essa cor
                          endcomment
                          assign color_variant = null
                          for variant in product.variants
                            if variant.options contains color_value
                              if variant.available or color_variant == null
                                assign color_variant = variant
                                if variant.available
                                  break
                                endif
                              endif
                            endif
                          endfor

                          if color_variant == null
                            assign color_variant = product.first_available_variant
                          endif
                        -%}
                        <div class="swiper-slide m:column">
                          {% liquid
                            case card_style
                              when '1'
                                render 'product-card-1', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                              when '2'
                                render 'product-card-2', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                              when '3'
                                render 'product-card-3', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                              when '4'
                                render 'product-card-4', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                              when '5'
                                render 'product-card-5', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                              when '6'
                                render 'product-card-6', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                              when '7'
                                render 'product-card-7', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                            endcase
                          %}
                        </div>
                      {%- endfor -%}
                    {%- else -%}
                      {%- comment -%} Produto sem opção de cor - renderizar normalmente {%- endcomment -%}
                      {%- assign card_index = card_index | plus: 1 -%}
                      <div class="swiper-slide m:column">
                        {% liquid
                          case card_style
                            when '1'
                              render 'product-card-1', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect
                            when '2'
                              render 'product-card-2', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect
                            when '3'
                              render 'product-card-3', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect
                            when '4'
                              render 'product-card-4', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect
                            when '5'
                              render 'product-card-5', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect
                            when '6'
                              render 'product-card-6', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect
                            when '7'
                              render 'product-card-7', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: card_index, animated: animated, animation_effect: animation_effect
                          endcase
                        %}
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                {%- else -%}
                  {%- comment -%} Modo normal: um card por produto {%- endcomment -%}
                  {% for product in current_collection.products limit: product_to_show %}
                    <div class="swiper-slide m:column">
                      {% liquid
                        case card_style
                          when '1'
                            render 'product-card-1', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: forloop.index, animated: animated, animation_effect: animation_effect
                          when '2'
                            render 'product-card-2', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: forloop.index, animated: animated, animation_effect: animation_effect
                          when '3'
                            render 'product-card-3', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: forloop.index, animated: animated, animation_effect: animation_effect
                          when '4'
                            render 'product-card-4', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: forloop.index, animated: animated, animation_effect: animation_effect
                          when '5'
                            render 'product-card-5', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: forloop.index, animated: animated, animation_effect: animation_effect
                          when '6'
                            render 'product-card-6', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: forloop.index, animated: animated, animation_effect: animation_effect
                          when '7'
                            render 'product-card-7', product: product, image_ratio: image_ratio, show_vendor: show_vendor, hide_title: hide_title, index: forloop.index, animated: animated, animation_effect: animation_effect
                        endcase
                      %}
                    </div>
                  {% endfor %}
                {%- endif -%}
              {% else %}
                {% for i in (1..product_to_show) %}
                  <div class="swiper-slide m:column m:text-{{ settings.pcard_alignment }}">
                    <div
                      class="m-product-card m-product-card--placeholder{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
                      {% if animated %}
                        data-cascade
                        style="--animation-order: {{ forloop.index }};"
                      {% endif %}
                    >
                      <div class="m-product-card__media" style="--aspect-ratio: 1/1;">
                        {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
                        {{
                          'product-'
                          | append: current
                          | placeholder_svg_tag: 'm-placeholder-svg m:object-cover m:w-full m:h-full'
                        }}
                      </div>
                      <div class="m-product-card__name{% if settings.uppercase_prd_name %} m:uppercase{% endif %}">
                        {{ 'homepage.onboarding.product_title' | t }}
                      </div>
                      <div class="m-product-card__price">
                        <p class="m-price">$19.99</p>
                      </div>
                    </div>
                  </div>
                {% endfor %}
              {% endif %}
            </div>
          </div>
          {% if enable_slider %}
            {% render 'slider-controls',
              extra_classes: 'm:hidden',
              absolute: true,
              container: section.settings.container,
              show_pagination: section.settings.show_pagination,
              show_nav: section.settings.show_navigation,
              nav_class: 'm:hidden'
            %}
          {% endif %}
        </div>
        {% if section.settings.button_text != blank %}
          {% capture arrow %}<svg class="m-rlt-reverse-x" width="17" height="16" viewBox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M7.03062 2.4694L12.0306 7.4694C12.1005 7.53908 12.156 7.62187 12.1939 7.71304C12.2317 7.8042 12.2512 7.90194 12.2512 8.00065C12.2512 8.09936 12.2317 8.1971 12.1939 8.28827C12.156 8.37943 12.1005 8.46222 12.0306 8.5319L7.03062 13.5319C6.88973 13.6728 6.69863 13.752 6.49937 13.752C6.30012 13.752 6.10902 13.6728 5.96812 13.5319C5.82723 13.391 5.74807 13.1999 5.74807 13.0007C5.74807 12.8014 5.82723 12.6103 5.96812 12.4694L10.4375 8.00003L5.9675 3.53065C5.8266 3.38976 5.74745 3.19866 5.74745 2.9994C5.74745 2.80015 5.8266 2.60905 5.9675 2.46815C6.10839 2.32726 6.29949 2.2481 6.49875 2.2481C6.69801 2.2481 6.8891 2.32726 7.03 2.46815L7.03062 2.4694Z" fill="currentColor"/>
            </svg>{% endcapture %}
          {% liquid
            assign is_button_icon = false
            if section.settings.button_text contains '[arrow]'
              assign is_button_icon = true
            endif
          %}
          {% if button_type == 'load' and paginate.pages > 1 %}
            <div class="m-featured-collection__button {{ button_loadmore_class }}{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
              <button
                class="m-button {{ section.settings.button_style | replace: 'sf__btn-primary', 'm-button--primary' | replace: 'sf__btn-secondary', 'm-button--secondary' | replace: 'sf__btn-link', 'm-button--link' | replace: 'sf__btn-white', 'm-button--white' }} {{ section.settings.button_size }} m-spinner-button"
                data-load-more
              >
                <span class="m-spinner-icon">
                  <svg
                    class="animate-spin m-svg-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                  >
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                </span>
                <span>{{ section.settings.button_text }}</span>
              </button>
            </div>
          {% endif %}
          {% if button_type == 'link' and show_button_on_header == false %}
            <div class="m-featured-collection__button m:display-flex{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
              <a
                class="m-button{% if is_button_icon %} m-button--text-with-icon{% endif %} {{ section.settings.button_style | replace: 'sf__btn-primary', 'm-button--primary' | replace: 'sf__btn-secondary', 'm-button--secondary' | replace: 'sf__btn-link', 'm-button--link' | replace: 'sf__btn-white', 'm-button--white' | replace: 'm-button--link-arrow', 'm-button--link m-button--link-arrow' }} {{ section.settings.button_size }}"
                href="{{ current_collection.url }}"
              >
                <span>{{- section.settings.button_text | replace: '[arrow]', arrow -}}</span>
                {% if section.settings.button_style == 'm-button--link-arrow' %}
                  <span class="m-button-arrow-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 16 16" fill="none">
                      <path d="M12.3536 8.35355C12.5488 8.15829 12.5488 7.84171 12.3536 7.64645L9.17157 4.46447C8.97631 4.2692 8.65973 4.2692 8.46447 4.46447C8.2692 4.65973 8.2692 4.97631 8.46447 5.17157L11.2929 8L8.46447 10.8284C8.2692 11.0237 8.2692 11.3403 8.46447 11.5355C8.65973 11.7308 8.97631 11.7308 9.17157 11.5355L12.3536 8.35355ZM3 8V8.5H12V8V7.5H3V8Z" fill="#BDBDBD"/>
                      <circle cx="8" cy="8" r="7.5" stroke="#BDBDBD"/>
                    </svg>
                  </span>
                {% endif %}
              </a>
            </div>
          {% endif %}
        {% endif %}
      </div>
    </m-featured-collection>
  </section>
{%- endpaginate -%}

{% schema %}
{
  "name": "Featured collection",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Featured collection"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h3",
      "options": [
        {
          "label": "Medium",
          "value": "h3"
        },
        {
          "label": "Large",
          "value": "h2"
        }
      ]
    },
    {
      "type": "html",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_title_divider",
      "label": "Show divider line",
      "default": false,
      "info": "Display a horizontal divider line between heading and content"
    },
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Container type",
      "default": "container-fluid",
      "options": [
        {
          "value": "container-fluid",
          "label": "Default"
        },
        {
          "value": "w-full",
          "label": "Full width"
        },
        {
          "value": "container",
          "label": "Use container box"
        }
      ]
    },
    {
      "id": "collection",
      "type": "collection",
      "label": "Collection"
    },
    {
      "type": "header",
      "content": "Flash sale",
      "info": "Need to setup a countdown timer for flash sale via Fox Kit"
    },
    {
      "type": "checkbox",
      "id": "enable_flashsale",
      "label": "Enable flash sale",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Show countdown timer",
      "default": false
    },
    {
      "type": "header",
      "content": "Grid settings"
    },
    {
      "type": "range",
      "id": "product_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "split_by_color_variant",
      "label": "Separate listing by color variant",
      "default": false,
      "info": "Show one card per color variant instead of one card per product. The 'Products to show' limit applies to total cards."
    },
    {
