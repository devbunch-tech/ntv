{{ 'video-reels.css' | asset_url | stylesheet_tag }}
<script src="{{ 'video-reels.js' | asset_url }}" defer="defer"></script>
{% liquid
  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif
  assign enable_slider = section.settings.enable_slider
  assign items_per_row = section.settings.items_per_row
  assign item_gap = section.settings.item_gap
  assign item_gap_mobile = section.settings.item_gap_mobile
  assign animated = false
  if section.settings.animations != 'none' and section.settings.animations != 'inherit'
    assign animated = true
  endif
  assign animation_effect = section.settings.animations
%}

<style>
  #m-section--{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --items: {{ items_per_row }};
    --item-gap: {{ item_gap }}px;
  }
</style>

<section
  id="m-section--{{ section.id }}"
  class="m-section m-video-reels-section m-gradient m-color-{{ section.settings.color_scheme }}"
  data-section-type="video-reels"
  data-section-id="{{ section.id }}"
>
  <div class="{{ container }} m-section-py">
    {% if section.settings.heading != blank %}
      <div class="m-section__header m:text-{{ section.settings.header_alignment }}">
        <h2 class="m-section__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <m-video-reels
      data-enable-slider="{{ enable_slider }}"
      data-items="{{ items_per_row }}"
      data-gap="{{ item_gap }}"
      data-gap-mobile="{{ item_gap_mobile }}"
    >
      {% if enable_slider %}
        <div class="swiper-container">
          <div class="swiper-wrapper">
      {% else %}
        <div class="m-video-reels__grid">
      {% endif %}

            {% for block in section.blocks %}
              {% if enable_slider %}<div class="swiper-slide">{% endif %}

              <div class="m-video-reel{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}" {{ block.shopify_attributes }}>
                <div class="m-video-reel__media">
                  {%- if block.settings.video != blank -%}
                    {{ block.settings.video | video_tag:
                      class: 'm-video-reel__video',
                      preload: 'metadata',
                      playsinline: true,
                      muted: true,
                      loop: true,
                      image_size: '600x'
                    }}
                  {%- else -%}
                    <div class="m-video-reel__placeholder" style="width:100%;height:100%;background:#333;"></div>
                  {%- endif -%}

                  {%- if block.settings.thumbnail != blank -%}
                    <div class="m-video-reel__thumbnail">
                      <img
                        src="{{ block.settings.thumbnail | image_url: width: 600 }}"
                        alt="{{ block.settings.name | escape }}"
                        loading="lazy"
                        width="350"
                        height="650"
                      >
                    </div>
                  {%- endif -%}

                  <div class="m-video-reel__overlay">
                    <button class="m-video-reel__play" aria-label="{{ 'general.accessibility.play_video' | t }}">
                      <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 56 56" fill="none">
                        <path d="M28 0C22.4621 0 17.0486 1.64217 12.444 4.71885C7.83947 7.79553 4.25064 12.1685 2.13139 17.2849C0.0121319 22.4012 -0.542361 28.0311 0.538025 33.4625C1.61841 38.894 4.28515 43.8831 8.20102 47.799C12.1169 51.7149 17.106 54.3816 22.5375 55.462C27.9689 56.5424 33.5988 55.9879 38.7151 53.8686C43.8315 51.7494 48.2045 48.1605 51.2812 43.556C54.3578 38.9514 56 33.5379 56 28C56 24.323 55.2758 20.682 53.8686 17.2849C52.4615 13.8877 50.399 10.801 47.799 8.20101C45.199 5.60097 42.1123 3.5385 38.7151 2.13137C35.318 0.724241 31.677 0 28 0ZM22.4 40.6V15.4L39.2 28L22.4 40.6Z" fill="white"/>
                      </svg>
                    </button>
                  </div>
                </div>

                <div class="m-video-reel__info">
                  {% if block.settings.name != blank %}
                    <h3 class="m-video-reel__name">{{ block.settings.name }}</h3>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <p class="m-video-reel__desc">{{ block.settings.description }}</p>
                  {% endif %}
                </div>
              </div>

              {% if enable_slider %}</div>{% endif %}
            {% endfor %}

      {% if enable_slider %}
          </div>
        </div>
      {% else %}
        </div>
      {% endif %}
    </m-video-reels>

    {%- comment -%} ALOFT CUSTOM: Fullscreen video modal {%- endcomment -%}
    <div class="m-video-reel-modal" data-video-modal>
      <div class="m-video-reel-modal__backdrop" data-modal-close></div>
      <div class="m-video-reel-modal__content">
        <button class="m-video-reel-modal__close" data-modal-close aria-label="Close">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M18 6L6 18M6 6L18 18" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <video class="m-video-reel-modal__video" playsinline loop controls data-modal-video></video>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video Reels",
  "tag": "section",
  "class": "m-section--video-reels",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "QUEM VESTE ONÇA PRETA"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h3",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ]
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Heading alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Container",
      "default": "container-fluid",
      "options": [
        { "value": "container-fluid", "label": "Fluid" },
        { "value": "container", "label": "Boxed" },
        { "value": "w-full", "label": "Full width" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "items_per_row",
      "label": "Items per row",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Gap between items",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "item_gap_mobile",
      "label": "Gap on mobile",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable slider",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "default": 20,
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "default": 20,
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "animations",
      "label": "Animations",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Inherit" },
        { "value": "fade-in", "label": "Fade in" },
        { "value": "none", "label": "None" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "video_item",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Upload via Settings > Files"
        },
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail",
          "info": "Optional. If empty, shows video first frame."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Nome"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Influenciadora"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Reels",
      "blocks": [
        { "type": "video_item", "settings": { "name": "Bianca Moura", "description": "Influenciadora" } },
        { "type": "video_item", "settings": { "name": "Marcelle Ceolin", "description": "Influenciadora" } },
        { "type": "video_item", "settings": { "name": "Thay de Bem", "description": "Influenciadora" } },
        { "type": "video_item", "settings": { "name": "Rayka Caires", "description": "Influenciadora" } }
      ]
    }
  ]
}
{% endschema %}
