{{ 'footer.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign has_footer_bg = false
  if section.settings.footer_bg_image != blank or section.settings.footer_bg_image_mobile != blank
    assign has_footer_bg = true
  endif
  assign footer_bg_desktop = section.settings.footer_bg_image | default: section.settings.footer_bg_image_mobile
-%}
{% if has_footer_bg %}
  {% style %}
    .m-footer--bottom-has-bg {
      padding-top: {{ section.settings.footer_bg_padding_mobile }}px;
      overflow: hidden;
    }
    @media screen and (min-width: 768px) {
      .m-footer--bottom-has-bg {
        padding-top: {{ section.settings.footer_bg_padding_desktop }}px;
        background-image: url('{{ footer_bg_desktop | image_url: width: 1800 }}') !important;
        background-size: {{ section.settings.footer_bg_size_desktop }}% auto !important;
      }
    }
  {% endstyle %}
{% endif %}
{% style %}
  /* Fix breakpoint: centralizar footer-4 abaixo de 1280px */
  @media screen and (max-width: 1279px) {
    .m-footer--bottom-footer-4 .m-footer--bottom-inner {
      align-items: center;
    }
  }
  .m-footer--newsletter-image img {
    margin-left: auto;
    margin-right: auto;
    display: block;
  }
  .m-footer--newsletter-image {
    justify-self: center;
  }
  @media screen and (min-width: 768px) {
    .m-footer--newsletter-image {
      margin-top: 3rem;
    }
  }
  /* Copyright mobile/desktop visibility */
  .m-footer__copyright--mobile {
    display: block !important;
    width: 100%;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.50);
  }
  .m-footer__copyright--desktop {
    display: none !important;
    color: rgba(255, 255, 255, 0.50);
  }
  @media screen and (min-width: 1280px) {
    .m-footer__copyright--mobile {
      display: none !important;
    }
    .m-footer__copyright--desktop {
      display: block !important;
    }
  }
  .m-footer--block-content:has(> .m-footer-brand-contact) {
    --m-footer-brand-contact-stack-gap: 12px;
  }
  .m-footer-brand-contact {
    display: flex;
    flex-direction: column;
    gap: var(--m-footer-brand-contact-stack-gap);
  }
  .m-footer-brand-contact__row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .m-footer-brand-contact__icon {
    flex-shrink: 0;
    width: 15px;
    height: 15px;
    margin-top: 6px;
    line-height: 0;
  }
  .m-footer-brand-contact__icon svg {
    display: block;
  }
  .m-footer-brand-contact__text,
  .m-footer-brand-contact__link {
    flex: 1;
    min-width: 0;
    font-size: inherit;
    line-height: 1.45;
  }
  .m-footer-brand-contact__label {
    display: inline;
    font-weight: inherit;
  }
  .m-footer-brand-contact__top-link-list {
    margin-bottom: var(--m-footer-brand-contact-stack-gap);
  }
{% endstyle %}
{%- if section.settings.show_currency_selector
  or section.settings.show_country_selector
  or section.settings.show_language_selector
-%}
  <script src="{{ 'localization-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
{% style %}
  /* Linhas decorativas no topo e base do footer middle (somente desktop) */
  @media screen and (min-width: 768px) {
    .m-footer--middle-top-line,
    .m-footer--middle-bottom-line {
      display: block;
      height: 40px;
      width: 100%;
    }
    .m-footer--middle-top-line {
      border-bottom: 1px solid #E0DDD840;
    }
    .m-footer--middle-bottom-line {
      border-top: 1px solid #E0DDD840;
    }
  }
  @media screen and (max-width: 767px) {
    .m-footer--middle-top-line,
    .m-footer--middle-bottom-line {
      display: none;
    }
  }
{% endstyle %}
{% if section.settings.show_footer_bottom_divider %}
  {% style %}
    /* Cor customizada para as linhas superior e inferior do footer middle (somente desktop) */
    @media screen and (min-width: 768px) {
      .m-footer--middle-top-line {
        border-bottom-color: {{ section.settings.footer_bottom_divider_color }};
      }
      .m-footer--middle-bottom-line {
        border-top-color: {{ section.settings.footer_bottom_divider_color }};
      }
    }
  {% endstyle %}
{% endif %}
{% if section.settings.show_mobile_divider %}
  {% style %}
    /* Divisor entre elementos do footer no mobile */
    @media screen and (max-width: 767px) {
      .m-footer--middle .m-footer--block:not(:last-child) .m-footer--block-inner {
        position: relative;
        padding-bottom: 5px;
      }
      .m-footer--middle .m-footer--block:not(:last-child) .m-footer--block-inner::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 15px;
        right: 15px;
        height: 1px;
        background-color: #ADADAD;
      }
      .m-footer--middle .m-footer--block {
        margin-bottom: 8px;
      }
      .m-footer--middle .open .m-accordion--item-content.max-height-set {
        margin-bottom: 12px;
      }
    }
  {% endstyle %}
{% endif %}
<m-footer class="m-footer m:block" data-section-type="footer" data-section-id="{{ section.id }}">
  {% render 'footer-blocks',
    blocks: section.blocks,
    bordered: section.settings.bordered,
    container: section.settings.container
  %}
  {% render 'footer-design', container: section.settings.container %}
</m-footer>
<script src="{{ 'footer.js' | asset_url }}" defer="defer"></script>
