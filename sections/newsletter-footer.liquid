{{ 'newsletter-footer.css' | asset_url | stylesheet_tag }}
{% liquid
  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif
%}

{% style %}
  #m-newsletter-footer--{{ section.id }} {
    --nl-bg: {{ section.settings.bg_color }};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  }
{% endstyle %}

<section
  id="m-newsletter-footer--{{ section.id }}"
  class="m-section m-newsletter-footer"
  data-section-type="newsletter-footer"
>
  <div class="{{ container }} m-section-py">
    <div class="m-newsletter-footer__wrapper">
      <div class="m-newsletter-footer__text">
        {% if section.settings.heading != blank %}
          <h2 class="m-newsletter-footer__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <p class="m-newsletter-footer__desc">{{ section.settings.description }}</p>
        {% endif %}
      </div>

      <div class="m-newsletter-footer__form-wrap">
        {% form 'customer', class: 'm-newsletter-footer__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">

          {% if form.posted_successfully? %}
            <p class="m-newsletter-footer__message m-newsletter-footer__message--success">
              {{ 'general.newsletter_form.confirmation' | t }}
            </p>
          {% endif %}

          {% if form.errors %}
            <p class="m-newsletter-footer__message m-newsletter-footer__message--error">
              {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
            </p>
          {% endif %}

          <div class="m-newsletter-footer__fields">
            <input
              type="email"
              name="contact[email]"
              class="m-newsletter-footer__input"
              placeholder="{{ section.settings.placeholder }}"
              required
              autocomplete="email"
              aria-label="{{ section.settings.placeholder }}"
            >
            <button type="submit" class="m-newsletter-footer__submit">
              <span>{{ section.settings.button_text }}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="6" viewBox="0 0 15 6" fill="none">
                <path d="M15 3L10 0.113249V5.88675L15 3ZM0 3.5H10.5V2.5H0V3.5Z" fill="white"/>
              </svg>
            </button>
          </div>

          {% if section.settings.disclaimer != blank %}
            <p class="m-newsletter-footer__disclaimer m-newsletter-footer__disclaimer--desktop">
              {{ section.settings.disclaimer }}
            </p>
          {% endif %}
          {% if section.settings.disclaimer_mobile != blank %}
            <p class="m-newsletter-footer__disclaimer m-newsletter-footer__disclaimer--mobile">
              {{ section.settings.disclaimer_mobile }}
            </p>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter Footer",
  "tag": "section",
  "class": "m-section--newsletter-footer",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "SEJA A PRIMEIRA A <span class=\"highlight\">SABER.</span>",
      "info": "Use <span class=\"highlight\">text</span> for gold color"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Seu primeiro look Onça Preta com 10% off. Cadastre-se e seja a primeira a saber de tudo."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Seu melhor e-mail"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "INSCREVER-SE"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer (desktop)",
      "default": "Ao se cadastrar, você concorda com nossa Política de Privacidade. Cancele quando quiser."
    },
    {
      "type": "textarea",
      "id": "disclaimer_mobile",
      "label": "Disclaimer (mobile)",
      "default": "Cancele quando quiser. Sem Spam."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f5f2ec"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Container",
      "default": "container-fluid",
      "options": [
        { "value": "container-fluid", "label": "Fluid" },
        { "value": "container", "label": "Boxed" },
        { "value": "w-full", "label": "Full width" }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "default": 20,
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "default": 20,
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Newsletter Footer"
    }
  ]
}
{% endschema %}
