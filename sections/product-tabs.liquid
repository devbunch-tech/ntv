{{ 'component-product-inventory.css' | asset_url | stylesheet_tag }}
{{ 'tabs.css' | asset_url | stylesheet_tag }}
{{ 'product-tabs.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-tabs.js' | asset_url }}" defer="defer"></script>
{%- liquid
  assign button_type = section.settings.button_type
  assign product_limit = section.settings.limit

  assign enable_slider = false
  assign mobile_disable_slider = section.settings.mobile_disable_slider
  if section.settings.enable_slider
    assign enable_slider = true
  endif

  assign items_per_row = section.settings.items_per_row
  assign card_style = section.settings.pcard_layout
  assign image_ratio = section.settings.pcard_image_ratio
  assign show_vendor = section.settings.show_vendor
  assign tab_header = section.settings.tab_header
  assign button_type = section.settings.button_type
  assign use_scroll_mobile = section.settings.use_scroll_mobile

  if card_style == null or card_style == blank
    assign card_style = settings.pcard_layout
  endif

  assign animation_effect = settings.animations
  assign animated = false
  if animation_effect != 'none'
    assign animated = true
    if section.settings.animations != 'inherit'
      assign animation_effect = section.settings.animations
    endif
  endif

  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif

  assign button_loadmore_class = ''
  if enable_slider
    assign button_loadmore_class = 'md:m:hidden'
    if mobile_disable_slider
      if use_scroll_mobile
        assign button_loadmore_class = button_loadmore_class | append: ' m:hidden'
      else
        assign button_loadmore_class = button_loadmore_class | append: ' m:flex'
      endif
    else
      assign button_loadmore_class = button_loadmore_class | append: ' m:hidden'
    endif
  else
    assign button_loadmore_class = 'md:m:flex'
    if use_scroll_mobile
      assign button_loadmore_class = button_loadmore_class | append: ' m:hidden'
    else
      assign button_loadmore_class = button_loadmore_class | append: ' m:flex'
    endif
  endif

  assign classes = 'm-section m-product-tabs m:block'
  if section.settings.custom_class != blank
    assign classes = classes | append: ' ' | append: section.settings.custom_class
  endif
  assign classes = classes | append: ' m-product-tabs--' | append: tab_header | append: ' m-gradient' | append: ' m-color-' | append: section.settings.color_scheme
-%}

{%- capture dropdown -%}
  {% if section.blocks.size > 0 %}
    <m-select-component data-tab-header="{{ tab_header }}">
      <select
        name="country_code"
        class="js-selectNative"
        data-tab-select
      >
        {% for block in section.blocks %}
          {%- liquid
            assign tab_name = block.settings.title
            assign current_collection = block.settings.collection
            if block.settings.title == blank
              assign tab_name = 'Tab ' | append: forloop.index
              if collection != blank
                assign tab_name = current_collection.title
              endif
            endif
          -%}
          <option
            value="{{ forloop.index0 }}"
            {% if forloop.index0 == 0 %}
              selected="selected"
            {% endif %}
          >
            {{ tab_name }}
          </option>
        {%- endfor -%}
      </select>
      <div
        class="m-select-custom m-select-custom--custom-width m-select-custom--plain js-selectCustom h3"
        aria-hidden="true"
      >
        <div class="m-select-custom--trigger">
          <span class="m-select-custom--trigger-text"></span>
          <span class="m-select-custom--trigger-icon">
            <svg
              fill="currentColor"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 448 512"
            >
              <path d="M441.9 167.3l-19.8-19.8c-4.7-4.7-12.3-4.7-17 0L224 328.2 42.9 147.5c-4.7-4.7-12.3-4.7-17 0L6.1 167.3c-4.7 4.7-4.7 12.3 0 17l209.4 209.4c4.7 4.7 12.3 4.7 17 0l209.4-209.4c4.7-4.7 4.7-12.3 0-17z" />
            </svg>
          </span>
        </div>
        <div class="m-select-custom--options">
          {% for block in section.blocks %}
            {%- liquid
              assign tab_name = block.settings.title
              assign current_collection = block.settings.collection
              if block.settings.title == blank
                assign tab_name = 'Tab ' | append: forloop.index
                if collection != blank
                  assign tab_name = current_collection.title
                endif
              endif
            -%}
            <div class="m-select-custom--option" data-value="{{ forloop.index0 }}">
              {{ tab_name }}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </m-select-component>
  {% endif %}
{%- endcapture -%}
<style>
  #m-section--{{ section.id }} {
    --column-gap: {{ section.settings.item_gap }}px;
    --column-gap-mobile: {{ section.settings.item_gap_mobile }}px;
    --row-gap: {{ section.settings.item_gap | plus: 10 }}px;
    --items: {{ items_per_row }};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  }
</style>
<section
  id="m-section--{{ section.id }}"
  class="{{ classes }}"
>
  <m-product-tabs
    id="{{ section.id }}"
    data-section-type="product-tabs"
    data-enable-slider="{{ enable_slider }}"
    data-mobile-disable-slider="{{ section.settings.mobile_disable_slider }}"
    data-button-type="{{ button_type }}"
    {% if enable_slider %}
      data-show-pagination="{{ section.settings.show_pagination }}"
      data-show-navigation="{{ section.settings.show_navigation }}"data-items="{{ items_per_row }}"
    {% endif -%}
  >
    <div class="{{ container }} m-section-my m-section-py">
      <div class="m-section__header m:text-{{ section.settings.header_alignment }}">
        {% if section.settings.subheading != blank %}
          <p class="m-section__subheading m:w-full{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
            {{ section.settings.subheading }}
          </p>
        {% endif %}

        {% if tab_header == 'horizontal' %}
          {% if section.settings.heading != blank %}
            <h2 class="m-section__heading {{ section.settings.heading_size | default: 'h3' }}{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
              {{ section.settings.heading }}
            </h2>
          {% endif %}
        {% else %}
          <div class="m-section__heading {% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
            {% if section.settings.heading != blank %}
              <h2 class="{{ section.settings.heading_size | default: 'h3' }}">{{ section.settings.heading }}&nbsp;</h2>
            {% endif %}
            {{ dropdown }}
          </div>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="m-section__description m:w-full{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
            {{ section.settings.description }}
          </div>
        {% endif %}

        {% if tab_header == 'horizontal' and section.blocks.size > 0 %}
          <div class="m-section__tabs{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
            <div class="m-tabs__wrapper">
              {% for block in section.blocks %}
                {%- liquid
                  assign tab_name = block.settings.title
                  assign current_collection = block.settings.collection

                  if block.settings.title == blank
                    assign tab_name = 'Tab ' | append: forloop.index
                    if collection != blank
                      assign tab_name = current_collection.title
                    endif
                  endif
                -%}
                <a
                  class="m-tab-header{% if section.settings.tab_title_size == 'title' %} m-tab-header--title-size{% endif %}"
                  href="#product-tabs-{{ block.id }}"
                  data-index="{{ forloop.index0 }}"
                >
                  {{- tab_name -}}
                </a>
              {% endfor %}
            </div>
            {{ dropdown }}
          </div>
        {% endif %}

        {% if section.settings.button_position == 'below_title' and section.settings.button_label != blank and section.settings.show_button == true %}
          {%- liquid
            assign first_collection = null
            if section.blocks.size > 0
              assign first_block = section.blocks.first
              assign first_collection = collections[first_block.settings.collection]
            endif
          -%}
          {% if first_collection != blank %}
            {%- if button_type == 'load' -%}
              <div class="m-product-tabs__load-more {{ button_loadmore_class }}{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}" data-header-button-wrapper>
                <button
                  class="m-button {{ section.settings.button_style | replace: 'sf__btn-primary', 'm-button--primary' | replace: 'sf__btn-secondary', 'm-button--secondary' | replace: 'sf__btn-link', 'm-button--link' | replace: 'sf__btn-white', 'm-button--white' }} {{ section.settings.button_size }} m-spinner-button"
                  data-load-more-product
                  data-header-button
                >
                  <span class="m-spinner-icon">
                    <svg
                      class="animate-spin m-svg-icon"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                    >
                      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                  </span>
                  <span>{{ section.settings.button_label }}</span>
                </button>
              </div>
            {%- endif -%}
            {% if button_type == 'link' %}
              <div class="m-product-tabs__load-more m:text-center{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}" data-header-button-wrapper>
                <a
                  class="m-button {{ section.settings.button_style | replace: 'sf__btn-primary', 'm-button--primary' | replace: 'sf__btn-secondary', 'm-button--secondary' | replace: 'sf__btn-link', 'm-button--link' | replace: 'sf__btn-white', 'm-button--white' | replace: 'm-button--link-arrow', 'm-button--link m-button--link-arrow' }} {{ section.settings.button_size }}"
                  href="{{ first_collection.url }}"
                  data-load-more-product
                  data-header-button
                >
                  <span>{{ section.settings.button_label }}</span>
                  {% if section.settings.button_style == 'm-button--link-arrow' %}
                    <span class="m-button-arrow-icon">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 16 16" fill="none">
                        <path d="M12.3536 8.35355C12.5488 8.15829 12.5488 7.84171 12.3536 7.64645L9.17157 4.46447C8.97631 4.2692 8.65973 4.2692 8.46447 4.46447C8.2692 4.65973 8.2692 4.97631 8.46447 5.17157L11.2929 8L8.46447 10.8284C8.2692 11.0237 8.2692 11.3403 8.46447 11.5355C8.65973 11.7308 8.97631 11.7308 9.17157 11.5355L12.3536 8.35355ZM3 8V8.5H12V8V7.5H3V8Z" fill="#BDBDBD"/>
                        <circle cx="8" cy="8" r="7.5" stroke="#BDBDBD"/>
                      </svg>
                    </span>
                  {% endif %}
                </a>
                {% if section.settings.show_header_navigation %}
                  <div class="m-section__header-nav m:hidden md:m:flex" data-header-nav>
                    {% render 'slider-controls',
                      show_nav: true,
                      show_pagination: false,
                      arrow_style: section.settings.arrow_style
                    %}
                  </div>
                {% endif %}
              </div>
            {% endif %}
          {% endif %}
        {% endif %}

      </div>

      {% if section.blocks.size > 0 %}
        <div class="m-product-tabs__content">
          {% for block in section.blocks %}
            {%- liquid
              assign current_collection = collections[block.settings.collection]
              assign split_by_color = block.settings.split_by_color_variant
              assign color_option_name = settings.pcard_option_name | default: 'Cor' | downcase

              comment
                Calcular o total de cards que serão exibidos
                Se split_by_color está ativo, conta variantes de cor; senão, conta produtos
              endcomment
              assign total_cards = 0
              if split_by_color and current_collection != blank
                for product in current_collection.products
                  if total_cards >= product_limit
                    break
                  endif
                  assign color_option = null
                  for option in product.options_with_values
                    assign option_name_downcase = option.name | downcase
                    if option_name_downcase == color_option_name or option_name_downcase == 'color' or option_name_downcase == 'colour' or option_name_downcase == 'cor'
                      assign color_option = option
                      break
                    endif
                  endfor
                  if color_option != null
                    for color_value in color_option.values
                      if total_cards >= product_limit
                        break
                      endif
                      assign total_cards = total_cards | plus: 1
                    endfor
                  else
                    assign total_cards = total_cards | plus: 1
                  endif
                endfor
              else
                if current_collection != blank
                  assign total_cards = current_collection.products.size
                  if total_cards > product_limit
                    assign total_cards = product_limit
                  endif
                endif
              endif

              comment
                Determinar se deve usar slider baseado no total de cards
              endcomment
              assign tab_enable_slider = enable_slider
              if current_collection != blank and total_cards > items_per_row and enable_slider
                assign tab_enable_slider = true
              endif
            -%}
            {%- paginate current_collection.products by product_limit -%}
              <div
                id="product-tabs-{{ block.id }}"
                class="m-tab-content{% unless section.settings.show_header_navigation %} m-swiper-overflow{% endunless %}"
                {{ block.shopify_attributes }}
                data-index="{{ forloop.index0 }}"
                data-url="{{ current_collection.url }}"
                data-total-pages="{{ paginate.pages }}"
                data-page="{{ paginate.current_page }}"
                data-total-items="{{ total_cards }}"
                data-enable-slide="{{ tab_enable_slider }}"
              >
                <div class="m-product-list m-slider-control-hover-inside m-mixed-layout {% if mobile_disable_slider or tab_enable_slider != true %} m-mixed-layout--mobile-grid{% if use_scroll_mobile %} m-mixed-layout--mobile-scroll{% endif %}{% endif %}">
                  <div class="m-mixed-layout__wrapper{% if tab_enable_slider %} swiper-container{% endif %}">
                    <div
                      class="m-mixed-layout__inner m:grid m:grid-2-cols md:m:grid-3-cols lg:m:grid-4-cols xl:m:grid-{{ section.settings.items_per_row }}-cols{% if tab_enable_slider %} swiper-wrapper{% endif %}"
                      data-products-container
                    >
                      {%- if split_by_color -%}
                        {%- comment -%} Modo separado por variante de cor {%- endcomment -%}
                        {%- assign card_index = 0 -%}
                        {%- for product in current_collection.products -%}
                          {%- if card_index >= product_limit -%}
                            {%- break -%}
                          {%- endif -%}
                          
                          {%- liquid
                            assign color_option = null
                            for option in product.options_with_values
                              assign option_name_downcase = option.name | downcase
                              if option_name_downcase == color_option_name or option_name_downcase == 'color' or option_name_downcase == 'colour' or option_name_downcase == 'cor'
                                assign color_option = option
                                break
                              endif
                            endfor
                          -%}

                          {%- if color_option != null -%}
                            {%- for color_value in color_option.values -%}
                              {%- if card_index >= product_limit -%}
                                {%- break -%}
                              {%- endif -%}
                              {%- liquid
                                assign card_index = card_index | plus: 1

                                comment
                                  Encontrar uma variante disponível com essa cor
                                endcomment
                                assign color_variant = null
                                for variant in product.variants
                                  if variant.options contains color_value
                                    if variant.available or color_variant == null
                                      assign color_variant = variant
                                      if variant.available
                                        break
                                      endif
                                    endif
                                  endif
                                endfor

                                if color_variant == null
                                  assign color_variant = product.first_available_variant
                                endif
                              -%}
                              {% if tab_enable_slider %}
                                <div class="swiper-slide m:column">
                                  {% liquid
                                    case card_style
                                      when '1'
                                        render 'product-card-1', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                                      when '2'
                                        render 'product-card-2', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                                      when '3'
                                        render 'product-card-3', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                                      when '4'
                                        render 'product-card-4', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                                      when '5'
                                        render 'product-card-5', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                                      when '6'
                                        render 'product-card-6', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                                      when '7'
                                        render 'product-card-7', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, forced_variant: color_variant, forced_color: color_value
                                    endcase
                                  %}
                                </div>
                              {% else %}
                                {% liquid
                                  case card_style
                                    when '1'
                                      render 'product-card-1', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true, forced_variant: color_variant, forced_color: color_value
                                    when '2'
                                      render 'product-card-2', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true, forced_variant: color_variant, forced_color: color_value
                                    when '3'
                                      render 'product-card-3', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true, forced_variant: color_variant, forced_color: color_value
                                    when '4'
                                      render 'product-card-4', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true, forced_variant: color_variant, forced_color: color_value
                                    when '5'
                                      render 'product-card-5', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true, forced_variant: color_variant, forced_color: color_value
                                    when '6'
                                      render 'product-card-6', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true, forced_variant: color_variant, forced_color: color_value
                                    when '7'
                                      render 'product-card-7', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true, forced_variant: color_variant, forced_color: color_value
                                  endcase
                                %}
                              {% endif %}
                            {%- endfor -%}
                          {%- else -%}
                            {%- comment -%} Produto sem opção de cor - renderizar normalmente {%- endcomment -%}
                            {%- assign card_index = card_index | plus: 1 -%}
                            {% if tab_enable_slider %}
                              <div class="swiper-slide m:column">
                                {% liquid
                                  case card_style
                                    when '1'
                                      render 'product-card-1', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect
                                    when '2'
                                      render 'product-card-2', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect
                                    when '3'
                                      render 'product-card-3', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect
                                    when '4'
                                      render 'product-card-4', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect
                                    when '5'
                                      render 'product-card-5', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect
                                    when '6'
                                      render 'product-card-6', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect
                                    when '7'
                                      render 'product-card-7', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect
                                  endcase
                                %}
                              </div>
                            {% else %}
                              {% liquid
                                case card_style
                                  when '1'
                                    render 'product-card-1', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                                  when '2'
                                    render 'product-card-2', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                                  when '3'
                                    render 'product-card-3', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                                  when '4'
                                    render 'product-card-4', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                                  when '5'
                                    render 'product-card-5', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                                  when '6'
                                    render 'product-card-6', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                                  when '7'
                                    render 'product-card-7', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: card_index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                                endcase
                              %}
                            {% endif %}
                          {%- endif -%}
                        {%- endfor -%}
                      {%- else -%}
                        {%- comment -%} Modo normal: um card por produto {%- endcomment -%}
                        {% for product in current_collection.products limit: product_limit %}
                          {% if tab_enable_slider %}
                            <div class="swiper-slide m:column">
                              {% liquid
                                case card_style
                                  when '1'
                                    render 'product-card-1', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect
                                  when '2'
                                    render 'product-card-2', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect
                                  when '3'
                                    render 'product-card-3', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect
                                  when '4'
                                    render 'product-card-4', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect
                                  when '5'
                                    render 'product-card-5', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect
                                  when '6'
                                    render 'product-card-6', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect
                                  when '7'
                                    render 'product-card-7', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect
                                endcase
                              %}
                            </div>
                          {% else %}
                            {% liquid
                              case card_style
                                when '1'
                                  render 'product-card-1', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                                when '2'
                                  render 'product-card-2', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                                when '3'
                                  render 'product-card-3', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                                when '4'
                                  render 'product-card-4', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                                when '5'
                                  render 'product-card-5', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                                when '6'
                                  render 'product-card-6', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                                when '7'
                                  render 'product-card-7', product: product, image_ratio: image_ratio, show_vendor: show_vendor, index: forloop.index, animated: animated, animation_effect: animation_effect, column_wrapper: true
                              endcase
                            %}
                          {% endif %}
                        {% else %}
                          {% for i in (1..product_limit) %}
                            <div class="swiper-slide m:column m:text-{{ settings.pcard_alignment }}">
                              <div
                                class="m-product-card m-product-card--placeholder{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
                                {% if animated %}
                                  data-cascade
                                  style="--animation-order: {{ forloop.index }};"
                                {% endif %}
                              >
                                <div class="m-product-card__media" style="--aspect-ratio: 1/1;">
                                  {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
                                  {{ 'product-' | append: current | placeholder_svg_tag: 'm-placeholder-svg' }}
                                </div>
                                <div class="m-product-card__name{% if settings.uppercase_prd_name %} m:uppercase{% endif %}">
                                  {{ 'homepage.onboarding.product_title' | t }}
                                </div>
                                <div class="m-product-card__price">
                                  <p class="m-price">$19.99</p>
                                </div>
                              </div>
                            </div>
                          {% endfor %}
                        {% endfor %}
                      {%- endif -%}
                    </div>
                  </div>
                  {% if tab_enable_slider %}
                    {% unless section.settings.show_header_navigation %}
                      {% if section.settings.show_navigation or section.settings.show_pagination %}
                        {% render 'slider-controls',
                          extra_classes: 'm:hidden',
                          absolute: true,
                          container: section.settings.container,
                          show_nav: section.settings.show_navigation,
                          show_pagination: section.settings.show_pagination,
                          nav_class: 'm:hidden'
                        %}
                      {% endif %}
                    {% endunless %}
                  {% endif %}
                </div>
                {% if section.settings.button_position == 'below_products' and section.settings.button_label != blank and section.settings.show_button == true %}
                  {%- if button_type == 'load' and paginate.pages > 1 -%}
                    <div class="m-product-tabs__load-more {{ button_loadmore_class }}{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
                      <button
                        class="m-button {{ section.settings.button_style | replace: 'sf__btn-primary', 'm-button--primary' | replace: 'sf__btn-secondary', 'm-button--secondary' | replace: 'sf__btn-link', 'm-button--link' | replace: 'sf__btn-white', 'm-button--white' }} {{ section.settings.button_size }} m-spinner-button"
                        data-load-more-product
                      >
                        <span class="m-spinner-icon">
                          <svg
                            class="animate-spin m-svg-icon"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                          >
                            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                          </svg>
                        </span>
                        <span>{{ section.settings.button_label }}</span>
                      </button>
                    </div>
                  {%- endif -%}
                  {% if button_type == 'link' %}
                    <div class="m-product-tabs__load-more m:text-center{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
                      <a
                        class="m-button {{ section.settings.button_style | replace: 'sf__btn-primary', 'm-button--primary' | replace: 'sf__btn-secondary', 'm-button--secondary' | replace: 'sf__btn-link', 'm-button--link' | replace: 'sf__btn-white', 'm-button--white' | replace: 'm-button--link-arrow', 'm-button--link m-button--link-arrow' }} {{ section.settings.button_size }}"
                        href="{{ current_collection.url }}"
                        data-load-more-product
                      >
                        <span>{{ section.settings.button_label }}</span>
                        {% if section.settings.button_style == 'm-button--link-arrow' %}
                          <span class="m-button-arrow-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 16 16" fill="none">
                              <path d="M12.3536 8.35355C12.5488 8.15829 12.5488 7.84171 12.3536 7.64645L9.17157 4.46447C8.97631 4.2692 8.65973 4.2692 8.46447 4.46447C8.2692 4.65973 8.2692 4.97631 8.46447 5.17157L11.2929 8L8.46447 10.8284C8.2692 11.0237 8.2692 11.3403 8.46447 11.5355C8.65973 11.7308 8.97631 11.7308 9.17157 11.5355L12.3536 8.35355ZM3 8V8.5H12V8V7.5H3V8Z" fill="#BDBDBD"/>
                              <circle cx="8" cy="8" r="7.5" stroke="#BDBDBD"/>
                            </svg>
                          </span>
                        {% endif %}
                      </a>
                    </div>
                  {% endif %}
                {% endif %}
              </div>
            {%- endpaginate -%}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </m-product-tabs>
</section>
{% schema %}
