{{ 'header.css' | asset_url | stylesheet_tag }}

<script src="{{ 'mega-menu.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'header.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'localization-form.js' | asset_url }}" defer="defer"></script>
{%- comment -%}
  ===== STRUCTURED DATA: Organization (schema.org 2026 best practices) =====
  - @id para referência cruzada entre schemas
  - sameAs filtrado (sem links vazios)
  - contactPoint com telefone e email do tema
  - Logo como ImageObject com dimensões
{%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": {{ request.origin | append: '/#organization' | json }},
  "name": {{ shop.name | json }},
  "url": {{ shop.url | json }},
  {% if section.settings.logo %}
    {% assign logo_w = section.settings.logo.width %}
    "logo": {
      "@type": "ImageObject",
      "url": {{ section.settings.logo | image_url: width: logo_w | prepend: "https:" | json }},
      "width": {{ section.settings.logo.width }},
      "height": {{ section.settings.logo.height }}
    },
  {% endif %}
  "sameAs": [
    {%- assign _sep = '' -%}
    {%- if settings.social_facebook_link != blank -%}{{ _sep }}{{ settings.social_facebook_link | json }}{%- assign _sep = ',' -%}{%- endif -%}
    {%- if settings.social_instagram_link != blank -%}{{ _sep }}{{ settings.social_instagram_link | json }}{%- assign _sep = ',' -%}{%- endif -%}
    {%- if settings.social_twitter_link != blank -%}{{ _sep }}{{ settings.social_twitter_link | json }}{%- assign _sep = ',' -%}{%- endif -%}
    {%- if settings.social_youtube_link != blank -%}{{ _sep }}{{ settings.social_youtube_link | json }}{%- assign _sep = ',' -%}{%- endif -%}
    {%- if settings.social_pinterest_link != blank -%}{{ _sep }}{{ settings.social_pinterest_link | json }}{%- assign _sep = ',' -%}{%- endif -%}
    {%- if settings.social_tiktok_link != blank -%}{{ _sep }}{{ settings.social_tiktok_link | json }}{%- assign _sep = ',' -%}{%- endif -%}
    {%- if settings.social_tumblr_link != blank -%}{{ _sep }}{{ settings.social_tumblr_link | json }}{%- assign _sep = ',' -%}{%- endif -%}
    {%- if settings.social_snapchat_link != blank -%}{{ _sep }}{{ settings.social_snapchat_link | json }}{%- assign _sep = ',' -%}{%- endif -%}
    {%- if settings.social_vimeo_link != blank -%}{{ _sep }}{{ settings.social_vimeo_link | json }}{%- assign _sep = ',' -%}{%- endif -%}
    {%- if settings.social_linkedin_link != blank -%}{{ _sep }}{{ settings.social_linkedin_link | json }}{%- assign _sep = ',' -%}{%- endif -%}
    {%- if settings.social_spotify_link != blank -%}{{ _sep }}{{ settings.social_spotify_link | json }}{%- assign _sep = ',' -%}{%- endif -%}
    {%- if settings.social_whatsapp_link != blank -%}{{ _sep }}{{ settings.social_whatsapp_link | json }}{%- assign _sep = ',' -%}{%- endif -%}
    {%- if settings.social_discord_link != blank -%}{{ _sep }}{{ settings.social_discord_link | json }}{%- assign _sep = ',' -%}{%- endif -%}
  ]
  {%- if settings.contact_email != blank or settings.contact_phone_number != blank -%}
  ,"contactPoint": [
    {%- assign _csep = '' -%}
    {%- if settings.contact_phone_number != blank -%}
    {{ _csep }}{
      "@type": "ContactPoint",
      "telephone": {{ settings.contact_phone_number | json }},
      "contactType": "customer service",
      "availableLanguage": "Portuguese"
    }
    {%- assign _csep = ',' -%}
    {%- endif -%}
    {%- if settings.contact_email != blank -%}
    {{ _csep }}{
      "@type": "ContactPoint",
      "email": {{ settings.contact_email | json }},
      "contactType": "customer service",
      "availableLanguage": "Portuguese"
    }
    {%- endif -%}
  ]
  {%- endif -%}
}
</script>

{%- comment -%}
  ===== STRUCTURED DATA: WebSite + SearchAction (somente na Home) =====
  - EntryPoint format (spec 2026)
  - inLanguage pt-BR
  - publisher referenciando Organization
{%- endcomment -%}
{% if request.page_type == 'index' %}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": {{ request.origin | append: '/#website' | json }},
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }},
    "inLanguage": "pt-BR",
    "publisher": {
      "@id": {{ request.origin | append: '/#organization' | json }}
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": {{ potential_action_target | json }}
      },
      "query-input": "required name=search_term_string"
    }
  }
  </script>
{% endif %}

{%- comment -%}
  ===== STRUCTURED DATA: BreadcrumbList (por tipo de página) =====
  - Home, Coleção, Blog, Artigo
  - CollectionPage para páginas de coleção
{%- endcomment -%}
{% if request.page_type == 'index' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [{
      "@type": "ListItem",
      "position": 1,
      "item": {
        "@id": "{{ request.origin }}",
        "name": "Home"
      }
    }]
  }
  </script>
{%- elsif template.name == 'collection' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@id": "{{ request.origin }}",
          "name": "Home"
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@id": {{ collection.url | prepend: request.origin | json }},
          "name": {{ collection.title | json }}
        }
      }
    ]
  }
  </script>
  {%- comment -%} CollectionPage Schema {%- endcomment -%}
  {%- if collection and collection.title != blank -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": {{ collection.title | json }},
    {%- if collection.description != blank -%}
      "description": {{ collection.description | strip_html | truncate: 300 | json }},
    {%- endif -%}
    "url": {{ collection.url | prepend: request.origin | json }},
    {%- if collection.image -%}
      "image": {{ collection.image | image_url: width: collection.image.width | prepend: "https:" | json }},
    {%- endif -%}
    "numberOfItems": {{ collection.products_count | default: collection.products.size }},
    "inLanguage": "pt-BR",
    "isPartOf": {
      "@id": {{ request.origin | append: '/#website' | json }}
    }
  }
  </script>
  {%- endif -%}
{%- elsif template.name == 'blog' and blog and blog.title != blank -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@id": "{{ request.origin }}",
          "name": "Home"
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@id": {{ blog.url | prepend: request.origin | json }},
          "name": {{ blog.title | json }}
        }
      }
    ]
  }
  </script>
{%- elsif template.name == 'article' and article and article.title != blank -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@id": "{{ request.origin }}",
          "name": "Home"
        }
      }
      {%- if blog and blog.title != blank -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@id": {{ blog.url | prepend: request.origin | json }},
          "name": {{ blog.title | json }}
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@id": {{ article.url | prepend: request.origin | json }},
          "name": {{ article.title | json }}
        }
      }
      {%- else -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@id": {{ article.url | prepend: request.origin | json }},
          "name": {{ article.title | json }}
        }
      }
      {%- endif -%}
    ]
  }
  </script>
{% endif %}

{% liquid
  assign transparent_on_top = false

  if template.name == 'index'
    assign transparent_on_top = section.settings.transparent_on_top
  endif

  assign show_language_switcher = section.settings.show_language_switcher
  assign show_currency_switcher = section.settings.show_currency_switcher
  assign show_account_icon = section.settings.show_account_icon
  assign show_wishlist_icon = section.settings.show_wishlist_icon
  assign show_compare_icon = section.settings.show_compare_icon
  assign show_cart_icon = section.settings.show_cart_icon
  assign show_country_selector = section.settings.show_country_selector
  assign design = section.settings.header_design
  assign container = section.settings.container
  assign search_settings = section.settings.search

  if container == 'w-full'
    assign container = 'container-full'
  endif

  assign logo_aspect_ratio = section.settings.logo.aspect_ratio | default: 2.333
%}

{% style %}
  :root {
    --logo-width-desktop: {{ section.settings.logo_max_width }}px;
    --logo-width-mobile: {{ section.settings.mobile_logo_max_width }}px;
    --logo-width-sticky: {{ section.settings.sticky_logo_max_width }}px;
    --logo-height-sticky: {{ section.settings.sticky_logo_max_width | divided_by: logo_aspect_ratio }}px;
    --header-transparent-text-color: {{ section.settings.transparent_text_color.red }}, {{ section.settings.transparent_text_color.green }}, {{ section.settings.transparent_text_color.blue }};
  }

  {% if section.settings.header_blur %}
    .m-header__wrapper{
      background: rgba(0, 0, 0, 0.35);
      backdrop-filter: blur(17.5px);
    }
    .m-header__mobile {
      background-color: transparent;
    }
    @media screen and (min-width: 1024px) {
        .m-header__desktop {
            background: transparent;
        }
    }
  {% endif %}

  {% if section.settings.header_design == 'logo-center__2l' %}
    {% if section.settings.show_menu_link_divider %}
      /* Divisor entre os itens do menu */
      .logo-center__2l .m-menu .m-menu__item:not(:first-child)::before {
        content: "";
        background: currentColor;
        height: 50%;
        width: 1px;
        position: absolute;
        left: 0px;
        top: 50%;
        transform: translateY(-50%);
        z-index: 1;
      }
      .logo-center__2l .m-menu .m-menu__item {
        position: relative;
      }
      /* Espaçamento entre os itens do menu e Padding entre o menu e os links*/
      .logo-center__2l .m-menu {
        --main-link-px: 16px !important;
        --main-link-py: 12px !important;
        padding-top: 10px;
        padding-bottom: 10px;
      }
    {% endif %}

    {% if section.settings.show_menu_bottom_divider %}
      /* Divisor entre o menu e os links */
      .logo-center__2l .m-header__container.container-fluid > .m-header__inner {
        position: relative;
      }
      .logo-center__2l .m-header__container.container-fluid > .m-header__inner::after {
        content: "";
        background: {{ section.settings.menu_bottom_divider_color }};
        height: 1.3px;
        width: 100%;
        position: absolute;
        left: 0;
        bottom: 0;
      }

      /* Padding entre o menu e os links */
      .logo-center__2l .m-header__container.container-fluid > .m-header__inner {
        padding-bottom: 10px;
      }
    {% endif %}

  {% endif %}
{% endstyle %}
<m-header
  data-section-id="{{ section.id }}"
  data-section-type="header"
  data-page="{{ request.path | strip }}"
  data-header-design="{{ section.settings.header_design }}"
  {% if request.design_mode == true %}
    data-design-mode="true"
  {% endif %}
  class="m-header m:block{% if transparent_on_top %} transparent-on-top{% endif %}"
  data-transparent="{{ transparent_on_top }}"
  data-sticky="{{ section.settings.sticky_header }}"
>
  {% render 'header__topbar', header: section %}
  <div class="m-header__wrapper">
    {% comment %}Header Mobile{% endcomment %}
    <header
      class="m-header__mobile container-fluid m:flex m:items-center m-gradient m-color-{{ section.settings.color_scheme }}"
      data-screen="m-header__mobile"
      data-transparent="{{ transparent_on_top }}"
    >
      <div class="m-header__mobile-left m:flex m:flex-1 m:w-3/12 m:items-center">
        <span class="m-menu-button m:flex">
          <div class="m-hamburger-box">
            <div class="m-hamburger-box__inner"></div>
          </div>
        </span>
        {% if search_settings != 'hide' %}
          <m-search-popup class="m:flex m:justify-center m:items-center" data-open-search-popup>
            <span class="m-header__search-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 17 17" fill="none" class="m-svg-icon--medium">
                <path d="M16.5 16.5L12.6396 12.6396M12.6396 12.6396C13.2999 11.9793 13.8237 11.1953 14.1811 10.3326C14.5385 9.46978 14.7224 8.54507 14.7224 7.61121C14.7224 6.67735 14.5385 5.75264 14.1811 4.88987C13.8237 4.0271 13.2999 3.24316 12.6396 2.58283C11.9793 1.92249 11.1953 1.39868 10.3326 1.04131C9.46978 0.683937 8.54507 0.5 7.61121 0.5C6.67735 0.5 5.75264 0.683937 4.88987 1.04131C4.0271 1.39868 3.24316 1.92249 2.58283 2.58283C1.24921 3.91644 0.5 5.7252 0.5 7.61121C0.5 9.49722 1.24921 11.306 2.58283 12.6396C3.91644 13.9732 5.7252 14.7224 7.61121 14.7224C9.49722 14.7224 11.306 13.9732 12.6396 12.6396Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </m-search-popup>
        {% endif %}
      </div>
      {% comment %} Header-logo-mobile {% endcomment %}
      {% liquid
        assign class = 'm-logo m-logo--mobile m:justify-center ' | append: 'm:w-6/12'

        assign aspect_ratio = section.settings.logo.aspect_ratio | default: 2.333
        assign aspect_ratio_mobile = section.settings.logo_mobile.aspect_ratio | default: aspect_ratio

        assign logo_text = section.settings.logo_text
        assign logo_desktop = section.settings.logo
        assign logo_mobile = section.settings.logo_mobile
        assign logo_svg_desktop = section.settings.logo_svg
        assign logo_svg_mobile = section.settings.logo_mobile_svg

        assign logo_transparent = section.settings.logo_transparent
        assign logo_transparent_svg = section.settings.logo_transparent_svg

        assign logo_alt = section.settings.logo.alt | default: shop.name

        assign transparent_on_top = section.settings.transparent_on_top

        assign logo = ''
        assign is_svg = false
        if logo_svg_mobile != blank
          assign logo = logo_svg_mobile
          assign is_svg = true
        elsif logo_svg_desktop != blank
          assign logo = logo_svg_desktop
          assign is_svg = true
        elsif logo_mobile != blank
          assign logo = logo_mobile
          assign is_svg = false
        elsif logo_desktop != blank
          assign logo = logo_desktop
          assign is_svg = false
        else
          assign logo = ''
          assign is_svg = false
        endif

        if section.settings.logo
          assign class = class | append: ' m-logo--has-image'
        endif
      %}

      <div class="{{ class | strip_newlines }}">
        {% if logo != blank %}
          <a href="{{ routes.root_url }}" class="m-logo__image m:block" title="{{ shop.name }}">
            {% if is_svg %}
              <div class="m-logo__image-default m:display-flex m-image">
                {% comment %}theme-check-disable RemoteAsset{% endcomment %}
                <img src="{{ logo }}" alt="{{ logo_alt }}" width="auto" height="auto" loading="lazy">
                {% comment %}theme-check-enable RemoteAsset{% endcomment %}
              </div>
            {% else %}
              <div
                class="m-logo__image-default m:display-flex m-image"
                style="--aspect-ratio: {{ aspect_ratio }};--aspect-ratio-mobile: {{ aspect_ratio_mobile }}"
              >
                {% liquid
                  assign logo_alt = logo.alt | default: shop.name | escape
                  assign logo_height = section.settings.mobile_logo_max_width | divided_by: logo.aspect_ratio | round
                %}
                {{
                  logo
                  | image_url: width: section.settings.width
                  | image_tag:
                    class: 'm:inline-block',
                    widths: '50, 100, 150, 200, 250, 300, 400',
                    height: logo_height,
                    width: section.settings.logo_width,
                    alt: logo_alt
                }}
              </div>
            {% endif %}
            {% if transparent_on_top %}
              {%- liquid
                assign logo_transparent_mobile = ''
                if logo_transparent_svg != blank
                  assign logo_transparent_mobile = logo_transparent_svg
                elsif logo_transparent != blank
                  assign logo_transparent_mobile = logo_transparent
                else
                  assign logo_transparent_mobile = logo
                endif
              -%}
              {% if logo_transparent_svg != blank %}
                <div class="m-logo__image-transparent m:display-flex m-image">
                  {% comment %} theme-check-disable RemoteAsset {% endcomment %}
                  <img
                    src="{{ logo_transparent_mobile }}"
                    alt="{{ logo_alt }}"
                    width="auto"
                    height="auto"
                    loading="lazy"
                  >
                  {% comment %} theme-check-enable RemoteAsset {% endcomment %}
                </div>
              {% else %}
                <div class="m-logo__image-transparent m:display-flex m-image">
                  {{
                    logo_transparent_mobile
                    | image_url: width: section.settings.width
                    | image_tag:
                      class: 'm:inline-block',
                      widths: '50, 100, 150, 200, 250, 300, 400',
                      height: logo_height,
                      width: section.settings.logo_width,
                      alt: logo_alt
                  }}
                </div>
              {% endif %}
            {% endif %}
          </a>
        {% else %}
          <a href="{{ routes.root_url }}" class="m:block m:text-center">
            <strong>{{ logo_text | default: shop.name }}</strong>
          </a>
        {% endif %}
      </div>
      {% comment %} End header logo mobile {% endcomment %}
      {% if show_cart_icon or show_account_icon %}
        <div class="m-header__mobile-right m:w-3/12 m:flex m:flex-1 m:justify-end m:items-center">
          {% if show_account_icon %}
            {% render 'header-option-item__account', display_by: 'icon' %}
          {% endif %}
          {% if show_cart_icon %}
            {% render 'cart' %}
          {% endif %}
        </div>
      {% endif %}

      {% render 'header-menu-drawer', section: section %}
    </header>

    {% comment %}Header Desktop{% endcomment %}
    <header
      class="m-header__desktop {{ design }} m-gradient m-color-{{ section.settings.color_scheme }}"
      data-screen="m-header__desktop"
      data-transparent="{{ transparent_on_top }}"
    >
      <div class="m-header__bg m-gradient m-color-{{ section.settings.color_scheme }}"></div>
      <div class="m-header__dropdown-bg m-gradient m-color-{{ section.settings.color_scheme }}"></div>
      {% case design %}
        {% when 'logo-center-menu-left' %}
          <div class="m-header__container {{ container }}">
            <div class="m-header__inner">
              <div class="m-header__left m:w-5/12">
                {% render 'header-main-menu-container', section: section %}
              </div>
              <div class="m-header__center m:w-2/12">
                {% render 'header-logo', header_settings: section.settings %}
              </div>
              <div class="m-header__right m:w-5/12">
                {% liquid
                  if show_language_switcher
                    render 'language-switcher', box_size: 'm:hidden xl:m:block'
                  endif

                  if show_currency_switcher
                    render 'currency-switcher', box_size: 'm:hidden xl:m:block'
                  endif

                  if show_country_selector
                    render 'country-selector', box_size: 'm:hidden xl:m:block'
                  endif

                  render 'header-option-item__search', header_settings: section.settings
                  if show_account_icon
                    render 'header-option-item__account', display_by: 'icon'
                  endif

                  if show_wishlist_icon
                    render 'header-option-item__wishlist', display_by: 'icon'
                  endif

                  if show_compare_icon
                    render 'header-option-item__compare', display_by: 'icon'
                  endif

                  if show_cart_icon
                    render 'cart'
                  endif
                %}
              </div>
            </div>
          </div>
        {% when 'both-center' %}
          <div class="m-header__container {{ container }}">
            <div class="m-header__inner">
              <div class="m-header__left m:w-2/12">
                {% liquid
                  if show_language_switcher
                    render 'language-switcher', box_size: 'm:hidden xl:m:block'
                  endif

                  if show_currency_switcher
                    render 'currency-switcher', box_size: 'm:hidden xl:m:block'
                  endif

                  if show_country_selector
                    render 'country-selector', box_size: 'm:hidden xl:m:block'
                  endif

                  render 'header-option-item__search', header_settings: section.settings, icon_left: true
                %}
              </div>
              <div class="m-header__center m:w-8/12">
                {% render 'header-main-menu-container', section: section %}
                {% render 'header-logo', header_settings: section.settings %}
                {% render 'header-main-menu-container', section: section, menu: 'secondary_menu' %}
              </div>
              <div class="m-header__right m:w-2/12">
                {% liquid
                  if show_account_icon
                    render 'header-option-item__account', display_by: 'icon'
                  endif

                  if show_wishlist_icon
                    render 'header-option-item__wishlist', display_by: 'icon'
                  endif

                  if show_compare_icon
                    render 'header-option-item__compare', display_by: 'icon'
                  endif

                  if show_cart_icon
                    render 'cart'
                  endif
                %}
              </div>
            </div>
          </div>
        {% when 'logo-left-menu-center' %}
          <div class="m-header__container {{ container }}">
            <div class="m-header__inner">
              <div class="m-header__left">
                {% render 'header-logo', header_settings: section.settings %}
              </div>
              <div class="m-header__center">
                {% render 'header-main-menu-container', section: section %}
              </div>
              <div class="m-header__right">
                {% liquid
                  if show_language_switcher
                    render 'language-switcher', box_size: 'm:hidden xl:m:block'
                  endif

                  if show_currency_switcher
                    render 'currency-switcher', box_size: 'm:hidden xl:m:block'
                  endif

                  if show_country_selector
                    render 'country-selector', box_size: 'm:hidden xl:m:block'
                  endif

                  render 'header-option-item__search', header_settings: section.settings
                  if show_account_icon
                    render 'header-option-item__account', display_by: 'icon'
                  endif

                  if show_wishlist_icon
                    render 'header-option-item__wishlist', display_by: 'icon'
                  endif

                  if show_compare_icon
                    render 'header-option-item__compare', display_by: 'icon'
                  endif

                  if show_cart_icon
                    render 'cart'
                  endif
                %}
              </div>
            </div>
          </div>
        {% when 'logo-center__2l' %}
          <div class="m-header__top">
            <div class="m-header__container {{ container }}">
              <div class="m-header__inner">
                <div class="m-header__left m:w-2/5">
                  {% liquid
                    if show_language_switcher
                      render 'language-switcher'
                    endif

                    if show_currency_switcher
                      render 'currency-switcher'
