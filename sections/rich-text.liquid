{{ 'rich-text.css' | asset_url | stylesheet_tag }}
{% liquid
  assign animation_effect = settings.animations
  assign animated = false
  if animation_effect != 'none'
    assign animated = true
    if section.settings.animations != 'inherit'
      assign animation_effect = section.settings.animations
    endif
  endif

  assign show_image = false
  if section.settings.image_1 != blank or section.settings.image_2 != blank or section.settings.image_3 != blank
    assign show_image = true
  endif

  comment
    Verifica se a seção deve ser ocultada:
    - Se tiver apenas 1 bloco
    - E esse bloco for collapsible_text
    - E o conteúdo estiver vazio (incluindo metafields vazios)
  endcomment
  assign hide_section = false
  if section.blocks.size == 1
    assign single_block = section.blocks[0]
    if single_block.type == 'collapsible_text'
      assign content_value = single_block.settings.collapsible_content
      comment
        strip_html remove tags HTML e strip remove espaços
        Isso verifica se o conteúdo é realmente vazio mesmo com tags HTML
      endcomment
      assign content_stripped = content_value | strip_html | strip
      if content_stripped == blank
        assign hide_section = true
      endif
    endif
  endif
%}

{%- style -%}
  #m-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    {% if hide_section %}display: none;{% endif %}
  }
{%- endstyle -%}

<section
  id="m-section-{{ section.id }}"
  class="m-section m-rich-text{% if show_image %} m-rich-text--show-images{% endif %} m-gradient m-color-{{ section.settings.color_scheme }} {{ section.settings.custom_class }}"
>
  <div class="{{ section.settings.container }} m-section-my m-section-py">
    <div class="m-richtext m:text-{{ section.settings.content_alignment }}">
      {%- for block in section.blocks -%}
        {% case block.type %}
          {%- when 'heading' -%}
            {%- if block.settings.heading != blank -%}
              <h2
                class="m-richtext__title {{ block.settings.heading_size }}{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
                {% if animated %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
                {{ block.shopify_attributes }}
              >
                {{ block.settings.heading }}
              </h2>
            {% endif %}
          {%- when 'subheading' -%}
            {%- if block.settings.subheading != blank -%}
              <p
                class="m-richtext__subtitle{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
                {% if animated %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
                {{ block.shopify_attributes }}
              >
                {{ block.settings.subheading }}
              </p>
            {% endif %}
          {%- when 'text' -%}
            {%- if block.settings.text != blank -%}
              <div
                class="m-richtext__description rte{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
                {% if animated %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>
            {% endif %}
          {%- when 'button' -%}
            {%- if block.settings.button_label != blank -%}
              <div
                class="m-richtext__button{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
                {% if animated %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                <a
                  href="{{ block.settings.button_link }}"
                  class="m-button {{ block.settings.button_style }} {{ block.settings.button_size }}"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.button_label -}}
                </a>
              </div>
            {%- endif -%}
          {%- when 'collapsible_text' -%}
            {%- if block.settings.collapsible_content != blank -%}
              {%- liquid
                assign collapsed_height = block.settings.collapsed_height | default: 220
                assign fade_height = block.settings.fade_height | default: 90
                assign animation_duration = block.settings.animation_duration | default: 400
              -%}
              <div
                class="m-richtext__collapsible{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
                data-collapsible-block="{{ block.id }}"
                style="
                  --rt-collapsed: {{ collapsed_height }}px;
                  --rt-fade-height: {{ fade_height }}px;
                  --rt-duration: {{ animation_duration }}ms;
                  --rt-bg: var(--color-background-rgb, 255,255,255);
                  {% if animated %}--animation-order: {{ forloop.index }};{% endif %}
                "
                {% if animated %}data-cascade{% endif %}
                {{ block.shopify_attributes }}
              >
                <div class="m-richtext__collapsible-wrapper" data-rt-collapsible data-collapsed="{{ collapsed_height }}">
                  <div class="m-richtext__collapsible-content rte" id="rt-content-{{ block.id }}">
                    {{ block.settings.collapsible_content }}
                  </div>
                  <div class="m-richtext__collapsible-fade" aria-hidden="true"></div>
                </div>
                <div class="m-richtext__collapsible-toggle-wrap">
                  <button
                    type="button"
                    class="m-richtext__collapsible-toggle"
                    aria-controls="rt-content-{{ block.id }}"
                    aria-expanded="false"
                    hidden
                  >
                    <span class="m-richtext__collapsible-label-more">{{ block.settings.read_more_label | default: 'Ler mais' }}</span>
                    <span class="m-richtext__collapsible-label-less">{{ block.settings.read_less_label | default: 'Ler menos' }}</span>
                  </button>
                </div>
              </div>
            {%- endif -%}
          {%- when 'instagram_header' -%}
            {%- if block.settings.instagram_image != blank or block.settings.instagram_text != blank or block.settings.instagram_svg != blank -%}
              <div
                class="m-richtext__instagram-header{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
                {% if animated %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
                {{ block.shopify_attributes }}
              >
                <div class="m-richtext__instagram-header-container">
                  {%- if block.settings.instagram_link_url != blank -%}
                    <a 
                      href="{{ block.settings.instagram_link_url }}" 
                      class="m-richtext__instagram-header-link-wrapper"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                  {%- endif -%}
                      {%- if block.settings.instagram_image != blank -%}
                        <div class="m-richtext__instagram-header-image-wrapper">
                          <img 
                            src="{{ block.settings.instagram_image | image_url: width: 50 }}" 
                            alt="{{ block.settings.instagram_text | default: 'Instagram' }}"
                            class="m-richtext__instagram-header-image"
                            loading="lazy"
                          >
                        </div>
                      {%- endif -%}
                      {%- if block.settings.instagram_text != blank -%}
                        <h4 class="heading h3 m-richtext__instagram-header-text">{{ block.settings.instagram_text }}</h4>
                      {%- endif -%}
                      {%- if block.settings.instagram_svg != blank -%}
                        <div class="m-richtext__instagram-header-svg">
                          {{ block.settings.instagram_svg }}
                        </div>
                      {%- endif -%}
                  {%- if block.settings.instagram_link_url != blank -%}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.instagram_link_text != blank and block.settings.instagram_link_url != blank -%}
                    <a 
                      href="{{ block.settings.instagram_link_url }}" 
                      class="m-richtext__instagram-header-link"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {{ block.settings.instagram_link_text }}
                    </a>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
  {% if show_image %}
    <div class="m-rich-text__images">
      <div class="{{ section.settings.container }} m-rich-text__images-container">
        <div class="m-rich-text__images-wrapper">
          {% if section.settings.image_1 != blank %}
            <div class="m-rich-text__image m-rich-text__image-1">
              {% render 'responsive-image', image: section.settings.image_1, section_index: section.index, index: 1 %}
            </div>
          {% endif %}
          {% if section.settings.image_2 != blank %}
            <div class="m-rich-text__image m-rich-text__image-2">
              {% render 'responsive-image', image: section.settings.image_2, section_index: section.index, index: 1 %}
            </div>
          {% endif %}
          {% if section.settings.image_3 != blank %}
            <div class="m-rich-text__image m-rich-text__image-3">
              {% render 'responsive-image', image: section.settings.image_3, section_index: section.index, index: 1 %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  {% endif %}
</section>

{%- comment -%} JavaScript para blocos colapsáveis {%- endcomment -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'collapsible_text' and block.settings.collapsible_content != blank -%}
    <script>
      (function() {
        var blockEl = document.querySelector('[data-collapsible-block="{{ block.id }}"]');
        if (!blockEl) return;

        var wrapper = blockEl.querySelector('[data-rt-collapsible]');
        var content = wrapper && wrapper.querySelector('.m-richtext__collapsible-content');
        var toggle = blockEl.querySelector('.m-richtext__collapsible-toggle');
        if (!wrapper || !content || !toggle) return;

        var collapsedHeight = parseInt(wrapper.getAttribute('data-collapsed'), 10) || 220;

        function setMax(h) {
          wrapper.style.setProperty('--rt-max-height', h + 'px');
        }
        function needsTruncate() {
          return content.scrollHeight > collapsedHeight + 1;
        }
        function applyState(expanded) {
          if (expanded) {
            wrapper.classList.add('is-expanded');
            toggle.setAttribute('aria-expanded', 'true');
            setMax(content.scrollHeight);
          } else {
            wrapper.classList.remove('is-expanded');
            toggle.setAttribute('aria-expanded', 'false');
            setMax(collapsedHeight);
          }
        }
        function measureAndInit() {
          if (!needsTruncate()) {
            toggle.hidden = true;
            setMax(content.scrollHeight);
            wrapper.classList.add('is-expanded');
            return;
          }
          toggle.hidden = false;
          if (toggle.getAttribute('aria-expanded') === 'true') {
            setMax(content.scrollHeight);
            wrapper.classList.add('is-expanded');
          } else {
            setMax(collapsedHeight);
            wrapper.classList.remove('is-expanded');
          }
        }

        requestAnimationFrame(measureAndInit);

        toggle.addEventListener('click', function() {
          var expanded = toggle.getAttribute('aria-expanded') === 'true';
          applyState(!expanded);
        });

        if ('ResizeObserver' in window) {
          var ro = new ResizeObserver(function() {
            if (toggle.getAttribute('aria-expanded') === 'true') {
              setMax(content.scrollHeight);
            } else {
              setMax(collapsedHeight);
            }
            if (!needsTruncate()) {
              toggle.hidden = true;
              wrapper.classList.add('is-expanded');
              setMax(content.scrollHeight);
            } else {
              toggle.hidden = false;
            }
          });
          ro.observe(content);
        }

        window.addEventListener('resize', function() {
          if (toggle.getAttribute('aria-expanded') === 'true') {
            setMax(content.scrollHeight);
          }
        });

        document.addEventListener('shopify:block:select', function(e) {
          if (e && e.detail && e.detail.blockId === '{{ block.id }}') {
            measureAndInit();
          }
        });
      })();
    </script>
  {%- endif -%}
{%- endfor -%}

{% schema %}
{
  "name": "Rich text",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Container type",
      "default": "container",
      "options": [
        {
          "value": "container-fluid",
          "label": "Default"
        },
        {
          "value": "container-full",
          "label": "Full width"
        },
        {
          "value": "container",
          "label": "Use container box"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Image settings"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 52,
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 52,
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "default": 20,
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "default": 20,
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Custom Attributes"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom classes"
    },
    {
      "type": "header",
      "content": "Animations"
    },
    {
      "type": "select",
      "id": "animations",
      "label": "Visible in the view animation",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "Inherit global setting"
        },
        {
          "value": "fade-in",
          "label": "Fade in"
        },
        {
          "value": "fade-in-up",
          "label": "Fade in up"
        },
        {
          "value": "fade-in-left",
          "label": "Fade in left"
        },
        {
          "value": "fade-in-right",
          "label": "Fade in right"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Subheading text"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
          "default": "Talk about your brand"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "default": "h2",
          "options": [
            {
              "label": "Medium",
              "value": "h3"
            },
            {
              "label": "Large",
              "value": "h2"
            }
          ]
