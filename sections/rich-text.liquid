          "type": "image_picker",
          "id": "instagram_image",
          "label": "Foto"
        },
        {
          "type": "text",
          "id": "instagram_text",
          "label": "Texto",
          "default": "nome_instagram"
        },
        {
          "type": "textarea",
          "id": "instagram_svg",
