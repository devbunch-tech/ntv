07868 3.27239 6.11209 3.23562 6.154C3.19885 6.19591 3.17019 6.24548 3.15136 6.29973C3.13253 6.35399 3.12392 6.41182 3.12602 6.46979C3.12812 6.52776 3.1409 6.58467 3.1636 6.63714C3.18629 6.6896 3.21845 6.73654 3.25813 6.77516L4.86911 8.45926C4.91222 8.50424 4.9641 8.538 5.02086 8.55804C5.07762 8.57808 5.13778 8.58387 5.19687 8.57498C5.25597 8.56609 5.31248 8.54276 5.36215 8.50671C5.41181 8.47066 5.45337 8.42283 5.48372 8.3668L7.80831 4.07317Z\" fill=\"#2CAEFF\"></path></svg>"
        },
        {
          "type": "text",
          "id": "instagram_link_text",
          "label": "Texto do link",
