{% liquid
  assign has_qty_rules = false
  if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
    assign has_qty_rules = true
  endif

  assign has_vol_pricing = false
  if item.variant.quantity_price_breaks.size > 0
    assign has_vol_pricing = true
  endif
%}
{%- if has_qty_rules or has_vol_pricing -%}
  {%- capture qty_rules_vol_pricing -%}
      {%- if has_qty_rules -%}
        <div class="quantity__rules m:text-sm m:flex-wrap">
          {%- if item.variant.quantity_rule.increment > 1 -%}
            <span class="divider">
              {%- render 'new-locale',
                key: 'products.product.quantity_multiples_of',
                param: '{{ quantity }}',
                value: item.variant.quantity_rule.increment
              -%}
            </span>
          {%- endif -%}
          {%- if item.variant.quantity_rule.min > 1 -%}
            <span class="divider">
              {%- render 'new-locale',
                key: 'products.product.quantity_minimum_of',
                param: '{{ quantity }}',
                value: item.variant.quantity_rule.min
              -%}
            </span>
          {%- endif -%}
          {%- if item.variant.quantity_rule.max != null -%}
            <span class="divider">
              {%- render 'new-locale',
                key: 'products.product.quantity_maximum_of',
                param: '{{ quantity }}',
                value: item.variant.quantity_rule.max
              -%}
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- if has_vol_pricing -%}
        {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
        <volume-pricing
          class="volume-pricing m:block parent-display{% unless has_qty_rules %} volume-pricing--empty-header{% endunless %}"
          id="Volume-{{ section.id }}"
        >
          <ul class="list-unstyled volume-pricing__list">
            <li class="volume-pricing__item">
              <span>{{ item.variant.quantity_rule.min }}+</span>
              {%- liquid
                if settings.currency_code_enabled
                  assign price = item.variant.price | money_with_currency
                else
                  assign price = item.variant.price | money
                endif
              -%}
              {%- capture price_at_each -%}
                {%- render 'new-locale',
                  key: 'products.product.volume_pricing.price_at_each',
                  param: '{{ price }}',
                  value: price
                -%}
              {%- endcapture -%}
              <span data-text="{{ price_at_each | strip_html }}">
                {%- render 'new-locale',
                  key: 'products.product.volume_pricing.each_html',
                  param: '{{ money }}',
                  value: price
                -%}
              </span>
            </li>
            {%- for price_break in item.variant.quantity_price_breaks -%}
              {%- liquid
                if settings.currency_code_enabled
                  assign price_break_price = price_break.price | money_with_currency
                else
                  assign price_break_price = price_break.price | money
                endif
              -%}
              <li class="volume-pricing__item">
                <span>
                  {{- price_break.minimum_quantity -}}
                  <span aria-hidden="true">+</span></span
                >
                {%- capture price_at_each -%}
                  {%- render 'new-locale',
                    key: 'products.product.volume_pricing.price_at_each',
                    param: '{{ price }}',
                    value: price_break_price
                  -%}
                {%- endcapture -%}
                <span data-text="{{ price_at_each | strip_html }}">
                  {%- render 'new-locale',
                    key: 'products.product.volume_pricing.each_html',
                    param: '{{ money }}',
                    value: price_break_price
                  -%}
                </span>
              </li>
            {%- endfor -%}
          </ul>
        </volume-pricing>
      {%- endif -%}
    {%- endcapture -%}
{%- endif -%}
<div
  id="MinimogCart-Item-{{ item.index | plus: 1 }}"
  class="m-cart-item m-cart-drawer-item"
  data-cart-item
  data-product-id="{{- item.product_id -}}"
  data-index="{{- forloop.index -}}"
>
  <div class="m-cart-item--drawer__wrapper m:flex m:items-start">
    <div class="m-cart-drawer-item__image m-cart-item__image m:blocks-radius-md">
      <a href="{{- item.url -}}">
        {% if item.image != blank %}
          {% render 'responsive-image', image: item.image, wrapper_class: 'm-cart-item__image' %}
        {% else %}
          {{- 'image' | placeholder_svg_tag: 'm-placeholder-svg' -}}
        {% endif %}
      </a>
    </div>
    {%- assign use_compare_price_style = force_compare_price_style | default: false -%}
    <div class="m-cart-item__info m-cart-drawer-item__info{% if settings.cart_drawer_card_style == 'card_2' %} m-cart-item__info--card-2{% elsif settings.cart_drawer_card_style == 'card_4' %} m-cart-item__info--card-4{% elsif settings.cart_drawer_card_style == 'card_3' or use_compare_price_style %} m-cart-item__info--card-3{% endif %}">
      {% if settings.cart_drawer_card_style == 'card_4' %}
        {%- comment -%} Card 4: delete icon top-right {%- endcomment -%}
        <m-cart-remove-button
          id="MinimogCartDrawer-Remove-{{ item.index | plus: 1 }}"
          data-index="{{ item.index | plus: 1 }}"
          class="m-cart-item__remove--card-4-wrap"
        >
          <button type="button" class="m-cart-item__remove m-cart-item__remove--icon m-cart-item__remove--card-4{% unless gift_wrap_id == nil or item.id != gift_wrap_id %} m:hidden{% endunless %}" aria-label="{{ 'cart.general.remove' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <g clip-path="url(#clip-trash-{{ item.index }})">
                <path d="M11.0849 4.98799L9.97926 11.2762C9.93415 11.5331 9.79996 11.7657 9.60027 11.9334C9.40058 12.1011 9.14818 12.193 8.88744 12.1929H4.41482C4.15408 12.193 3.90168 12.1011 3.70199 11.9334C3.5023 11.7657 3.3681 11.5331 3.323 11.2762L2.21731 4.98799M11.6392 3.32531H8.52165M8.52165 3.32531V2.21685C8.52165 1.92287 8.40486 1.64093 8.19699 1.43306C7.98911 1.22518 7.70717 1.1084 7.41319 1.1084H5.88907C5.59509 1.1084 5.31315 1.22518 5.10527 1.43306C4.8974 1.64093 4.78061 1.92287 4.78061 2.21685V3.32531M8.52165 3.32531H4.78061M1.66309 3.32531H4.78061" stroke="currentColor" stroke-width="0.75" stroke-linecap="round" stroke-linejoin="round"/>
              </g>
              <defs>
                <clipPath id="clip-trash-{{ item.index }}">
                  <rect width="13.3014" height="13.3014" fill="white"/>
                </clipPath>
              </defs>
            </svg>
          </button>
        </m-cart-remove-button>
      {% endif %}
      <div class="m-cart-item__header{% if settings.cart_drawer_card_style == 'card_2' %} m-cart-item__header--card-2{% elsif settings.cart_drawer_card_style == 'card_3' or use_compare_price_style and settings.cart_drawer_card_style != 'card_4' %} m-cart-item__header--card-3{% endif %}">
        <a href="{{- item.url -}}" class="m-cart-item__title">
          {{- item.product.title -}}
        </a>
        {% if settings.cart_drawer_card_style == 'card_2' %}
          <div class="m-cart-item__price m-cart-item__price--card-2">
            {%- liquid
              assign compare_at_price = item.variant.compare_at_price
              assign has_compare_price = false
              if compare_at_price != null and compare_at_price > item.final_price
                assign has_compare_price = true
              endif
            -%}
            {%- if has_compare_price -%}
              <div class="m-cart-item__price-discounted m-cart-item__price-discounted--card-2">
                <del class="m-cart-item__price--regular m-cart-item__price--compare">
                  {% if settings.currency_code_enabled %}
                    {{- compare_at_price | money_with_currency -}}
                  {% else %}
                    {{- compare_at_price | money -}}
                  {% endif %}
                </del>
                <span class="m-cart-item__price--final">
                  {% if settings.currency_code_enabled %}
                    {{- item.final_price | money_with_currency -}}
                  {% else %}
                    {{- item.final_price | money -}}
                  {% endif %}
                </span>
              </div>
            {%- else -%}
              <span class="m-cart-item__price--regular">
                {% if settings.currency_code_enabled %}
                  {{- item.final_price | money_with_currency -}}
                {% else %}
                  {{- item.final_price | money -}}
                {% endif %}
              </span>
            {%- endif -%}
          </div>
        {% elsif settings.cart_drawer_card_style == 'card_3' or use_compare_price_style and settings.cart_drawer_card_style != 'card_4' %}
          <div class="m-cart-item__price m-cart-item__price--card-3">
            {%- liquid
              assign compare_at_price = item.variant.compare_at_price
              assign has_compare_price = false
              if compare_at_price != null and compare_at_price > item.final_price
                assign has_compare_price = true
              endif
            -%}
            {%- if has_compare_price -%}
              <div class="m-cart-item__price-discounted m-cart-item__price-discounted--card-3">
                <del class="m-cart-item__price--regular m-cart-item__price--compare">
                  {% if settings.currency_code_enabled %}
                    {{- compare_at_price | money_with_currency -}}
                  {% else %}
                    {{- compare_at_price | money -}}
                  {% endif %}
                </del>
                <span class="m-cart-item__price--final">
                  {% if settings.currency_code_enabled %}
                    {{- item.final_price | money_with_currency -}}
                  {% else %}
                    {{- item.final_price | money -}}
                  {% endif %}
                </span>
              </div>
              {%- liquid
                assign discount_amount_card3 = compare_at_price | minus: item.final_price
                assign discount_percentage_card3 = discount_amount_card3 | times: 100.0 | divided_by: compare_at_price | round
              -%}
              <span class="m-cart-item__discount-badge m-cart-item__discount-badge--price m-gradient m-color-{{ settings.sale_badge_color_scheme }}">
                {{ discount_percentage_card3 }}% OFF
              </span>
            {%- else -%}
              <span class="m-cart-item__price--regular">
                {% if settings.currency_code_enabled %}
                  {{- item.final_price | money_with_currency -}}
                {% else %}
                  {{- item.final_price | money -}}
                {% endif %}
              </span>
            {%- endif -%}
          </div>
        {% endif %}
      </div>

      {% if settings.cart_drawer_card_style == 'card_4' %}
        <div class="m-cart-item__price m-cart-item__price--card-4">
          {%- liquid
            assign compare_at_price = item.variant.compare_at_price
            assign has_compare_price = false
            if compare_at_price != null and compare_at_price > item.final_price
              assign has_compare_price = true
            endif
          -%}
          {%- if has_compare_price -%}
            <div class="m-cart-item__price-discounted m-cart-item__price-discounted--card-4">
              <span class="m-cart-item__price--final">
                {% if settings.currency_code_enabled %}
                  {{- item.final_price | money_with_currency -}}
                {% else %}
                  {{- item.final_price | money -}}
                {% endif %}
              </span>
              <del class="m-cart-item__price--regular m-cart-item__price--compare">
                {% if settings.currency_code_enabled %}
                  {{- compare_at_price | money_with_currency -}}
                {% else %}
                  {{- compare_at_price | money -}}
                {% endif %}
              </del>
            </div>
          {%- else -%}
            <span class="m-cart-item__price--regular">
              {% if settings.currency_code_enabled %}
                {{- item.final_price | money_with_currency -}}
              {% else %}
                {{- item.final_price | money -}}
              {% endif %}
            </span>
          {%- endif -%}
        </div>
      {% endif %}

      <div class="m-cart-drawer-item__variant m:text-color-subtext">
        {%- unless item.product.has_only_default_variant -%}
          {%- for option in item.options_with_values -%}
            <p class="m-cart-item__option m:text-sm">
              <span class="m:font-medium">
                {{- option.name -}}
                :
              </span>
              {{- option.value -}}
            </p>
          {%- endfor -%}
        {%- endunless -%}
        {% comment %}Properties{% endcomment %}
        {%- liquid
          assign property_size = item.properties | size
          assign properties = 'template ' | split: ' '
          if property_size > 0
            assign properties = item.properties
          endif
        -%}
        {%- for p in properties -%}
          {%- assign property_first_char = p.first | slice: 0 -%}
          <p
            class="m-cart-item__property m:text-sm{% if property_size == 0 or p.last == blank or property_first_char == '_' %} m:hidden{% endif %}"
            data-cart-item-property
          >
            <span class="m:font-medium" data-cart-item-property-name>{{ p.first }}: </span>
            {%- comment -%}
              Check if there was an uploaded file associated
            {%- endcomment -%}
            <span data-cart-item-property-value>
              {%- if p.last contains '/uploads/' -%}
                <a href="{{ p.last }}" data-role="product-upload" target="_blank">{{ p.last | split: '/' | last }}</a>
              {%- else -%}
                {{ p.last }}
              {%- endif -%}
            </span>
          </p>
        {%- endfor -%}
      </div>

      {% unless settings.cart_drawer_card_style == 'card_2' or settings.cart_drawer_card_style == 'card_3' or settings.cart_drawer_card_style == 'card_4' or use_compare_price_style %}
        <div class="m-cart-item__price">
          {%- if item.original_price != item.final_price -%}
            <div class="m-cart-item__price-discounted">
              <del class="m-cart-item__price--regular">
                {% if settings.currency_code_enabled %}
                  {{- item.original_price | money_with_currency -}}
                {% else %}
                  {{- item.original_price | money -}}
                {% endif %}
              </del>
              <span class="m-cart-item__price--final">
                {% if settings.currency_code_enabled %}
                  {{- item.final_price | money_with_currency -}}
                {% else %}
                  {{- item.final_price | money -}}
                {% endif %}
              </span>
            </div>
          {%- else -%}
            <span class="m-cart-item__price--regular">
              {% if settings.currency_code_enabled %}
                {{- item.original_price | money_with_currency -}}
              {% else %}
                {{- item.original_price | money -}}
              {% endif %}
            </span>
          {%- endif -%}

          <div class="m-cart-item__unit-price{% unless item.unit_price_measurement %} m:hidden{% endunless %}">
            <span class="m:visually-hidden m:visually-hidden--inline">{{ 'products.product.unit_price_label' | t }}</span>
            <span class="m:text-sm m:text-color-subtext">
              {%- capture unit_price_separator -%}
              <span aria-hidden="true">/</span>
              <span class="m:visually-hidden">{{ 'general.accessibility.unit_price_separator' | t }}&nbsp;</span>
            {%- endcapture -%}

              {%- capture unit_price_base_unit -%}
                {%- if item.unit_price_measurement.reference_value != 1 -%}
                  {{- item.unit_price_measurement.reference_value -}}
                {%- endif -%}
                {{ item.unit_price_measurement.reference_unit }}
              {%- endcapture -%}

              <span data-unit-price>{{ item.unit_price | money }}</span>
              {{- unit_price_separator -}}
              <span data-unit-price-base-unit>{{- unit_price_base_unit -}}</span>
            </span>
          </div>
        </div>
      {% endunless %}

      {%- if item.discounts.size > 0 -%}
        {%- if settings.cart_drawer_card_style == 'card_3' -%}<div class="m-cart-item__discount-info">{%- endif -%}
        <ul class="m-cart__discount{% if settings.cart_drawer_card_style == 'card_3' %} m-cart__discount--card-3{% endif %}" role="list">
          {%- for discount in item.discounts -%}
            <li class="m-cart__discount--item m:inline-flex m:items-center{% if settings.cart_drawer_card_style == 'card_3' %} m-gradient m-color-{{ settings.sale_badge_color_scheme }}{% endif %}">
              {%- if settings.cart_drawer_card_style == 'card_3' -%}
                <svg class="m-cart__discount--card-3-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M2.8 4C2.48174 4 2.17652 3.87357 1.95147 3.64853C1.72643 3.42348 1.6 3.11826 1.6 2.8C1.6 2.48174 1.72643 2.17652 1.95147 1.95147C2.17652 1.72643 2.48174 1.6 2.8 1.6C3.11826 1.6 3.42348 1.72643 3.64853 1.95147C3.87357 2.17652 4 2.48174 4 2.8C4 3.11826 3.87357 3.42348 3.64853 3.64853C3.42348 3.87357 3.11826 4 2.8 4ZM15.528 7.664L8.328 0.464C8.04 0.176 7.64 0 7.2 0H1.6C0.712 0 0 0.712 0 1.6V7.2C0 7.64 0.176 8.04 0.472 8.328L7.664 15.528C7.96 15.816 8.36 16 8.8 16C9.24 16 9.64 15.816 9.928 15.528L15.528 9.928C15.824 9.64 16 9.24 16 8.8C16 8.352 15.816 7.952 15.528 7.664Z" fill="currentColor"/>
                </svg>
              {%- else -%}
                <svg aria-hidden="true" width="20" height="20" focusable="false" role="presentation" viewBox="0 0 12 13">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M7 .5h3a2 2 0 0 1 2 2v3a.995.995 0 0 1-.293.707l-6 6a1 1 0 0 1-1.414 0l-4-4a1 1 0 0 1 0-1.414l6-6A.995.995 0 0 1 7 .5zm2 2a1 1 0 1 0 2 0 1 1 0 0 0-2 0z" fill="currentColor"></path>
                </svg>
              {%- endif -%}
              {{- discount.title -}}
            </li>
          {%- endfor -%}
        </ul>
        {%- if settings.cart_drawer_card_style == 'card_3' -%}</div>{%- endif -%}
      {%- endif -%}
      <div class="m-cart-drawer-item__quantity m:flex m:items-center">
        {%- if gift_wrap_id == null or item.id != gift_wrap_id -%}
          {%- if item.properties._parentKey == blank -%}
            <m-quantity-input class="m-quantity">
              <button
                class="m-quantity__button"
                name="minus"
                type="button"
                aria-label="{{ 'products.product.decrease_quantity' | t: title: item.product.title }}"
              >
                <svg
                  fill="currentColor"
                  stroke="currentColor"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 384 512"
                >
                  <path d="M376 232H8c-4.42 0-8 3.58-8 8v32c0 4.42 3.58 8 8 8h368c4.42 0 8-3.58 8-8v-32c0-4.42-3.58-8-8-8z"/>
                </svg>
              </button>
              <input
                class="m-quantity__input"
                type="number"
                data-quantity-variant-id="{{ item.variant.id }}"
                name="updates[]"
                value="{{ item.quantity }}"
                {% # theme-check-disable %}
                data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                min="{{ item.variant.quantity_rule.min }}"
                {% if item.variant.quantity_rule.max != null %}
                  max="{{ item.variant.quantity_rule.max }}"
                {% endif %}
                step="{{ item.variant.quantity_rule.increment }}"
                {% # theme-check-enable %}
                id="MinimogDrawer-quantity-{{ item.index | plus: 1 }}"
                data-index="{{ item.index | plus: 1 }}"
              >
              <button
                class="m-quantity__button"
                name="plus"
                type="button"
                aria-label="{{ 'products.product.increase_quantity' | t: title: item.product.title }}"
              >
                <svg
                  fill="currentColor"
                  stroke="currentColor"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 384 512"
                >
                  <path d="M376 232H216V72c0-4.42-3.58-8-8-8h-32c-4.42 0-8 3.58-8 8v160H8c-4.42 0-8 3.58-8 8v32c0 4.42 3.58 8 8 8h160v160c0 4.42 3.58 8 8 8h32c4.42 0 8-3.58 8-8V280h160c4.42 0 8-3.58 8-8v-32c0-4.42-3.58-8-8-8z"/>
                </svg>
              </button>
            </m-quantity-input>
            {%- if has_qty_rules or has_vol_pricing -%}
              <quantity-popover class="quantity-popover m:block m:relative">
                <button
                  class="quantity-popover__button volume-pricing-toggle m-button m-button--blank"
                  aria-label="Open Volume Pricing"
                >
                  <svg
                    class="m-svg-icon"
                    viewBox="0 0 25 24"
                    stroke="currentColor"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12.5 16V11M13 8C13 8.27614 12.7761 8.5 12.5 8.5C12.2239 8.5 12 8.27614 12 8M13 8C13 7.72386 12.7761 7.5 12.5 7.5C12.2239 7.5 12 7.72386 12 8M13 8H12M22.5 12C22.5 17.5228 18.0228 22 12.5 22C6.97715 22 2.5 17.5228 2.5 12C2.5 6.47715 6.97715 2 12.5 2C18.0228 2 22.5 6.47715 22.5 12Z"></path>
                  </svg>
                </button>
                <div class="quantity-popover__wrapper m:blocks-radius-md" hidden>
                  <button class="quantity-popover__close" aria-label="Close">
                    <svg
                      class="m-svg-icon"
                      fill="currentColor"
                      stroke="currentColor"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 320 512"
                    >
                      <path d="M193.94 256L296.5 153.44l21.15-21.15c3.12-3.12 3.12-8.19 0-11.31l-22.63-22.63c-3.12-3.12-8.19-3.12-11.31 0L160 222.06 36.29 98.34c-3.12-3.12-8.19-3.12-11.31 0L2.34 120.97c-3.12 3.12-3.12 8.19 0 11.31L126.06 256 2.34 379.71c-3.12 3.12-3.12 8.19 0 11.31l22.63 22.63c3.12 3.12 8.19 3.12 11.31 0L160 289.94 262.56 392.5l21.15 21.15c3.12 3.12 8.19 3.12 11.31 0l22.63-22.63c3.12-3.12 3.12-8.19 0-11.31L193.94 256z"></path>
                    </svg>
                  </button>
                  {{ qty_rules_vol_pricing }}
                </div>
              </quantity-popover>
            {% endif %}
          {%- endif -%}
        {%- else -%}
          <m-gift-wrapping-input
            class="m-quantity"
            data-product-id="{{ product_id | default: item.product.id }}"
            cart-items-size="{{ cart.items.size }}"
            gift-wraps-in-cart="{{ gift_wraps_in_cart }}"
            items-in-cart="{{ items_in_cart }}"
          >
            <button
              class="m-quantity__button"
              type="button"
              name="minus"
              disabled
              aria-label="{{ 'products.product.decrease_quantity' | t: title: item.product.title }}"
            >
              <svg
                fill="currentColor"
                stroke="currentColor"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 384 512"
              >
                <path d="M376 232H8c-4.42 0-8 3.58-8 8v32c0 4.42 3.58 8 8 8h368c4.42 0 8-3.58 8-8v-32c0-4.42-3.58-8-8-8z"/>
              </svg>
            </button>
            <input
              class="m-quantity__input"
              type="number"
              data-quantity-variant-id="{{ item.variant.id }}"
              name="updates[]"
              value="{{ item.quantity }}"
              {% # theme-check-disable %}
              data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
              min="{{ item.variant.quantity_rule.min }}"
              {% if item.variant.quantity_rule.max != null %}
                max="{{ item.variant.quantity_rule.max }}"
              {% endif %}
              step="{{ item.variant.quantity_rule.increment }}"
              {% # theme-check-enable %}
              id="MinimogQuantity-{{ item.index | plus: 1 }}"
              data-index="{{ item.index | plus: 1 }}"
              disabled="disabled"
            >
            <button
              class="m-quantity__button"
              type="button"
              name="plus"
              disabled
              aria-label="{{ 'products.product.increase_quantity' | t: title: item.product.title }}"
            >
              <svg
                fill="currentColor"
                stroke="currentColor"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 384 512"
              >
                <path d="M376 232H216V72c0-4.42-3.58-8-8-8h-32c-4.42 0-8 3.58-8 8v160H8c-4.42 0-8 3.58-8 8v32c0 4.42 3.58 8 8 8h160v160c0 4.42 3.58 8 8 8h32c4.42 0 8-3.58 8-8V280h160c4.42 0 8-3.58 8-8v-32c0-4.42-3.58-8-8-8z"/>
              </svg>
            </button>
          </m-gift-wrapping-input>
        {%- endif -%}
        {%- if item.properties._parentKey == blank and settings.cart_drawer_card_style != 'card_4' -%}
          <m-cart-remove-button
            id="MinimogCartDrawer-Remove-{{ item.index | plus: 1 }}"
            data-index="{{ item.index | plus: 1 }}"
          >
            {% if settings.cart_drawer_card_style == 'card_3' %}
              <button type="button" class="m-cart-item__remove m-cart-item__remove--icon{% unless gift_wrap_id == nil or item.id != gift_wrap_id %} m:hidden{% endunless %}" aria-label="{{ 'cart.general.remove' | t }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="18" viewBox="0 0 15 18" fill="none" aria-hidden="true">
                  <path d="M1.07143 16C1.07143 16.5304 1.29719 17.0391 1.69906 17.4142C2.10092 17.7893 2.64596 18 3.21429 18H11.7857C12.354 18 12.8991 17.7893 13.3009 17.4142C13.7028 17.0391 13.9286 16.5304 13.9286 16V4H1.07143V16ZM3.21429 6H11.7857V16H3.21429V6ZM11.25 1L10.1786 0H4.82143L3.75 1H0V3H15V1H11.25Z" fill="currentColor"/>
                </svg>
              </button>
            {% else %}
              <span class="m-cart-item__remove m-button--link{% unless gift_wrap_id == nil or item.id != gift_wrap_id %} m:hidden{% endunless %}">
                {{- 'cart.general.remove' | t -}}
              </span>
            {% endif %}
          </m-cart-remove-button>
        {%- endif -%}
      </div>
    </div>
  </div>
  {% comment %}Custom element for FoxKit In-cart upsells{% endcomment %}
  {% liquid
    assign collections = ''
    for collection in item.product.collections
      assign collections = collections | append: collection.id | append: ','
    endfor
  %}
  <foxkit-incart-upsell
    data-collections="{{ collections | remove_last: ',' }}"
    data-product-title="{{ item.product.title }}"
    data-product-id="{{ item.product_id }}"
  ></foxkit-incart-upsell>
</div>
