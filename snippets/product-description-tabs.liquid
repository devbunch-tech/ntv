<!-- /snippets/product-description-tabs.liquid -->
{%- liquid
  assign tab1_content = product.description
  assign tab1_title = tab1_title | default: 'Descrição da peça'
  assign tab2_title = tab2_title | default: 'Composição & Modelagem'

  assign has_tab1 = false
  assign has_tab2 = false
  if tab1_content != blank
    assign has_tab1 = true
  endif
  if tab2_content != blank
    assign has_tab2 = true
  endif
-%}

{%- if has_tab1 or has_tab2 -%}
<m-product-desc-tabs class="m-product-desc-tabs">
