{% comment %}
  Accepts:
  - show_pagination: {Boolean} Show Pagination (optional)
  - show_nav: {Boolean} Show Navigation (optional)
  - pagination_type: {String} Accepted value: bullets/fraction (optional)
  - position: {String} Accepted value: top-left/top-center/top-right/middle-left/middle-right/bottom-left/bottom-center/bottom-right (optional)
  - absolute: {Boolean} (optional)
  - container: {String} (optional)
  - pagination_class: {String} Pagination extra classes (optional)
  - extra_classes: {String} Extra classes (optional)
  - arrow_style: {String} Accepted value: default/line (optional)

  Usage:
  {% render 'slider-controls',
    show_pagination: false,
    show_nav: false,
    pagination_type: 'bullets',
    position: 'bottom-center',
    container: '',
    absolute: false,
    pagination_class: '',
    extra_classes: '',
    arrow_style: 'default'
  %}
{% endcomment %}

{% liquid
  assign pagination_type = pagination_type | default: 'bullets'
  assign position = position | default: 'bottom-center'
  assign arrow_style = arrow_style | default: 'default'

  if show_pagination == null
    assign show_pagination = true
  endif

  assign classes = 'm-slider-controls'
  assign classes = classes | append: ' m-slider-controls--' | append: position

  if show_nav
    assign classes = classes | append: ' m-slider-controls--show-nav'
  endif

  if show_pagination
    assign classes = classes | append: ' m-slider-controls--show-pagination'
    assign classes = classes | append: ' m-slider-controls--pagination-' | append: pagination_type
  endif

  if absolute == true and pagination_type == 'bullets'
    assign classes = classes | append: ' m-slider-controls--absolute'
  else
    assign classes = classes | append: ' m-slider-controls--group'
  endif

  if container == 'w-full' or container == 'container-full'
    assign classes = classes | append: ' m-slider-controls--full'
  endif

  if animated
    assign classes = classes | append: ' m-scroll-trigger animate--' | append: animation_effect
  endif

  if extra_classes
    assign classes = classes | append: ' ' | append: extra_classes
  endif
%}
<div class="{{ classes }}">
  <div class="m-slider-controls__wrapper">
    {% if show_nav %}
      <button
        class="m-slider-controls__button m-slider-controls__button-prev swiper-button-prev {% if arrow_style == 'line' %}m-slider-controls__button--line{% endif %} {{ nav_class }}"
        aria-label="Previous"
      >
        {% if arrow_style == 'line' %}
          <svg width="28" height="16" viewBox="0 0 24 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M7 1L1 7L7 13" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M1 7H23" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
          </svg>
        {% else %}
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        {% endif %}
      </button>
    {% endif %}
    {% if show_pagination %}
      <div class="swiper-pagination m:w-full {{ pagination_class }}"></div>
    {% endif %}
    {% if show_nav %}
      <button
        class="m-slider-controls__button m-slider-controls__button-next swiper-button-next {% if arrow_style == 'line' %}m-slider-controls__button--line{% endif %} {{ nav_class }}"
        aria-label="Next"
      >
        {% if arrow_style == 'line' %}
          <svg width="28" height="16" viewBox="0 0 24 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M17 1L23 7L17 13" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M23 7H1" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
          </svg>
        {% else %}
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        {% endif %}
      </button>
    {% endif %}
  </div>
</div>
