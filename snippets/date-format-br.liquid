{% comment %}
  Formata a data no padrão brasileiro: DD de Mês de YYYY
  Uso: {% render 'date-format-br', date: article.published_at %}
{% endcomment %}

{% liquid
  assign day = date | date: '%d'
  assign month_number = date | date: '%m'
  assign year = date | date: '%Y'

  case month_number
    when '01'
      assign month_name = 'Janeiro'
    when '02'
      assign month_name = 'Fevereiro'
    when '03'
      assign month_name = 'Março'
    when '04'
      assign month_name = 'Abril'
    when '05'
      assign month_name = 'Maio'
    when '06'
      assign month_name = 'Junho'
    when '07'
      assign month_name = 'Julho'
    when '08'
      assign month_name = 'Agosto'
    when '09'
      assign month_name = 'Setembro'
    when '10'
      assign month_name = 'Outubro'
    when '11'
      assign month_name = 'Novembro'
    when '12'
      assign month_name = 'Dezembro'
  endcase
%}
<time datetime="{{ date | date: '%Y-%m-%dT%H:%M:%SZ' }}">{{ day }} de {{ month_name }} de {{ year }}</time>
