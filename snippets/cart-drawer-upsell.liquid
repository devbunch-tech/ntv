{% comment %}
  Upsell do drawer do carrinho.
  Renderiza produtos da coleção handle "upsell" em um slider horizontal.
  Exibido somente quando o carrinho não estiver vazio e houver produtos na coleção
  que ainda não estejam no carrinho.

  Aceita:
  - collection_handle: {String} handle da coleção (default: 'upsell')
  - max_installments: {Number} parcelas exibidas (default: 12)
  - heading: {String} título exibido acima do slider (default: 'Você também pode gostar')
{% endcomment %}

{%- liquid
  assign upsell_handle = collection_handle | default: 'upsell'
  assign upsell_collection = collections[upsell_handle]
  assign max_installments = max_installments | default: 12
  assign heading_text = heading | default: 'Aproveite e leve também:'

  assign cart_product_ids = ''
  for item in cart.items
    assign cart_product_ids = cart_product_ids | append: ',' | append: item.product_id
  endfor

  assign upsell_products_count = 0
  for product in upsell_collection.products
    assign needle = ',' | append: product.id
    unless cart_product_ids contains needle
      assign upsell_products_count = upsell_products_count | plus: 1
    endunless
  endfor
-%}

{%- if cart.items.size > 0 and upsell_products_count > 0 -%}
  {{ 'cart-drawer-upsell.css' | asset_url | stylesheet_tag }}
  <m-cart-upsell class="m-cart-upsell" data-cart-upsell>
    <div class="m-cart-upsell__header">
      <h4 class="m-cart-upsell__title">{{ heading_text }}</h4>
      <div class="m-cart-upsell__nav">
        <button type="button" class="m-cart-upsell__nav-button m-cart-upsell__nav-button--prev" aria-label="Anterior">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button type="button" class="m-cart-upsell__nav-button m-cart-upsell__nav-button--next" aria-label="Próximo">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="m-cart-upsell__slider swiper-container">
      <div class="swiper-wrapper">
        {%- for product in upsell_collection.products -%}
          {%- assign needle = ',' | append: product.id -%}
          {%- if cart_product_ids contains needle -%}{%- continue -%}{%- endif -%}
          {%- assign variant_id = product.first_available_variant.id | default: product.variants.first.id -%}
          {%- assign price = product.price -%}
          {%- assign compare_at_price = product.compare_at_price -%}
          {%- assign installment_value = price | divided_by: max_installments -%}
          {%- assign upsell_form_id = 'cart-upsell-form-' | append: product.id -%}
          <div class="swiper-slide m-cart-upsell__slide">
            <div class="m-cart-upsell-card">
              <a href="{{ product.url }}" class="m-cart-upsell-card__image" aria-label="{{ product.title | escape }}">
                {%- if product.featured_image != blank -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 200 }}"
                    srcset="{{ product.featured_image | image_url: width: 120 }} 120w, {{ product.featured_image | image_url: width: 200 }} 200w, {{ product.featured_image | image_url: width: 320 }} 320w"
                    sizes="80px"
                    loading="lazy"
                    width="80"
                    height="80"
                    alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'm-cart-upsell-card__placeholder' }}
                {%- endif -%}
              </a>
              <div class="m-cart-upsell-card__content">
                <a href="{{ product.url }}" class="m-cart-upsell-card__title">{{ product.title }}</a>
                <div class="m-cart-upsell-card__prices">
                  <span class="m-cart-upsell-card__price">{{ price | money }}</span>
                  {%- if compare_at_price > price -%}
                    <span class="m-cart-upsell-card__compare">{{ compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
                {%- if price > 0 -%}
                  <div class="m-cart-upsell-card__installments">
                    ou {{ max_installments }}x de <strong>{{ installment_value | money }}</strong> sem juros
                  </div>
                {%- endif -%}
              </div>
              <div class="m-cart-upsell-card__action">
                {%- if product.available -%}
                  <product-form data-product-id="{{ product.id }}" class="m-cart-upsell-card__form">
                    {%- form 'product', product, id: upsell_form_id, novalidate: 'novalidate' -%}
                      <input type="hidden" name="id" value="{{ variant_id }}">
                      <button
                        type="submit"
                        name="add"
                        class="m-cart-upsell-card__button m-add-to-cart m-spinner-button"
                        aria-label="Adicionar {{ product.title | escape }} ao carrinho"
                      >
                        <span class="m-spinner-icon">
                          <svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" width="16" height="16">
                            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                          </svg>
                        </span>
                        <span class="m-add-to-cart--text" data-atc-text>Adicionar</span>
                      </button>
                    {%- endform -%}
                  </product-form>
                {%- else -%}
                  <button type="button" class="m-cart-upsell-card__button m-cart-upsell-card__button--disabled" disabled>Esgotado</button>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </m-cart-upsell>

  <script>
    if (!customElements.get('m-cart-upsell')) {
      customElements.define('m-cart-upsell', class extends HTMLElement {
        connectedCallback() {
          this._tryInit();
        }
        _tryInit(attempts) {
          attempts = attempts || 0;
          var SwiperLib = (window.MinimogLibs && window.MinimogLibs.Swiper) || window.Swiper;
          if (!SwiperLib) {
            if (attempts > 80) {
              console.warn('[cart-drawer-upsell] Swiper indisponível, slider não inicializado.');
              return;
            }
            return setTimeout(this._tryInit.bind(this, attempts + 1), 100);
          }
          var container = this.querySelector('.m-cart-upsell__slider');
          if (!container || container.dataset.swiperInitialized === '1') return;
          var prevEl = this.querySelector('.m-cart-upsell__nav-button--prev');
          var nextEl = this.querySelector('.m-cart-upsell__nav-button--next');
          var slidesCount = container.querySelectorAll('.swiper-slide').length;
          var useLoop = slidesCount > 1;
          try {
            this._swiper = new SwiperLib(container, {
              slidesPerView: 1,
              spaceBetween: 12,
              loop: useLoop,
              speed: 500,
              autoplay: useLoop ? { delay: 5000, disableOnInteraction: false, pauseOnMouseEnter: true } : false,
              navigation: { prevEl: prevEl, nextEl: nextEl }
            });
            container.dataset.swiperInitialized = '1';
          } catch (e) {
            console.warn('[cart-drawer-upsell] falha ao inicializar Swiper:', e);
          }
        }
        disconnectedCallback() {
          if (this._swiper && typeof this._swiper.destroy === 'function') {
            try { this._swiper.destroy(true, true); } catch (e) {}
          }
        }
      });
    }
  </script>
{%- endif -%}
