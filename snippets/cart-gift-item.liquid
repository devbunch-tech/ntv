{%- comment -%}
  Produto brinde virtual - exibido quando o cliente atinge a meta de valor
  Este item é apenas visual e não é enviado no checkout
{%- endcomment -%}

{%- liquid
  assign gift_product = settings.cart_drawer_gift_product
  assign threshold_type = settings.cart_drawer_promo_threshold_type | default: 'value'
  assign is_goal_reached = false
  if threshold_type == 'quantity'
    assign threshold_qty = settings.cart_drawer_promo_threshold_quantity | default: 3
    if cart.item_count >= threshold_qty
      assign is_goal_reached = true
    endif
  else
    assign promo_threshold = settings.cart_drawer_promo_threshold
    assign cart_total = cart.total_price | divided_by: 100.0
    if cart_total >= promo_threshold
      assign is_goal_reached = true
    endif
  endif
-%}

{%- if settings.cart_drawer_progress_type == 'gift' and gift_product != blank and is_goal_reached and cart.item_count > 0 -%}
  {%- liquid
    assign gift_variant = gift_product.selected_or_first_available_variant
    assign gift_image = gift_variant.featured_image | default: gift_product.featured_image
    
    if gift_variant.compare_at_price != null and gift_variant.compare_at_price > 0
      assign gift_original_price = gift_variant.compare_at_price
    else
      assign gift_original_price = gift_variant.price
    endif
    
    assign discount_percentage = 100
  -%}

  <div
    class="m-cart-item m-cart-drawer-item m-cart-gift-item"
    data-gift-item
    data-gift-value="{{ gift_original_price }}"
  >
    <div class="m-cart-item--drawer__wrapper m:flex m:items-start">
      <div class="m-cart-drawer-item__image m-cart-item__image m:blocks-radius-md">
        <a href="{{ gift_product.url }}">
          {%- if gift_image -%}
            {% render 'responsive-image', image: gift_image, wrapper_class: 'm-cart-item__image' %}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'm-placeholder-svg' }}
          {%- endif -%}
        </a>
      </div>
      <div class="m-cart-item__info m-cart-drawer-item__info m-cart-item__info--card-3">
        <div class="m-cart-item__header m-cart-item__header--card-3">
          <a href="{{ gift_product.url }}" class="m-cart-item__title">
            {{ gift_product.title }}
          </a>
          <div class="m-cart-item__price m-cart-item__price--card-3">
            <div class="m-cart-item__price-discounted m-cart-item__price-discounted--card-3">
              <del class="m-cart-item__price--regular m-cart-item__price--compare">
                {% if settings.currency_code_enabled %}
                  {{ gift_original_price | money_with_currency }}
                {% else %}
                  {{ gift_original_price | money }}
                {% endif %}
              </del>
              <span class="m-cart-item__price--final m-cart-item__price--free">
                {% if settings.currency_code_enabled %}
                  {{ 0 | money_with_currency }}
                {% else %}
                  {{ 0 | money }}
                {% endif %}
              </span>
            </div>
            <span class="m-cart-item__discount-badge m-cart-item__discount-badge--price m-cart-gift-item__discount-badge">
              {{ discount_percentage }}% OFF
            </span>
          </div>
        </div>

        <div class="m-cart-item__discount-info">
          <span class="m-cart-gift-item__badge m-gradient m-color-{{ settings.sale_badge_color_scheme }}">🎁 BRINDE</span>
        </div>
      </div>
    </div>
  </div>
{%- endif -%}
