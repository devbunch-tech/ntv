{%- liquid
  assign show_promo_bar = false
  if settings.cart_drawer_progress_type == 'free_shipping'
    assign show_promo_bar = true
  elsif settings.cart_drawer_progress_type == 'gift' and settings.cart_drawer_gift_product != blank
    assign show_promo_bar = true
  endif
-%}
{%- if show_promo_bar -%}
  {%- liquid
    assign threshold_type = settings.cart_drawer_promo_threshold_type | default: 'value'
    assign cart_total = cart.total_price | divided_by: 100.0
    assign is_goal_reached = false
    assign progress_percentage = 0
    assign remaining_amount = 0
  -%}
  {%- if threshold_type == 'quantity' -%}
    {%- liquid
      assign promo_threshold_qty = settings.cart_drawer_promo_threshold_quantity | default: 3
      assign progress_percentage = cart.item_count | times: 100 | divided_by: promo_threshold_qty | at_least: 0 | at_most: 100
      assign remaining_amount = promo_threshold_qty | minus: cart.item_count | at_least: 0
      if cart.item_count >= promo_threshold_qty
        assign is_goal_reached = true
      endif
    -%}
  {%- else -%}
    {%- liquid
      assign promo_threshold = settings.cart_drawer_promo_threshold
      assign progress_percentage = cart_total | times: 100 | divided_by: promo_threshold | at_least: 0 | at_most: 100
      assign remaining_amount = promo_threshold | minus: cart_total | at_least: 0
      if cart_total >= promo_threshold
        assign is_goal_reached = true
      endif
    -%}
  {%- endif -%}

  {%- liquid
    assign progress_color = settings.cart_drawer_promo_bar_color | default: 'linear-gradient(90deg, #4ade80, #22c55e)'
    assign progress_bg_color = settings.cart_drawer_promo_bar_bg_color | default: '#e5e7eb'
    assign display_value = 'none'
    if cart.item_count > 0
      assign display_value = 'block'
    endif
    assign bar_style = settings.cart_drawer_promo_bar_style | default: 'default'
  -%}

  {%- liquid
    assign success_text = settings.promo_bar_success_text | default: 'Parabéns! Você ganhou Frete Grátis'
    assign remaining_text = settings.promo_bar_remaining_text | default: 'Faltam {{ amount }} para você ganhar o Frete Grátis'
    assign info_text = settings.promo_bar_info_text | default: 'Frete Grátis a partir de {{ amount }}'
  -%}

  {%- if threshold_type == 'quantity' -%}
    {%- capture remaining_amount_formatted -%}{% if remaining_amount == 1 %}1 item{% else %}{{ remaining_amount }} itens{% endif %}{%- endcapture -%}
    {%- capture threshold_amount_formatted -%}{% if promo_threshold_qty == 1 %}1 item{% else %}{{ promo_threshold_qty }} itens{% endif %}{%- endcapture -%}
  {%- else -%}
    {%- capture remaining_amount_formatted -%}{{ remaining_amount | money_without_currency | round: 2 }}{%- endcapture -%}
    {%- capture threshold_amount_formatted -%}{{ settings.cart_drawer_promo_threshold | times: 100 | money }}{%- endcapture -%}
  {%- endif -%}

  {%- if threshold_type == 'quantity' -%}
    {%- assign data_threshold_value = promo_threshold_qty -%}
  {%- else -%}
    {%- assign data_threshold_value = promo_threshold -%}
  {%- endif -%}

  <m-cart-promo-bar
    class="m-cart-promo-bar{% if bar_style == 'inline' %} m-cart-promo-bar--inline{% endif %}"
    data-cart-promo-bar
    data-threshold-type="{{ threshold_type }}"
    data-cart-total="{{ cart_total }}"
    data-cart-item-count="{{ cart.item_count }}"
    data-threshold="{{ data_threshold_value }}"
    data-style="{{ bar_style }}"
    data-msg-success="{{ success_text | escape }}"
    data-msg-remaining="{{ remaining_text | escape }}"
    style="--progress-color: {{ progress_color }}; --progress-bg-color: {{ progress_bg_color }}; --progress-percentage: {{ progress_percentage }}%; display: {{ display_value }};"
  >
    {%- if bar_style == 'default' -%}
      <div class="m-cart-promo-bar__message">
        {%- if is_goal_reached -%}
          <span class="m-cart-promo-bar__success">
            {{ success_text | replace: 'Frete Grátis', '<green>Frete Grátis</green>' }}
          </span>
        {%- else -%}
          <span class="m-cart-promo-bar__remaining">
            {%- assign remaining_parts = remaining_text | split: '{{ amount }}' -%}
            {{ remaining_parts[0] }}{{ remaining_amount_formatted }}{% if remaining_parts[1] %}{{ remaining_parts[1] }}{% endif %}
          </span>
        {%- endif -%}
      </div>

      <div class="m-cart-promo-bar__bar">
        <div class="m-cart-promo-bar__bar-bg"></div>
        <div class="m-cart-promo-bar__bar-fill"></div>
        <div class="m-cart-promo-bar__icon">
          {%- if settings.cart_drawer_progress_type == 'gift' -%}
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="40" height="40" rx="20" fill="black"/>
