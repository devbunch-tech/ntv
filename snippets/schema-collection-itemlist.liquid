{%- comment -%}
  ===== Schema.org ItemList para carrossel Google (formato compatível) =====
  - ListItem com position + item apenas (evita propriedades mutuamente exclusivas)
  - Product dentro de item com estrutura mínima para carrossel
  - @id obrigatório para evitar "Item sem nome"
  - Sem AggregateOffer aninhado (causa conflito no carrossel)
{%- endcomment -%}
{%- if collection.products != empty and collection.title != blank -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ collection.title | json }},
  {%- if collection.description != blank -%}
    "description": {{ collection.description | strip_html | truncate: 300 | json }},
  {%- endif -%}
  "url": {{ request.origin | append: collection.url | json }},
  "numberOfItems": {{ collection.products_count | default: collection.products.size }},
  "itemListElement": [
    {%- assign _first = true -%}
    {%- for product in collection.products limit: 30 -%}
      {%- if product.title != blank -%}
        {%- unless _first -%},{%- endunless -%}
        {%- assign _first = false -%}
    {
      "@type": "ListItem",
      "position": {{ forloop.index }},
      "item": {
        "@type": "Product",
        "@id": {{ request.origin | append: product.url | append: '#product' | json }},
        "name": {{ product.title | json }},
        "url": {{ request.origin | append: product.url | json }}
        {%- if product.featured_image -%}
          ,"image": {{ product.featured_image | image_url: width: product.featured_image.width | prepend: "https:" | json }}
        {%- endif -%}
        {%- if product.vendor != blank -%}
          ,"brand": {
            "@type": "Brand",
            "name": {{ product.vendor | json }}
          }
        {%- endif -%}
        ,"offers": {
          "@type": "Offer",
          "url": {{ request.origin | append: product.url | json }},
          "priceCurrency": {{ cart.currency.iso_code | json }},
          "price": {{ product.price_min | divided_by: 100.00 | json }},
          "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}"
        }
      }
    }
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}
