  {%- if enable_installment -%}
  <!-- Parcelamento -->
  <div class="m-product-benefits__card">
    <div class="m-product-benefits__header">
      <span class="m-product-benefits__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M1.66602 10.0002C1.66602 6.85766 1.66602 5.286 2.64268 4.31016C3.61935 3.33433 5.19018 3.3335 8.33268 3.3335H11.666C14.8085 3.3335 16.3802 3.3335 17.356 4.31016C18.3318 5.28683 18.3327 6.85766 18.3327 10.0002C18.3327 13.1427 18.3327 14.7143 17.356 15.6902C16.3793 16.666 14.8085 16.6668 11.666 16.6668H8.33268C5.19018 16.6668 3.61852 16.6668 2.64268 15.6902C1.66685 14.7135 1.66602 13.1427 1.66602 10.0002Z" stroke="#656565"/>
          <path d="M8.33268 13.3335H4.99935M11.666 13.3335H10.416M1.66602 8.3335H18.3327" stroke="#656565" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="m-product-benefits__title">{{ installment_title }}</span>
    </div>
    <p class="m-product-benefits__desc">{{ installment_desc }}</p>
  </div>
  {%- endif -%}
</div>

<script>
  document.querySelectorAll('.m-product-benefits__copy-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var coupon = this.getAttribute('data-coupon');
      navigator.clipboard.writeText(coupon).then(function() {
        btn.querySelector('span').textContent = 'Copiado!';
        setTimeout(function() {
          btn.querySelector('span').textContent = 'Copiar cupom';
        }, 2000);
      });
    });
  });
</script>
{%- endif -%}
