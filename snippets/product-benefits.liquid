          <path d="M11.666 7.5L11.666 7.5075M6.66602 12.4925L6.66602 12.5" stroke="#656565" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="m-product-benefits__title">{{ coupon_title }}</span>
    </div>
    <div class="m-product-benefits__coupon-row">
      <span class="m-product-benefits__coupon-code">{{ coupon_code }}</span>
