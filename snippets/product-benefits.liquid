<!-- /snippets/product-benefits.liquid -->
{%- liquid
  assign count = 0
  if enable_coupon
    assign count = count | plus: 1
  endif
  if enable_exchange
    assign count = count | plus: 1
  endif
  if enable_installment
    assign count = count | plus: 1
  endif
-%}

{%- if count > 0 -%}
<div class="m-product-benefits m-product-benefits--cols-{{ count }}">
  {%- if enable_coupon -%}
  <!-- Cupom -->
  <div class="m-product-benefits__card m-product-benefits__card--coupon">
    <div class="m-product-benefits__header">
      <span class="m-product-benefits__icon">
