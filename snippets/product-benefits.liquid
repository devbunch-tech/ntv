        <path d="M1.625 5.97H1.16667C0.923552 5.97 0.690394 5.87729 0.518485 5.71225C0.346577 5.54722 0.25 5.32339 0.25 5.09V1.13C0.25 0.896609 0.346577 0.672778 0.518485 0.507746C0.690394 0.342714 0.923552 0.25 1.16667 0.25H5.29167C5.53478 0.25 5.76794 0.342714 5.93985 0.507746C6.11176 0.672778 6.20833 0.896609 6.20833 1.13V1.57" stroke="#656565" stroke-width="0.5"/>
