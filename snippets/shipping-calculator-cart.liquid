{% comment %}
  Calculadora de frete para o CARRINHO.
  Usa o carrinho atual (não limpa nem adiciona produto).
  Use no cart-addons no lugar do bloco de estimate shipping.
  Textos customizáveis via variáveis ao renderizar (opcional):
  {% render 'shipping-calculator-cart',
    title: 'Cálcule seu Frete',
    placeholder: 'Digite seu CEP',
    button_text: 'CALCULAR',
    free_shipping_text: 'Grátis',
    error_message: 'CEP não encontrado, tente novamente.'
  %}
{% endcomment %}
{% liquid
  assign calc_title = title | default: 'Cálcule seu Frete'
  assign calc_placeholder = placeholder | default: 'Digite seu CEP'
  assign calc_button_text = button_text | default: 'CALCULAR'
  assign calc_free_shipping_text = free_shipping_text | default: 'Grátis'
  assign calc_error_message = error_message | default: 'CEP não encontrado, tente novamente.'
%}
{% stylesheet %}
  .frete-calculo-cart { margin: 15px 0; }
  .frete-calculo-cart .frete-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .frete-calculo-cart .frete-header__title { font-family: var(--font-body-family); font-size: 14px; font-weight: 500; color: #000; letter-spacing: -0.7px; margin: 0; }
  .frete-calculo-cart .frete-form { display: flex; gap: 8px; }
  .frete-calculo-cart .frete-form__input { flex: 1; min-width: 0; height: 43px; padding: 0 16px; border: 1px solid #d9d9d9; border-radius: 3px; font-family: var(--font-body-family); font-size: 14px; font-weight: 300; color: #000; letter-spacing: -0.7px; outline: none; transition: border-color 0.2s ease; }
  .frete-calculo-cart .frete-form__input::placeholder { color: #8f8f8f; }
  .frete-calculo-cart .frete-form__input:focus { border-color: #414141; }
  .frete-calculo-cart .frete-form__button { flex-shrink: 0; height: 43px; padding: 0 24px; background: #414141 !important; background-color: #414141 !important; border: none !important; border-radius: 3px; font-family: var(--font-body-family); font-size: 12px; font-weight: 500; color: #fff !important; letter-spacing: -0.24px; text-transform: uppercase; cursor: pointer; transition: background-color 0.2s ease; white-space: nowrap; }
  .frete-calculo-cart .frete-form__button:hover { background: #2a2a2a !important; background-color: #2a2a2a !important; }
  .frete-calculo-cart .frete-error { color: #c00; font-size: 14px; margin-top: 10px; display: none; }
  .frete-calculo-cart .frete-results { margin-top: 12px; padding: 0 12px; border-radius: 3px; background: #f5f5f5; display: none; }
  .frete-calculo-cart .frete-item { display: flex; justify-content: space-between; align-items: flex-start; padding: 10px 0; }
  .frete-calculo-cart .frete-item + .frete-item { border-top: 1px solid #d9d9d9; }
  .frete-calculo-cart .frete-item__name { font-size: 14px; font-weight: 500; color: #000; margin: 0; }
  .frete-calculo-cart .frete-item__delivery { font-size: 12px; font-weight: 400; color: #666; margin-top: 2px; }
  .frete-calculo-cart .frete-item__price { font-size: 14px; font-weight: 500; color: #000; text-align: right; white-space: nowrap; }
  #pais-simulator-cart, #estados-simulator-cart { display: none; }
  @media screen and (max-width: 400px) { .frete-calculo-cart .frete-form__button { padding: 0 16px; } }
{% endstylesheet %}

<div
  class="frete-calculo frete-calculo-cart"
  data-error-message="{{ calc_error_message | escape }}"
  data-free-shipping-text="{{ calc_free_shipping_text | escape }}"
  data-cart-calculator
>
  <div class="frete-header">
    <h4 class="frete-header__title">{{ calc_title }}</h4>
  </div>
  <div class="frete-form" id="frete-form-cart">
    <select id="pais-simulator-cart" name="shipping_address[country]">
      <option value="Brazil" selected>Brazil</option>
    </select>
    <select id="estados-simulator-cart" name="shipping_address[province]">
      <option value="Acre">Acre</option>
      <option value="Alagoas">Alagoas</option>
      <option value="Amapa">Amapá</option>
      <option value="Amazonas">Amazonas</option>
      <option value="Bahia">Bahia</option>
      <option value="Ceara">Ceará</option>
      <option value="Distrito Federal">Distrito Federal</option>
      <option value="Espirito Santo">Espírito Santo</option>
      <option value="Goias">Goiás</option>
      <option value="Maranhao">Maranhão</option>
      <option value="Mato Grosso">Mato Grosso</option>
      <option value="Mato Grosso do Sul">Mato Grosso do Sul</option>
      <option value="Minas Gerais">Minas Gerais</option>
      <option value="Para">Pará</option>
      <option value="Paraiba">Paraíba</option>
      <option value="Parana">Paraná</option>
      <option value="Pernambuco">Pernambuco</option>
      <option value="Piaui">Piauí</option>
      <option value="Rio de Janeiro">Rio de Janeiro</option>
      <option value="Rio Grande do Norte">Rio Grande do Norte</option>
      <option value="Rio Grande do Sul">Rio Grande do Sul</option>
      <option value="Rondonia">Rondônia</option>
      <option value="Roraima">Roraima</option>
      <option value="Santa Catarina">Santa Catarina</option>
      <option value="Sao Paulo">São Paulo</option>
      <option value="Sergipe">Sergipe</option>
      <option value="Tocantins">Tocantins</option>
    </select>
    <input
      type="text"
      id="frete-cep-cart"
      name="shipping_address[zip]"
      class="frete-form__input"
      placeholder="{{ calc_placeholder }}"
      maxlength="10"
    >
    <button type="button" id="frete-calcular-cart" class="frete-form__button">
      {{ calc_button_text }}
    </button>
  </div>
  <p class="frete-error" id="frete-error-cart"></p>
  <div class="frete-results" id="frete-results-cart"></div>
</div>

{% javascript %}
  (function() {
    "use strict";
    var root = document.querySelector("[data-cart-calculator]");
    if (!root) return;

    /** Testa se o ViaCEP está online; se não estiver, oculta o calculador e o botão de frete do carrinho. */
    function checkViaCEP() {
      var url = "https://viacep.com.br/ws/01310100/json/";
      var timeoutMs = 5000;
      function tryFetch() {
        return Promise.race([
          fetch(url).then(function(r) { return r.json(); }).then(function() { return true; }),
          new Promise(function(_, rej) { setTimeout(function() { rej(new Error("timeout")); }, timeoutMs); })
        ]);
      }
      return tryFetch().catch(function() { return tryFetch(); }).catch(function() { return false; });
    }

    checkViaCEP().then(function(online) {
      if (!online) {
        root.style.display = "none";
        var addons = root.closest("m-cart-addons");
        if (addons) {
          var shippingBtn = addons.querySelector('button[data-open="shipping"]');
          if (shippingBtn) shippingBtn.style.display = "none";
        }
        return;
      }

      var shippingZip = document.getElementById("frete-cep-cart");
      var shippingCountry = document.getElementById("pais-simulator-cart");
      var shippingProvince = document.getElementById("estados-simulator-cart");
      var shippingMessage = document.getElementById("frete-error-cart");
      var freteLista = document.getElementById("frete-results-cart");
      var calcularBtn = document.getElementById("frete-calcular-cart");
      if (!shippingZip || !calcularBtn) return;

      var config = {
      errorMessage: root.dataset.errorMessage || "CEP não encontrado, tente novamente.",
      freeShippingText: root.dataset.freeShippingText || "Grátis"
    };

    function formatMoney(cents, format) {
      if (typeof window.MinimogSettings !== "undefined" && window.MinimogSettings.money_format) {
        format = window.MinimogSettings.money_format;
      }
      if (!format) format = "R$ {{amount}}";
      var value = (cents / 100).toFixed(2).replace(/\d(?=(\d{3})+\.)/g, "$1,");
      return format.replace("{{amount}}", value).replace("{{amount_no_decimals}}", Math.round(cents / 100)).replace("{{amount_with_comma_separator}}", value);
    }

    shippingZip.addEventListener("input", function(e) {
      var value = e.target.value.replace(/\D/g, "");
      if (value.length > 8) value = value.slice(0, 8);
      if (value.length > 5) value = value.slice(0, 2) + "." + value.slice(2, 5) + "-" + value.slice(5);
      else if (value.length > 2) value = value.slice(0, 2) + "." + value.slice(2);
      e.target.value = value;
    });

    function isDateBeforeToday(date) {
      return new Date(date.toDateString()) < new Date(new Date().toDateString());
    }
    function excludeDate(name) {
      return name !== "Entrega Expressa - pedidos feitos até 11h chegam em até 24hrs úteis" && name !== "Entrega Rápida - pedidos chegam em até 48hrs úteis";
    }

    calcularBtn.addEventListener("click", function(e) {
      e.preventDefault();
      var cepLimpo = shippingZip.value.replace(/\D/g, "");
      if (cepLimpo.length < 8) {
        shippingMessage.textContent = "CEP inválido";
        shippingMessage.style.display = "block";
        return;
      }
      shippingMessage.textContent = "";
      shippingMessage.style.display = "none";

      fetch("https://viacep.com.br/ws/" + cepLimpo + "/json/")
        .then(function(r) { return r.json(); })
        .then(function(dados) {
          if (!("erro" in dados)) {
            var ufMap = { "AC": "Acre", "AL": "Alagoas", "AP": "Amapa", "AM": "Amazonas", "BA": "Bahia", "CE": "Ceara", "DF": "Distrito Federal", "ES": "Espirito Santo", "GO": "Goias", "MA": "Maranhao", "MT": "Mato Grosso", "MS": "Mato Grosso do Sul", "MG": "Minas Gerais", "PA": "Para", "PB": "Paraiba", "PR": "Parana", "PE": "Pernambuco", "PI": "Piaui", "RJ": "Rio de Janeiro", "RN": "Rio Grande do Norte", "RS": "Rio Grande do Sul", "RO": "Rondonia", "RR": "Roraima", "SC": "Santa Catarina", "SP": "Sao Paulo", "SE": "Sergipe", "TO": "Tocantins" };
            shippingProvince.value = ufMap[dados.uf] || dados.uf;
            getRatesCart();
          } else {
            freteLista.innerHTML = "";
            freteLista.style.display = "none";
            shippingMessage.textContent = config.errorMessage;
            shippingMessage.style.display = "block";
          }
        })
        .catch(function() {
          freteLista.innerHTML = "";
          freteLista.style.display = "none";
          shippingMessage.textContent = config.errorMessage;
          shippingMessage.style.display = "block";
        });
    });

    function getRatesCart() {
      shippingMessage.style.display = "none";
      freteLista.style.display = "block";
      freteLista.innerHTML = '<div style="display:flex;justify-content:center;padding:20px;"><svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="animation:spin 1s linear infinite"><style>@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}</style><circle cx="12" cy="12" r="10" stroke="#d9d9d9" stroke-width="3" fill="none"/><path d="M12 2a10 10 0 0 1 10 10" stroke="#414141" stroke-width="3" fill="none" stroke-linecap="round"/></svg></div>';

      var params = new URLSearchParams({
        "shipping_address[country]": shippingCountry.value,
        "shipping_address[province]": shippingProvince.value,
        "shipping_address[zip]": shippingZip.value.replace(/\D/g, "")
      });

      fetch("/cart/shipping_rates.json?_easygift_internal=true&" + params.toString(), {
        credentials: "same-origin",
        headers: { "Content-Type": "application/json" }
      })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.shipping_rates && d.shipping_rates.length) {
            freteLista.innerHTML = "";
            for (var i = 0; i < d.shipping_rates.length; i++) {
              var deliveryDate = d.shipping_rates[i].delivery_date;
              var entrega = deliveryDate ? new Date(d.shipping_rates[i].delivery_date) : null;
              var checkBeforeday = entrega ? isDateBeforeToday(entrega) : true;
              var excludeDateCheck = excludeDate(d.shipping_rates[i].name);
              var dataFormatada = entrega ? entrega.getDate() + "/" + (entrega.getMonth() + 1) + "/" + entrega.getFullYear() : "";
              var valorFrete = d.shipping_rates[i].price;
              if (valorFrete === "0.00" || valorFrete == null) valorFrete = config.freeShippingText;
              else valorFrete = formatMoney(parseFloat(valorFrete) * 100, null);
              var entregaText = "";
              if (deliveryDate == null && excludeDateCheck || (entrega && checkBeforeday && excludeDateCheck)) entregaText = "Estimativa de entrega indisponível";
              else if (!excludeDateCheck) entregaText = "";
              else entregaText = "(Estimativa de entrega: " + dataFormatada + ")";
              var freteItem = document.createElement("div");
              freteItem.className = "frete-item";
              freteItem.innerHTML = '<div class="frete-item__info"><p class="frete-item__name">' + d.shipping_rates[i].name + "</p>" + (entregaText ? '<span class="frete-item__delivery">' + entregaText + "</span>" : "") + "</div><div class=\"frete-item__price\">" + valorFrete + "</div>";
              freteLista.appendChild(freteItem);
            }
          } else {
            freteLista.innerHTML = "";
            freteLista.style.display = "none";
            shippingMessage.textContent = config.errorMessage;
            shippingMessage.style.display = "block";
          }
        })
        .catch(function(err) {
          console.error(err);
          freteLista.innerHTML = "";
          freteLista.style.display = "none";
          shippingMessage.textContent = config.errorMessage;
          shippingMessage.style.display = "block";
        });
    }
    });
  })();
{% endjavascript %}
