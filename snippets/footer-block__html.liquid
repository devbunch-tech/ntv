<div class="{% if block.settings.title != blank %}m-accordion--item-content{% endif %} m-footer--block-content">
  {% if block.settings.html != blank %}
    <div class="block-text">
      {{ block.settings.html }}
    </div>
  {% endif %}
  {% if block.settings.show_social_icons %}
    <div class="block-text m:hidden md:m:block{% if block.settings.html != blank %} m:mt-4{% endif %}">
      {% render 'social-media-links', size: 'm-svg-icon--medium', extra_classes: 'justify-center md:justify-start' %}
    </div>
  {% endif %}
</div>
